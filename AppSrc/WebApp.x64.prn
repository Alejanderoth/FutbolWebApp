36779>>>>>>>    Function RandomBuffer UInteger uiSize Returns UChar[]
36781>>>>>>>        UChar[] ucaBuffer
36782>>>>>>>        Move (ResizeArray(ucaBuffer, uiSize)) to ucaBuffer
36783>>>>>>>        If (CNG_BCryptGenRandom(0, AddressOf(ucaBuffer), uiSize, |CI$00000002 /*BCRYPT_USE_SYSTEM_PREFERRED_RNG*/)) Begin
36785>>>>>>>            Error 8710 "Failed to create random buffer."
36786>>>>>>>>
36786>>>>>>>        End
36786>>>>>>>>
36786>>>>>>>        Function_Return ucaBuffer
36787>>>>>>>    End_Function
36788>>>>>>>    
36788>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
36790>>>>>>>        Integer iErr
36790>>>>>>>        Pointer pBase64
36790>>>>>>>        String sBase64
36790>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
36791>>>>>>>        If (not(pBase64)) Begin
36793>>>>>>>            Function_Return sBase64
36794>>>>>>>        End
36794>>>>>>>>
36794>>>>>>>        Move (PointerToString(pBase64)) to sBase64
36795>>>>>>>        Move (Free(pBase64)) to iErr
36796>>>>>>>        Function_Return sBase64
36797>>>>>>>    End_Function
36798>>>>>>>    
36798>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36800>>>>>>>        Integer iLen
36800>>>>>>>        Pointer pBase64
36800>>>>>>>        UChar[] ucaBuffer
36801>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36802>>>>>>>        If (not(pBase64)) Begin
36804>>>>>>>            Function_Return ucaBuffer
36805>>>>>>>        End
36805>>>>>>>>
36805>>>>>>>        
36805>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36806>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36807>>>>>>>        Move (Free(pBase64)) to iLen
36808>>>>>>>        Function_Return ucaBuffer
36809>>>>>>>    End_Function
