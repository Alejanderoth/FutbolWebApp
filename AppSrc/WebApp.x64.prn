37681>>>        tWebNavigateData NavigateData
37681>>>        tWebNavigateData NavigateData
37681>>>        Boolean bHasRecord
37681>>>        Handle hoDD
37681>>>
37681>>>        Get Server to hoDD
37682>>>        Get GetNavigateData to NavigateData
37683>>>        
37683>>>        If (hoDD) Begin
37685>>>            Get HasRecord of hoDD to bHasRecord
37686>>>        End
37686>>>>
37686>>>        Else Begin
37687>>>            Move False to bHasRecord
37688>>>        End
37688>>>>
37688>>>
37688>>>        // let's hide all buttons and then show the ones we want
37688>>>        WebSet pbRender of oEditBtn to False 
37689>>>        WebSet pbRender of oSaveBtn to False
37690>>>        WebSet pbRender of oCancelChangesBtn to False
37691>>>        WebSet pbRender of oDeleteBtn to False
37692>>>
37692>>>        If (NavigateData.bReadOnly) Begin 
37694>>>            WebSet pbRender of oEditBtn to True 
37695>>>        End
37695>>>>
37695>>>        Else Begin
37696>>>            WebSet pbRender of oSaveBtn to True
37697>>>            WebSet pbRender of oCancelChangesBtn to True
37698>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37699>>>        End
37699>>>>
