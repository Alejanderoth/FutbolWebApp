37590>>>    Procedure SetActionButtons
37593>>>        tWebNavigateData NavigateData
37593>>>        tWebNavigateData NavigateData
37593>>>        Boolean bHasRecord
37593>>>        Handle hoDD
37593>>>
37593>>>        Get Server to hoDD
37594>>>        Get GetNavigateData to NavigateData
37595>>>        
37595>>>        If (hoDD) Begin
37597>>>            Get HasRecord of hoDD to bHasRecord
37598>>>        End
37598>>>>
37598>>>        Else Begin
37599>>>            Move False to bHasRecord
37600>>>        End
37600>>>>
37600>>>
37600>>>        // let's hide all buttons and then show the ones we want
37600>>>        WebSet pbRender of oEditBtn to False 
37601>>>        WebSet pbRender of oSaveBtn to False
37602>>>        WebSet pbRender of oCancelChangesBtn to False
37603>>>        WebSet pbRender of oDeleteBtn to False
37604>>>
37604>>>        If (NavigateData.bReadOnly) Begin 
37606>>>            WebSet pbRender of oEditBtn to True 
37607>>>        End
37607>>>>
37607>>>        Else Begin
37608>>>            WebSet pbRender of oSaveBtn to True
37609>>>            WebSet pbRender of oCancelChangesBtn to True
37610>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37611>>>        End
