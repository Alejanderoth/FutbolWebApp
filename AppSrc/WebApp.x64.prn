37481>>>    // This can be used to show and hide buttons based on context.
37481>>>    // This can be called any time the view is active.
37481>>>    Procedure SetActionButtons
37484>>>        tWebNavigateData NavigateData
37484>>>        tWebNavigateData NavigateData
37484>>>        Boolean bHasRecord
37484>>>        Handle hoDD
37484>>>
37484>>>        Get Server to hoDD
37485>>>        Get GetNavigateData to NavigateData
37486>>>        
37486>>>        If (hoDD) Begin
37488>>>            Get HasRecord of hoDD to bHasRecord
37489>>>        End
37489>>>>
37489>>>        Else Begin
37490>>>            Move False to bHasRecord
37491>>>        End
37491>>>>
37491>>>
37491>>>        // let's hide all buttons and then show the ones we want
37491>>>        WebSet pbRender of oEditBtn to False 
37492>>>        WebSet pbRender of oSaveBtn to False
37493>>>        WebSet pbRender of oCancelChangesBtn to False
37494>>>        WebSet pbRender of oDeleteBtn to False
37495>>>
37495>>>        If (NavigateData.bReadOnly) Begin 
37497>>>            WebSet pbRender of oEditBtn to True 
37498>>>        End
37498>>>>
37498>>>        Else Begin
37499>>>            WebSet pbRender of oSaveBtn to True
37500>>>            WebSet pbRender of oCancelChangesBtn to True
37501>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37502>>>        End
37502>>>>
37502>>>    End_Procedure
