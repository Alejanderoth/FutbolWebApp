37404>>>        String sPrevStateHash sView
37404>>>        
37404>>>        Forward Send OnLoad
37406>>>        
37406>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37406>>>        Get StateHash of ghoWebApp to sPrevStateHash
37407>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37408>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37410>>>            WebSet psPrevStateHash to sPrevStateHash
37411>>>        End
37411>>>>
37411>>>        
37411>>>    End_Procedure
