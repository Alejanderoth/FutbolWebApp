37855>>>    // This can be used to show and hide buttons based on context.
37855>>>    // This can be called any time the view is active.
37855>>>    Procedure SetActionButtons
37858>>>        tWebNavigateData NavigateData
37858>>>        tWebNavigateData NavigateData
37858>>>        Boolean bHasRecord
37858>>>        Handle hoDD
37858>>>
37858>>>        Get Server to hoDD
37859>>>        Get GetNavigateData to NavigateData
37860>>>        
37860>>>        If (hoDD) Begin
37862>>>            Get HasRecord of hoDD to bHasRecord
37863>>>        End
37863>>>>
37863>>>        Else Begin
37864>>>            Move False to bHasRecord
37865>>>        End
37865>>>>
37865>>>
37865>>>        // let's hide all buttons and then show the ones we want
37865>>>        WebSet pbRender of oEditBtn to False 
37866>>>        WebSet pbRender of oSaveBtn to False
37867>>>        WebSet pbRender of oCancelChangesBtn to False
37868>>>        WebSet pbRender of oDeleteBtn to False
37869>>>
37869>>>        If (NavigateData.bReadOnly) Begin 
37871>>>            WebSet pbRender of oEditBtn to True 
37872>>>        End
37872>>>>
37872>>>        Else Begin
37873>>>            WebSet pbRender of oSaveBtn to True
37874>>>            WebSet pbRender of oCancelChangesBtn to True
37875>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37876>>>        End
37876>>>>
37876>>>    End_Procedure
37877>>>
37877>>>    // this will close the view after a save
37877>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37880>>>        Send NavigateClose Self
37881>>>    End_Procedure
37882>>>
37882>>>    // this will close the view after a delete
37882>>>    Procedure OnViewDeleted Handle hoDDO
37885>>>        Send NavigateClose Self
37886>>>    End_Procedure
