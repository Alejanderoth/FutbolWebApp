37902>>>
37902>>>    // This can be used to show and hide buttons based on context.
37902>>>    // This can be called any time the view is active.
37902>>>    Procedure SetActionButtons
37905>>>        tWebNavigateData NavigateData
37905>>>        tWebNavigateData NavigateData
37905>>>        Boolean bHasRecord
37905>>>        Handle hoDD
37905>>>
37905>>>        Get Server to hoDD
37906>>>        Get GetNavigateData to NavigateData
37907>>>        
37907>>>        If (hoDD) Begin
37909>>>            Get HasRecord of hoDD to bHasRecord
37910>>>        End
37910>>>>
37910>>>        Else Begin
37911>>>            Move False to bHasRecord
37912>>>        End
37912>>>>
37912>>>
37912>>>        // let's hide all buttons and then show the ones we want
37912>>>        WebSet pbRender of oEditBtn to False 
37913>>>        WebSet pbRender of oSaveBtn to False
37914>>>        WebSet pbRender of oCancelChangesBtn to False
37915>>>        WebSet pbRender of oDeleteBtn to False
37916>>>
37916>>>        If (NavigateData.bReadOnly) Begin 
37918>>>            WebSet pbRender of oEditBtn to True 
37919>>>        End
37919>>>>
37919>>>        Else Begin
37920>>>            WebSet pbRender of oSaveBtn to True
37921>>>            WebSet pbRender of oCancelChangesBtn to True
37922>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37923>>>        End
37923>>>>
37923>>>    End_Procedure
37924>>>
37924>>>    // this will close the view after a save
37924>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37927>>>        Send NavigateClose Self
37928>>>    End_Procedure
37929>>>
37929>>>    // this will close the view after a delete
37929>>>    Procedure OnViewDeleted Handle hoDDO
37932>>>        Send NavigateClose Self
37933>>>    End_Procedure
