37862>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37865>>>        Send NavigateClose Self
37866>>>    End_Procedure
37867>>>
37867>>>    // this will close the view after a delete
37867>>>    Procedure OnViewDeleted Handle hoDDO
37870>>>        Send NavigateClose Self
37871>>>    End_Procedure
