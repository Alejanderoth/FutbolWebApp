39027>>>    // Add code to customize your Select View based on how it was invoked.
39027>>>    // Use NavigateData to determine the context this view will be used in.
39027>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39030>>>
39030>>>        // if this view is being used in multiple contexts, you may need a block of code
39030>>>        // like this to handle customizations. This would include hiding rows and buttons
39030>>>        // (WebSet pbRender) and changing the values of various captions.
39030>>>        Case Begin
39030>>>            Case (NavigateData.eNavigateType=nfFromParent)
39032>>>                // If from parent, this is a constrained drill down.
39032>>>                // If needed you could check NavigateData.iTable to determine the constraining parent.
39032>>>                Case Break
39033>>>                
39033>>>            Case (NavigateData.eNavigateType=nfFromChild)
39036>>>                // If from child, this is a probably a parent lookup from a Zoom
39036>>>                Case Break
39037>>>                
39037>>>            Case (NavigateData.eNavigateType=nfFromMain)
39040>>>                // If from main, this is a propbably a main file lookup from a Zoom.
39040>>>                // This is not used often with the drilldown style
39040>>>                Case Break
39041>>>                
39041>>>            Case Else // must be nfUndefined
39041>>>                // This may be the start of a drilldown query or some kind ofcustom query.
39041>>>                // You may want to check NavigateData.NamedValues.
39041>>>                  
39041>>>        Case End
39041>>>        
39041>>>    End_Procedure
