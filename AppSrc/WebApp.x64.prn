38657>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38660>>>
38660>>>        // if this view is being used in multiple contexts, you may need a block of code
38660>>>        // like this to handle customizations. This would include hiding rows and buttons
38660>>>        // (WebSet pbRender) and changing the values of various captions.
38660>>>        Case Begin
38660>>>            Case (NavigateData.eNavigateType = nfFromMain)
38662>>>                // If from main, this is a probably a main file Select to Zoom.
38662>>>                // This is the most typical way to navigate to a zoom.
38662>>>                Case Break
38663>>>                
38663>>>            Case (NavigateData.eNavigateType = nfFromParent)
38666>>>                // If from parent, this is a constrained drill down.
38666>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38666>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38666>>>                Case Break
38667>>>                
38667>>>            Case (NavigateData.eNavigateType = nfFromChild)
38670>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38670>>>                // This is unusual, but it might be used for adding a new child record.
38670>>>                Case Break
38671>>>                
38671>>>            Case Else // must be nfUndefined
38671>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38671>>>                // You may want to check NavigateData.NamedValues.
38671>>>                  
38671>>>        Case End
38671>>>
38671>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38671>>>        // It's best to set these buttons in their own procedure so you can change later.
38671>>>        Send SetActionButtons
38672>>>
38672>>>    End_Procedure
38673>>>
38673>>>End_Object
