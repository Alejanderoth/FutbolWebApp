36726>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36727>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36728>>>>>>>        Move (Free(pBase64)) to iLen
36729>>>>>>>        Function_Return ucaBuffer
36730>>>>>>>    End_Function
