37377>>>    Procedure DoLogin
37380>>>        String sLoginName sPassword sPrevStateHash
37380>>>        Boolean bResult
37380>>>        
37380>>>        WebGet psValue of oLoginName to sLoginName
37381>>>        WebGet psValue of oPassword to sPassword
37382>>>        
37382>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37383>>>        
37383>>>        If (bResult) Begin
37385>>>            Send Hide of oLogin
37386>>>            Send ShowHeader of ghoWebApp
37387>>>            WebSet psCSSClass of ghoWebApp to ""
37388>>>            
37388>>>            WebGet psPrevStateHash to sPrevStateHash
37389>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37390>>>            
37390>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37390>>>            WebSet psValue of oLoginName to ""
37391>>>            WebSet psValue of oPassword  to ""
37392>>>            WebSet pbVisible of oWarning to False
37393>>>        End
37393>>>>
37393>>>        Else Begin
37394>>>            WebSet pbVisible of oWarning to True
37395>>>        End
37395>>>>
37395>>>    End_Procedure
