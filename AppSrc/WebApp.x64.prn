36528>>>>>>>    //
36528>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36528>>>>>>>    //
36528>>>>>>>    //  Params:
36528>>>>>>>    //      dtTime  Time to convert
36528>>>>>>>    //  Returns:
36528>>>>>>>    //      String with "HH:MM:SS" format
36528>>>>>>>    //
36528>>>>>>>    Function TimeToString DateTime dtTime Returns String
36530>>>>>>>        String sHours sMinutes sSeconds
36530>>>>>>>        
36530>>>>>>>        //  Extract parts
36530>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36531>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36532>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36533>>>>>>>        
36533>>>>>>>        //  Fill out with 0
36533>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36536>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36539>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36542>>>>>>>        
36542>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36543>>>>>>>    End_Function
36544>>>>>>>    
36544>>>>>>>    //
36544>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36544>>>>>>>    //
36544>>>>>>>    //  Params:
36544>>>>>>>    //      dtTime  Datetime variable to add time to
36544>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36544>>>>>>>    //  Returns:
36544>>>>>>>    //      dtDateTime with the loaded time
36544>>>>>>>    //
36544>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36546>>>>>>>        String sHours sMinutes sSeconds
36546>>>>>>>        
36546>>>>>>>        //  Extract parts
36546>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36547>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36548>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36549>>>>>>>        
36549>>>>>>>        //  Set to DateTime
36549>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36550>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36551>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36552>>>>>>>        
36552>>>>>>>        Function_Return dtTime
36553>>>>>>>    End_Function
