36691>>>>>>>        Case End
36691>>>>>>>        
36691>>>>>>>        String sSalt
36691>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36692>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36695>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36696>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36699>>>>>>>        
36699>>>>>>>        If (bRequireTimeCost) Begin
36701>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36702>>>>>>>        End
36702>>>>>>>>
36702>>>>>>>        Else Begin
36703>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36704>>>>>>>        End
36704>>>>>>>>
36704>>>>>>>        
36704>>>>>>>        Function_Return bOk
36705>>>>>>>    End_Function
36706>>>>>>>    
36706>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36708>>>>>>>        UChar[] ucaSalt
36709>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36710>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36713>>>>>>>        
36713>>>>>>>        If (num_arguments > 4) Begin
36715>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36716>>>>>>>        End
36716>>>>>>>>
36716>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36717>>>>>>>    End_Function
36718>>>>>>>    
36718>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36720>>>>>>>        Boolean bRequiresTimeCost
36720>>>>>>>        UInteger uiAlgo uiTimeCost
36720>>>>>>>        Integer iBegin iEnd
36720>>>>>>>        String sSalt
36720>>>>>>>        
36720>>>>>>>        Move 1 to iBegin
36721>>>>>>>        
36721>>>>>>>        // Parse Algo
36721>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36722>>>>>>>        If (not(iEnd)) Function_Return False
36725>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36726>>>>>>>        
36726>>>>>>>        // Parse Salt
36726>>>>>>>        Move (iEnd + 1) to iBegin
36727>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36728>>>>>>>        If (not(iEnd)) Function_Return False
36731>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36732>>>>>>>        
36732>>>>>>>        Case Begin
36732>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36734>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36737>>>>>>>                Move True to bRequiresTimeCost
36738>>>>>>>                Case Break
36739>>>>>>>            Case Else
36739>>>>>>>                Error 8710 "Invalid algorithm selected."
36740>>>>>>>>
36740>>>>>>>                Function_Return False
36741>>>>>>>        Case End
36741>>>>>>>        
36741>>>>>>>        // Parse optional timecost
36741>>>>>>>        If (bRequiresTimeCost) Begin
36743>>>>>>>            Move (iEnd + 1) to iBegin
36744>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36745>>>>>>>            If (not(iEnd)) Function_Return False
36748>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36749>>>>>>>        End
36749>>>>>>>>
36749>>>>>>>        
36749>>>>>>>        // Parse rest hash
36749>>>>>>>        Move (iEnd + 1) to iBegin
36750>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36751>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36754>>>>>>>        
36754>>>>>>>        // Base64Decode
36754>>>>>>>        UChar[] ucaSalt
36755>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36756>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36759>>>>>>>        
36759>>>>>>>        // Create new hash
36759>>>>>>>        String sNewHash
36759>>>>>>>        If (bRequiresTimeCost) Begin
36761>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36763>>>>>>>                Function_Return False 
36764>>>>>>>            End
36764>>>>>>>>
36764>>>>>>>        End
36764>>>>>>>>
36764>>>>>>>        Else Begin
36765>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36767>>>>>>>                Function_Return False 
36768>>>>>>>            End
36768>>>>>>>>
36768>>>>>>>        End
36768>>>>>>>>
36768>>>>>>>        Function_Return (sNewHash = sHash)
36769>>>>>>>    End_Function
36770>>>>>>>    
36770>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36772>>>>>>>        Boolean bRequireTimeCost
36772>>>>>>>        UBigInt ullSize
36772>>>>>>>        UChar[] ucaSalt
36773>>>>>>>        String sSalt
36773>>>>>>>        
36773>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36774>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36775>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36778>>>>>>>        
36778>>>>>>>        Case Begin
36778>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36780>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36781>>>>>>>                Move True to bRequireTimeCost
36782>>>>>>>                Case Break
36783>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36786>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36787>>>>>>>                Move True to bRequireTimeCost
36788>>>>>>>                Case Break
36789>>>>>>>            Case Else
36789>>>>>>>                Error 8710 "Invalid algorithm selected."
36790>>>>>>>>
36790>>>>>>>                Function_Return 0
36791>>>>>>>        Case End
36791>>>>>>>        
36791>>>>>>>        // calculate base64 in a non-floating-manner
36791>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36792>>>>>>>        
36792>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36793>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36794>>>>>>>        If (bRequireTimeCost) Begin
36796>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36797>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36798>>>>>>>        End
36798>>>>>>>>
36798>>>>>>>        Else Begin
36799>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36800>>>>>>>        End
36800>>>>>>>>
36800>>>>>>>        
36800>>>>>>>        Function_Return ullSize
36801>>>>>>>    End_Function
36802>>>>>>>End_Class
36803>>>>>>>
36803>>>>>>>Class cPasswordHasher is a cObject
36804>>>>>>>    
36804>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36805>>>>>>>    
36805>>>>>>>    Procedure Construct_Object
36807>>>>>>>        Forward Send Construct_Object
36809>>>>>>>        
36809>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36810>>>>>>>        Property UInteger   puiSaltSize         16
36811>>>>>>>        
36811>>>>>>>        Property UInteger   puiOptTimeCost      420000
36812>>>>>>>    End_Procedure
36813>>>>>>>    
36813>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36815>>>>>>>        Boolean bOk
36815>>>>>>>        UInteger uiAlgo
36815>>>>>>>        Get peAlgorithm to uiAlgo
36816>>>>>>>        
36816>>>>>>>        Case Begin
36816>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36818>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36821>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36822>>>>>>>                Case Break
36823>>>>>>>            Case Else
36823>>>>>>>                Error 8710 "Invalid algorithm selected."
36824>>>>>>>>
36824>>>>>>>                Function_Return False
36825>>>>>>>        Case End
36825>>>>>>>        
36825>>>>>>>        Function_Return bOk
36826>>>>>>>    End_Function
36827>>>>>>>    
36827>>>>>>>    Function RequiredBufferSize Returns UBigInt
36829>>>>>>>        UBigInt ullSize
36829>>>>>>>        UInteger uiAlgo
36829>>>>>>>        Get peAlgorithm to uiAlgo
36830>>>>>>>        
36830>>>>>>>        Case Begin
36830>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36832>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36835>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36836>>>>>>>                Case Break
36837>>>>>>>            Case Else
36837>>>>>>>                Error 8710 "Invalid algorithm selected."
36838>>>>>>>>
36838>>>>>>>                Function_Return 0
36839>>>>>>>        Case End
36839>>>>>>>        
36839>>>>>>>        Function_Return ullSize
36840>>>>>>>    End_Function
36841>>>>>>>
36841>>>>>>>End_Class
