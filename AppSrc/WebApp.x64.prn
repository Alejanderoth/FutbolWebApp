37590>>>    // Add code to customize your Zoom View based on how it was invoked.
37590>>>    // Use NavigateData to determine the context this view will be used in.
37590>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37593>>>
37593>>>        // if this view is being used in multiple contexts, you may need a block of code
37593>>>        // like this to handle customizations. This would include hiding rows and buttons
37593>>>        // (WebSet pbRender) and changing the values of various captions.
37593>>>        Case Begin
37593>>>            Case (NavigateData.eNavigateType = nfFromMain)
37595>>>                // If from main, this is a probably a main file Select to Zoom.
37595>>>                // This is the most typical way to navigate to a zoom.
37595>>>                Case Break
37596>>>                
37596>>>            Case (NavigateData.eNavigateType = nfFromParent)
37599>>>                // If from parent, this is a constrained drill down.
37599>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
37599>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
37599>>>                Case Break
37600>>>                
37600>>>            Case (NavigateData.eNavigateType = nfFromChild)
37603>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
37603>>>                // This is unusual, but it might be used for adding a new child record.
37603>>>                Case Break
37604>>>                
37604>>>            Case Else // must be nfUndefined
37604>>>                // This may be the start of a query or this may be used for some kind of custom operation.
37604>>>                // You may want to check NavigateData.NamedValues.
37604>>>                  
37604>>>        Case End
37604>>>
