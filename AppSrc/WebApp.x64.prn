36652>>>>>>>    //
36652>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36652>>>>>>>    //
36652>>>>>>>    //  Params:
36652>>>>>>>    //      dtTime  Time to convert
36652>>>>>>>    //  Returns:
36652>>>>>>>    //      String with "HH:MM:SS" format
36652>>>>>>>    //
36652>>>>>>>    Function TimeToString DateTime dtTime Returns String
36654>>>>>>>        String sHours sMinutes sSeconds
36654>>>>>>>        
36654>>>>>>>        //  Extract parts
36654>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36655>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36656>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36657>>>>>>>        
36657>>>>>>>        //  Fill out with 0
36657>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36660>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36663>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36666>>>>>>>        
36666>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36667>>>>>>>    End_Function
36668>>>>>>>    
36668>>>>>>>    //
36668>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36668>>>>>>>    //
36668>>>>>>>    //  Params:
36668>>>>>>>    //      dtTime  Datetime variable to add time to
36668>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36668>>>>>>>    //  Returns:
36668>>>>>>>    //      dtDateTime with the loaded time
36668>>>>>>>    //
36668>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36670>>>>>>>        String sHours sMinutes sSeconds
36670>>>>>>>        
36670>>>>>>>        //  Extract parts
36670>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36671>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36672>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36673>>>>>>>        
36673>>>>>>>        //  Set to DateTime
36673>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36674>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36675>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36676>>>>>>>        
36676>>>>>>>        Function_Return dtTime
36677>>>>>>>    End_Function
