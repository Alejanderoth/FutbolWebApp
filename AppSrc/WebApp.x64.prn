37293>>>        Forward Send OnLoad
37295>>>        
37295>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37295>>>        Get StateHash of ghoWebApp to sPrevStateHash
37296>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37297>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37299>>>            WebSet psPrevStateHash to sPrevStateHash
37300>>>        End
37300>>>>
37300>>>        
37300>>>    End_Procedure
