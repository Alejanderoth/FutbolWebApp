38222>>>    // This can be used to show and hide buttons based on context.
38222>>>    // This can be called any time the view is active.
38222>>>    Procedure SetActionButtons
38225>>>        tWebNavigateData NavigateData
38225>>>        tWebNavigateData NavigateData
38225>>>        Boolean bHasRecord
38225>>>        Handle hoDD
38225>>>
38225>>>        Get Server to hoDD
38226>>>        Get GetNavigateData to NavigateData
38227>>>        
38227>>>        If (hoDD) Begin
38229>>>            Get HasRecord of hoDD to bHasRecord
38230>>>        End
38230>>>>
38230>>>        Else Begin
38231>>>            Move False to bHasRecord
38232>>>        End
38232>>>>
38232>>>
38232>>>        // let's hide all buttons and then show the ones we want
38232>>>        WebSet pbRender of oEditBtn to False 
38233>>>        WebSet pbRender of oSaveBtn to False
38234>>>        WebSet pbRender of oCancelChangesBtn to False
38235>>>        WebSet pbRender of oDeleteBtn to False
38236>>>
38236>>>        If (NavigateData.bReadOnly) Begin 
38238>>>            WebSet pbRender of oEditBtn to True 
38239>>>        End
38239>>>>
38239>>>        Else Begin
38240>>>            WebSet pbRender of oSaveBtn to True
38241>>>            WebSet pbRender of oCancelChangesBtn to True
38242>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38243>>>        End
38243>>>>
38243>>>    End_Procedure
38244>>>
38244>>>    // this will close the view after a save
38244>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38247>>>        Send NavigateClose Self
38248>>>    End_Procedure
38249>>>
38249>>>    // this will close the view after a delete
38249>>>    Procedure OnViewDeleted Handle hoDDO
38252>>>        Send NavigateClose Self
38253>>>    End_Procedure
