37892>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37895>>>        Send NavigateClose Self
37896>>>    End_Procedure
37897>>>
37897>>>    // this will close the view after a delete
37897>>>    Procedure OnViewDeleted Handle hoDDO
37900>>>        Send NavigateClose Self
37901>>>    End_Procedure
