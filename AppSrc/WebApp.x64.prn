36736>>>>>>>        Integer iLen
36736>>>>>>>        Pointer pBase64
36736>>>>>>>        UChar[] ucaBuffer
36737>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36738>>>>>>>        If (not(pBase64)) Begin
36740>>>>>>>            Function_Return ucaBuffer
36741>>>>>>>        End
36741>>>>>>>>
36741>>>>>>>        
36741>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36742>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36743>>>>>>>        Move (Free(pBase64)) to iLen
36744>>>>>>>        Function_Return ucaBuffer
36745>>>>>>>    End_Function
