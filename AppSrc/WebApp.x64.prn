38310>>>        // What to do when the row is selected.
38310>>>        //
38310>>>        // Depending on how you are using this view, you may wish to
38310>>>        // 1. Close the view, which will update the invoking view:
38310>>>        //      Send NavigateClose Self
38310>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
38310>>>        //      Send NavigateForward of oZoomMainView Self
38310>>>        //      Send NavigateForward of oSelectChildView Self
38310>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
38310>>>        Procedure OnRowClick String sRowID
38313>>>
38313>>>            // If this view is being used in multiple contexts, you may need a block of code
