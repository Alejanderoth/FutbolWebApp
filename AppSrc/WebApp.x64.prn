38293>>>        // What to do when the row is selected.
38293>>>        //
38293>>>        // Depending on how you are using this view, you may wish to
38293>>>        // 1. Close the view, which will update the invoking view:
38293>>>        //      Send NavigateClose Self
38293>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
38293>>>        //      Send NavigateForward of oZoomMainView Self
38293>>>        //      Send NavigateForward of oSelectChildView Self
38293>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
38293>>>        Procedure OnRowClick String sRowID
38296>>>
38296>>>            // If this view is being used in multiple contexts, you may need a block of code
38296>>>            // like this to handle different types of navigation
38296>>>            tWebNavigateData NavigateData
38296>>>            tWebNavigateData NavigateData
38296>>>            Get GetNavigateData to NavigateData
38297>>>            Case Begin
38297>>>                Case (NavigateData.eNavigateType=nfFromParent)
38299>>>                    // If from parent, this is a constrained drilldown.
