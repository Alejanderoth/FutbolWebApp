36872>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36873>>>>>    
36873>>>>>    Procedure Construct_Object
36875>>>>>        Handle hoObj
36875>>>>>        
36875>>>>>        Forward Send Construct_Object
36877>>>>>        
36877>>>>>        Set pbSessionCookieHttpOnly to True
36878>>>>>        
36878>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36879>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36880>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36881>>>>>        
36881>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36882>>>>>        Set phoUserDD to hoObj
36883>>>>>        
36883>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36884>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36885>>>>>        Set phoSessionDD to hoObj
36886>>>>>        
36886>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36887>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36888>>>>>        Set phoCrypto to hoObj
36889>>>>>        
36889>>>>>        Property Boolean pbPasswordHashing True
36890>>>>>        
36890>>>>>        Property Boolean pbCreatingNewSession False
36891>>>>>        Property String psLoginName
36892>>>>>        Property String psUserName ""
36893>>>>>        Property Integer piUserRights 0
36894>>>>>    End_Procedure
36895>>>>>    
36895>>>>>    Procedure End_Construct_Object
36897>>>>>        Forward Send End_Construct_Object
36899>>>>>        
36899>>>>>        Handle hoCrypto
36899>>>>>        Integer iFieldLen
36899>>>>>        If (pbPasswordHashing(Self)) Begin
36901>>>>>            Get phoCrypto to hoCrypto
36902>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36905>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36907>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36908>>>>>>
36908>>>>>            End
36908>>>>>>
36908>>>>>        End
36908>>>>>>
36908>>>>>    End_Procedure
36909>>>>>    
36909>>>>>    Function CreateSession String sRemoteAddress Returns String
36911>>>>>        String sSessionKey
36911>>>>>        Integer iErr
36911>>>>>        Boolean bLogWebSession
36911>>>>>        Handle hoSessionDD       
36911>>>>>        Get phoSessionDD to hoSessionDD
36912>>>>>        
36912>>>>>        //  Get session key
36912>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36914>>>>>        
36914>>>>>        Get pbLogWebSession to bLogWebSession
36915>>>>>        If not bLogWebSession Begin
36917>>>>>            Function_Return sSessionKey        
36918>>>>>        End
36918>>>>>>
36918>>>>>
36918>>>>>        //  Store session
36918>>>>>        Send Clear of hoSessionDD
36919>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36920>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36921>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36922>>>>>        Get Request_Validate of hoSessionDD to iErr
36923>>>>>        If (iErr) Begin
36925>>>>>            // this should not happen. If it does its a programming error
36925>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36926>>>>>>
36926>>>>>            Function_Return ""
36927>>>>>        End
36927>>>>>>
36927>>>>>        Send Request_Save of hoSessionDD
36928>>>>>        If (Err) Begin
36930>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36930>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36931>>>>>>
36931>>>>>            Function_Return ""
36932>>>>>        End
36932>>>>>>
36932>>>>>       
36932>>>>>        Function_Return sSessionKey        
36933>>>>>    End_Function
36934>>>>>    
36934>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36936>>>>>        DateTime dtLastAccess dtCurrent
36936>>>>>        TimeSpan tsDiff
36936>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36936>>>>>        Boolean bResult bCreatingNewSession
36936>>>>>        Boolean bLogWebSession bLoadWebApp
36936>>>>>        Integer eLoginMode
36936>>>>>        String sTime
36936>>>>>        Handle hoSessionDD hoUserDD       
36936>>>>>        
36936>>>>>        Move False to bLoadWebApp
36937>>>>>        If (num_arguments >= 2) Begin
36939>>>>>            Move bOptLoadWebApp to bLoadWebApp
36940>>>>>        End
36940>>>>>>
36940>>>>>        
36940>>>>>        Get phoSessionDD to hoSessionDD
36941>>>>>        Get phoUserDD to hoUserDD
36942>>>>>        
36942>>>>>        Get pbLogWebSession to bLogWebSession
36943>>>>>        Get peLoginMode to eLoginMode
36944>>>>>        
36944>>>>>        // for this object, you can only disable logging if login completely is disabled
36944>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36946>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36947>>>>>>
36947>>>>>            Function_Return False
36948>>>>>        End
36948>>>>>>
36948>>>>>
36948>>>>>        //  Clear session properties
36948>>>>>        Set psSessionKey to ""
36949>>>>>        Send UpdateSessionProperties True
36950>>>>>        
36950>>>>>        If not bLogWebSession Begin
36952>>>>>            Forward Get ValidateSession sSessionKey to bResult
36954>>>>>            Function_Return bResult
36955>>>>>        End        
36955>>>>>>
36955>>>>>        
36955>>>>>        Move False to bResult
36956>>>>>        Get piSessionTimeout to iSessionTimeout 
36957>>>>>        
36957>>>>>        //  Check if session exists
36957>>>>>        Send Clear of hoSessionDD
36958>>>>>        Move sSessionKey to WebAppSession.SessionKey
36959>>>>>        Send Find of hoSessionDD EQ Index.1
36960>>>>>            
36960>>>>>        If (Found) Begin
36962>>>>>            //  Calculate timespan between now and last access time
36962>>>>>            Move (CurrentDateTime()) to dtCurrent
36963>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36964>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36965>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36966>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36967>>>>>            
36967>>>>>            //  Check if session didn't time out
36967>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
36969>>>>>                Forward Get ValidateSession sSessionKey to bResult
36971>>>>>                   
36971>>>>>                If (bResult) Begin
36973>>>>>                    //  Update session record
36973>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
36974>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
36975>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
36976>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
36977>>>>>                    Get Request_Validate of hoSessionDD to iErr
36978>>>>>                    If (iErr) Begin
36980>>>>>                        // this should not happen. If it does its a programming error
36980>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36981>>>>>>
36981>>>>>                        Function_Return False
36982>>>>>                    End
36982>>>>>>
36982>>>>>                    Send Request_Save of hoSessionDD
36983>>>>>                    
36983>>>>>                    //  Update user properties
36983>>>>>                    Send UpdateSessionProperties False
36984>>>>>                End
36984>>>>>>
36984>>>>>            End
36984>>>>>>
36984>>>>>            Else Begin
36985>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
36985>>>>>                Get pbCreatingNewSession to bCreatingNewSession
36986>>>>>                
36986>>>>>                If (not(bCreatingNewSession)) Begin
36988>>>>>                    If (not(bLoadWebApp)) Begin
36990>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
36991>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
36992>>>>>>
36992>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
36993>>>>>                    End
36993>>>>>>
36993>>>>>                    Else Begin
36994>>>>>                        Set pbCreatingNewSession to True                    
36995>>>>>                        Get RecreateSession of ghoWebApp to bResult 
36996>>>>>                        Set pbCreatingNewSession to False                        
36997>>>>>                    End
36997>>>>>>
36997>>>>>                End
36997>>>>>>
36997>>>>>            End
36997>>>>>>
36997>>>>>        End
36997>>>>>>
36997>>>>>        Else Begin
36998>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
36999>>>>>>
36999>>>>>        End
36999>>>>>>
36999>>>>>        
36999>>>>>        Function_Return bResult
37000>>>>>    End_Function
37001>>>>>    
37001>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37003>>>>>        If (not(pbPasswordHashing(Self))) Begin
37005>>>>>            Move sPassword to sHash
37006>>>>>            Function_Return True
37007>>>>>        End
37007>>>>>>
37007>>>>>        
37007>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37009>>>>>            Function_Return False
37010>>>>>        End
37010>>>>>>
37010>>>>>        Move ("V1$" + sHash) to sHash
37011>>>>>        Function_Return True
37012>>>>>    End_Function
37013>>>>>    
37013>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37015>>>>>        If (not(pbPasswordHashing(Self))) Begin
37017>>>>>            Move False to bShouldUpgrade
37018>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37019>>>>>        End
37019>>>>>>
37019>>>>>        
37019>>>>>        String sVersion
37019>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37020>>>>>        If (sVersion = "V1$") Begin
37022>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37025>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37026>>>>>        End
37026>>>>>>
37026>>>>>        Else Begin
37027>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37030>>>>>            Function_Return False
37031>>>>>        End
37031>>>>>>
37031>>>>>    End_Function
37032>>>>>    
37032>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37034>>>>>        Handle hoUserDD
37034>>>>>        Integer iErr
37034>>>>>        Get phoUserDD to hoUserDD
37035>>>>>        
37035>>>>>        //  Find the user
37035>>>>>        Send Clear of hoUserDD
37036>>>>>        Move sLoginName to WebAppUser.LoginName
37037>>>>>        Send Find of hoUserDD EQ Index.1
37038>>>>>        If (Found) Begin
37040>>>>>            Send Clear of hoUserDD
37041>>>>>            Function_Return False
37042>>>>>        End
37042>>>>>>
37042>>>>>        
37042>>>>>        Send Clear of hoUserDD
37043>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37044>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37045>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37047>>>>>            Send Clear of hoUserDD
37048>>>>>            Function_Return False
37049>>>>>        End
37049>>>>>>
37049>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37050>>>>>        Get Request_Validate of hoUserDD to iErr
37051>>>>>        If (iErr) Begin
37053>>>>>            Send Clear of hoUserDD
37054>>>>>            Function_Return False
37055>>>>>        End
37055>>>>>>
37055>>>>>        
37055>>>>>        Send Request_Save of hoUserDD
37056>>>>>        Function_Return (not(Err))
37057>>>>>    End_Function
37058>>>>>    
37058>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37060>>>>>        String sSessionKey sUserPassword
37060>>>>>        Handle hoSessionDD hoUserDD
37060>>>>>        Boolean bMatch bUpgrade
37060>>>>>        
37060>>>>>        Get phoSessionDD to hoSessionDD
37061>>>>>        Get phoUserDD to hoUserDD
37062>>>>>        Integer iErr eLoginMode
37062>>>>>        
37062>>>>>        // Refind session record
37062>>>>>        Get psSessionKey to sSessionKey
37063>>>>>        Send Clear of hoSessionDD
37064>>>>>        Move sSessionKey to WebAppSession.SessionKey
37065>>>>>        Send Find of hoSessionDD EQ Index.1
37066>>>>>        
37066>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37068>>>>>            Get peLoginMode to eLoginMode
37069>>>>>            
37069>>>>>            //  Find the user
37069>>>>>            Move sLoginName to WebAppUser.LoginName
37070>>>>>            Send Find of hoUserDD EQ Index.1
37071>>>>>            
37071>>>>>            // Check username and password
37071>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37073>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37074>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37075>>>>>                
37075>>>>>                If (bMatch) Begin
37077>>>>>                    // Store the login
37077>>>>>                    If (bUpgrade) Begin
37079>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37080>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37083>>>>>                    End
37083>>>>>>
37083>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37084>>>>>                    Get Request_Validate of hoSessionDD to iErr
37085>>>>>                    If (iErr) Begin
37087>>>>>                        // this should not happen. If it does its a programming error
37087>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37088>>>>>>
37088>>>>>                        Function_Return False
37089>>>>>                    End
37089>>>>>>
37089>>>>>                    
37089>>>>>                    Send Request_Save of hoSessionDD
37090>>>>>                    
37090>>>>>                    // Update session properties
37090>>>>>                    Send UpdateSessionProperties False
37091>>>>>                    Send NotifyChangeRights
37092>>>>>                    Function_Return True
37093>>>>>                End
37093>>>>>>
37093>>>>>                Else Begin
37094>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37094>>>>>                    Send Clear of hoUserDD
37095>>>>>                End
37095>>>>>>
37095>>>>>            End
37095>>>>>>
37095>>>>>            Else Begin
37096>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37096>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37097>>>>>            End
37097>>>>>>
37097>>>>>        End
37097>>>>>>
37097>>>>>        Else Begin
37098>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37098>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37099>>>>>        End
37099>>>>>>
37099>>>>>          
37099>>>>>        Function_Return False
37100>>>>>    End_Function
37101>>>>>    
37101>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37103>>>>>        Handle hoUserDD
37103>>>>>        Integer iErr
37103>>>>>        Get phoUserDD to hoUserDD
37104>>>>>        
37104>>>>>        //  Find the user
37104>>>>>        Send Clear of hoUserDD
37105>>>>>        Move sLoginName to WebAppUser.LoginName
37106>>>>>        Send Find of hoUserDD EQ Index.1
37107>>>>>        If (not(Found)) Begin
37109>>>>>            Send Clear of hoUserDD
37110>>>>>            Function_Return False
37111>>>>>        End
37111>>>>>>
37111>>>>>        
37111>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37113>>>>>            Send Clear of hoUserDD
37114>>>>>            Function_Return False
37115>>>>>        End
37115>>>>>>
37115>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37116>>>>>        Get Request_Validate of hoUserDD to iErr
37117>>>>>        If (iErr) Begin
37119>>>>>            Send Clear of hoUserDD
37120>>>>>            Function_Return False
37121>>>>>        End
37121>>>>>>
37121>>>>>        
37121>>>>>        Send Request_Save of hoUserDD
37122>>>>>        Function_Return (not(Err))
37123>>>>>    End_Function
37124>>>>>    
37124>>>>>    Function IsLoggedIn Returns Boolean
37126>>>>>        String sLoginName
37126>>>>>        Boolean bLogWebSession bLoggedIn
37126>>>>>        
37126>>>>>        Get pbLogWebSession to bLogWebSession
37127>>>>>        If not bLogWebSession Begin
37129>>>>>            Forward Get IsLoggedIn to bLoggedIn
37131>>>>>            Function_Return bLoggedIn
37132>>>>>        End
37132>>>>>>
37132>>>>>        
37132>>>>>        Get psLoginName to sLoginName
37133>>>>>        
37133>>>>>        Function_Return (sLoginName <> "")
37134>>>>>    End_Function
37135>>>>>    
37135>>>>>    
37135>>>>>    //
37135>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37135>>>>>    // update properties based on the session and user data. Augment this function to update 
37135>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37135>>>>>    // the right records when this procedure is called.
37135>>>>>    //
37135>>>>>    // Params:
37135>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37135>>>>>    //
37135>>>>>    Procedure UpdateSessionProperties Boolean bClear
37137>>>>>        Handle hoUserDD
37137>>>>>        
37137>>>>>        Get phoUserDD to hoUserDD
37138>>>>>        
37138>>>>>        //  Update user properties
37138>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37140>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37141>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37142>>>>>            Set piUserRights to WebAppUser.Rights
37143>>>>>            
37143>>>>>            Send OnSessionPropertiesSet 
37144>>>>>        End
37144>>>>>>
37144>>>>>        Else Begin
37145>>>>>            Set psUsername to ""
37146>>>>>            Set psLoginName to ""
37147>>>>>            Set piUserRights to 0
37148>>>>>            
37148>>>>>            Send OnSessionPropertiesClear
37149>>>>>        End
37149>>>>>>
37149>>>>>    End_Procedure
37150>>>>>    
37150>>>>>    Procedure OnSessionPropertiesSet
37152>>>>>        //  Empty event stub
37152>>>>>    End_Procedure
37153>>>>>    
37153>>>>>    Procedure OnSessionPropertiesClear
37155>>>>>        //  Empty event stub
37155>>>>>    End_Procedure
37156>>>>>    
37156>>>>>    Procedure EndSession
37158>>>>>        Integer iErr
37158>>>>>        Boolean bLogWebSession
37158>>>>>        Handle hoSessionDD       
37158>>>>>        
37158>>>>>        Get phoSessionDD to hoSessionDD
37159>>>>>        Get pbLogWebSession to bLogWebSession
37160>>>>>        If not bLogWebSession Begin
37162>>>>>            Forward Send EndSession
37164>>>>>            Procedure_Return
37165>>>>>        End
37165>>>>>>
37165>>>>>            
37165>>>>>        //  Check if session exists
37165>>>>>        Send Clear of hoSessionDD
37166>>>>>        Get psSessionKey to WebAppSession.SessionKey
37167>>>>>        
37167>>>>>        Send Find of hoSessionDD EQ Index.1
37168>>>>>        If (Found) Begin
37170>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37171>>>>>            Get Request_Validate of hoSessionDD to iErr
37172>>>>>            If (iErr) Begin
37174>>>>>                // this should not happen. If it does its a programming error
37174>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37175>>>>>>
37175>>>>>                Procedure_Return
37176>>>>>            End
37176>>>>>>
37176>>>>>            Send Request_Save of hoSessionDD
37177>>>>>        End
37177>>>>>>
37177>>>>>    End_Procedure
37178>>>>>
37178>>>>>End_Class
