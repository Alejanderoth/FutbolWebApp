38332>>>        // What to do when the row is selected.
38332>>>        //
38332>>>        // Depending on how you are using this view, you may wish to
38332>>>        // 1. Close the view, which will update the invoking view:
38332>>>        //      Send NavigateClose Self
38332>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
38332>>>        //      Send NavigateForward of oZoomMainView Self
38332>>>        //      Send NavigateForward of oSelectChildView Self
38332>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
38332>>>        Procedure OnRowClick String sRowID
38335>>>
38335>>>            // If this view is being used in multiple contexts, you may need a block of code
