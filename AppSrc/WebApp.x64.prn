37275>>>    Procedure OnLoad
37278>>>        String sPrevStateHash sView
37278>>>        
37278>>>        Forward Send OnLoad
37280>>>        
37280>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37280>>>        Get StateHash of ghoWebApp to sPrevStateHash
37281>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37282>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37284>>>            WebSet psPrevStateHash to sPrevStateHash
37285>>>        End
37285>>>>
37285>>>        
37285>>>    End_Procedure
