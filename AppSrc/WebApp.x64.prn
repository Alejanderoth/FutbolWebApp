37919>>>
37919>>>    // This can be used to show and hide buttons based on context.
37919>>>    // This can be called any time the view is active.
37919>>>    Procedure SetActionButtons
37922>>>        tWebNavigateData NavigateData
37922>>>        tWebNavigateData NavigateData
37922>>>        Boolean bHasRecord
37922>>>        Handle hoDD
37922>>>
37922>>>        Get Server to hoDD
37923>>>        Get GetNavigateData to NavigateData
37924>>>        
37924>>>        If (hoDD) Begin
37926>>>            Get HasRecord of hoDD to bHasRecord
37927>>>        End
37927>>>>
37927>>>        Else Begin
37928>>>            Move False to bHasRecord
37929>>>        End
37929>>>>
37929>>>
37929>>>        // let's hide all buttons and then show the ones we want
37929>>>        WebSet pbRender of oEditBtn to False 
37930>>>        WebSet pbRender of oSaveBtn to False
37931>>>        WebSet pbRender of oCancelChangesBtn to False
37932>>>        WebSet pbRender of oDeleteBtn to False
37933>>>
37933>>>        If (NavigateData.bReadOnly) Begin 
37935>>>            WebSet pbRender of oEditBtn to True 
37936>>>        End
37936>>>>
37936>>>        Else Begin
37937>>>            WebSet pbRender of oSaveBtn to True
37938>>>            WebSet pbRender of oCancelChangesBtn to True
37939>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37940>>>        End
37940>>>>
37940>>>    End_Procedure
37941>>>
37941>>>    // this will close the view after a save
37941>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37944>>>        Send NavigateClose Self
37945>>>    End_Procedure
37946>>>
37946>>>    // this will close the view after a delete
37946>>>    Procedure OnViewDeleted Handle hoDDO
37949>>>        Send NavigateClose Self
37950>>>    End_Procedure
