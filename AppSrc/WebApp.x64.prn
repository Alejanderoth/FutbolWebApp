37558>>>    // This can be used to show and hide buttons based on context.
37558>>>    // This can be called any time the view is active.
37558>>>    Procedure SetActionButtons
37561>>>        tWebNavigateData NavigateData
37561>>>        tWebNavigateData NavigateData
37561>>>        Boolean bHasRecord
37561>>>        Handle hoDD
37561>>>
37561>>>        Get Server to hoDD
37562>>>        Get GetNavigateData to NavigateData
37563>>>        
37563>>>        If (hoDD) Begin
37565>>>            Get HasRecord of hoDD to bHasRecord
37566>>>        End
37566>>>>
37566>>>        Else Begin
37567>>>            Move False to bHasRecord
37568>>>        End
37568>>>>
37568>>>
37568>>>        // let's hide all buttons and then show the ones we want
37568>>>        WebSet pbRender of oEditBtn to False 
37569>>>        WebSet pbRender of oSaveBtn to False
37570>>>        WebSet pbRender of oCancelChangesBtn to False
37571>>>        WebSet pbRender of oDeleteBtn to False
37572>>>
37572>>>        If (NavigateData.bReadOnly) Begin 
37574>>>            WebSet pbRender of oEditBtn to True 
37575>>>        End
37575>>>>
37575>>>        Else Begin
37576>>>            WebSet pbRender of oSaveBtn to True
37577>>>            WebSet pbRender of oCancelChangesBtn to True
37578>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37579>>>        End
37579>>>>
37579>>>    End_Procedure
