37607>>>    // This can be used to show and hide buttons based on context.
37607>>>    // This can be called any time the view is active.
37607>>>    Procedure SetActionButtons
37610>>>        tWebNavigateData NavigateData
37610>>>        tWebNavigateData NavigateData
37610>>>        Boolean bHasRecord
37610>>>        Handle hoDD
37610>>>
37610>>>        Get Server to hoDD
37611>>>        Get GetNavigateData to NavigateData
37612>>>        
37612>>>        If (hoDD) Begin
37614>>>            Get HasRecord of hoDD to bHasRecord
37615>>>        End
37615>>>>
37615>>>        Else Begin
37616>>>            Move False to bHasRecord
37617>>>        End
37617>>>>
37617>>>
37617>>>        // let's hide all buttons and then show the ones we want
37617>>>        WebSet pbRender of oEditBtn to False 
37618>>>        WebSet pbRender of oSaveBtn to False
37619>>>        WebSet pbRender of oCancelChangesBtn to False
37620>>>        WebSet pbRender of oDeleteBtn to False
37621>>>
37621>>>        If (NavigateData.bReadOnly) Begin 
37623>>>            WebSet pbRender of oEditBtn to True 
37624>>>        End
37624>>>>
37624>>>        Else Begin
37625>>>            WebSet pbRender of oSaveBtn to True
37626>>>            WebSet pbRender of oCancelChangesBtn to True
37627>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37628>>>        End
37628>>>>
37628>>>    End_Procedure
