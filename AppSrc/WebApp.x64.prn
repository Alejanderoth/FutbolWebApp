36704>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36705>>>>>>>                If (not(bOk)) Function_Return False
36708>>>>>>>                
36708>>>>>>>                Move True to bRequireTimeCost
36709>>>>>>>                Case Break
36710>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36713>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36714>>>>>>>                If (not(bOk)) Function_Return False
36717>>>>>>>                
36717>>>>>>>                Move True to bRequireTimeCost
36718>>>>>>>                Case Break
36719>>>>>>>            Case Else
36719>>>>>>>                Error 8710 "Invalid algorithm selected."
36720>>>>>>>>
36720>>>>>>>                Function_Return False
36721>>>>>>>        Case End
36721>>>>>>>        
36721>>>>>>>        String sSalt
36721>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36722>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36725>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36726>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36729>>>>>>>        
36729>>>>>>>        If (bRequireTimeCost) Begin
36731>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36732>>>>>>>        End
36732>>>>>>>>
36732>>>>>>>        Else Begin
36733>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36734>>>>>>>        End
36734>>>>>>>>
36734>>>>>>>        
36734>>>>>>>        Function_Return bOk
36735>>>>>>>    End_Function
36736>>>>>>>    
36736>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36738>>>>>>>        UChar[] ucaSalt
36739>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36740>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36743>>>>>>>        
36743>>>>>>>        If (num_arguments > 4) Begin
36745>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36746>>>>>>>        End
36746>>>>>>>>
36746>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36747>>>>>>>    End_Function
36748>>>>>>>    
36748>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36750>>>>>>>        Boolean bRequiresTimeCost
36750>>>>>>>        UInteger uiAlgo uiTimeCost
36750>>>>>>>        Integer iBegin iEnd
36750>>>>>>>        String sSalt
36750>>>>>>>        
36750>>>>>>>        Move 1 to iBegin
36751>>>>>>>        
36751>>>>>>>        // Parse Algo
36751>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36752>>>>>>>        If (not(iEnd)) Function_Return False
36755>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36756>>>>>>>        
36756>>>>>>>        // Parse Salt
36756>>>>>>>        Move (iEnd + 1) to iBegin
36757>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36758>>>>>>>        If (not(iEnd)) Function_Return False
36761>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36762>>>>>>>        
36762>>>>>>>        Case Begin
36762>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36764>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36767>>>>>>>                Move True to bRequiresTimeCost
36768>>>>>>>                Case Break
36769>>>>>>>            Case Else
36769>>>>>>>                Error 8710 "Invalid algorithm selected."
36770>>>>>>>>
36770>>>>>>>                Function_Return False
36771>>>>>>>        Case End
36771>>>>>>>        
36771>>>>>>>        // Parse optional timecost
36771>>>>>>>        If (bRequiresTimeCost) Begin
36773>>>>>>>            Move (iEnd + 1) to iBegin
36774>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36775>>>>>>>            If (not(iEnd)) Function_Return False
36778>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36779>>>>>>>        End
36779>>>>>>>>
36779>>>>>>>        
36779>>>>>>>        // Parse rest hash
36779>>>>>>>        Move (iEnd + 1) to iBegin
36780>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36781>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36784>>>>>>>        
36784>>>>>>>        // Base64Decode
36784>>>>>>>        UChar[] ucaSalt
36785>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36786>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36789>>>>>>>        
36789>>>>>>>        // Create new hash
36789>>>>>>>        String sNewHash
36789>>>>>>>        If (bRequiresTimeCost) Begin
36791>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36793>>>>>>>                Function_Return False 
36794>>>>>>>            End
36794>>>>>>>>
36794>>>>>>>        End
36794>>>>>>>>
36794>>>>>>>        Else Begin
36795>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36797>>>>>>>                Function_Return False 
36798>>>>>>>            End
36798>>>>>>>>
36798>>>>>>>        End
36798>>>>>>>>
36798>>>>>>>        Function_Return (sNewHash = sHash)
36799>>>>>>>    End_Function
36800>>>>>>>    
36800>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36802>>>>>>>        Boolean bRequireTimeCost
36802>>>>>>>        UBigInt ullSize
36802>>>>>>>        UChar[] ucaSalt
36803>>>>>>>        String sSalt
36803>>>>>>>        
36803>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36804>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36805>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36808>>>>>>>        
36808>>>>>>>        Case Begin
36808>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36810>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36811>>>>>>>                Move True to bRequireTimeCost
36812>>>>>>>                Case Break
36813>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36816>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36817>>>>>>>                Move True to bRequireTimeCost
36818>>>>>>>                Case Break
36819>>>>>>>            Case Else
36819>>>>>>>                Error 8710 "Invalid algorithm selected."
36820>>>>>>>>
36820>>>>>>>                Function_Return 0
36821>>>>>>>        Case End
36821>>>>>>>        
36821>>>>>>>        // calculate base64 in a non-floating-manner
36821>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36822>>>>>>>        
36822>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36823>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36824>>>>>>>        If (bRequireTimeCost) Begin
36826>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36827>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36828>>>>>>>        End
36828>>>>>>>>
36828>>>>>>>        Else Begin
36829>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36830>>>>>>>        End
36830>>>>>>>>
36830>>>>>>>        
36830>>>>>>>        Function_Return ullSize
36831>>>>>>>    End_Function
36832>>>>>>>End_Class
36833>>>>>>>
36833>>>>>>>Class cPasswordHasher is a cObject
36834>>>>>>>    
36834>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36835>>>>>>>    
36835>>>>>>>    Procedure Construct_Object
36837>>>>>>>        Forward Send Construct_Object
36839>>>>>>>        
36839>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36840>>>>>>>        Property UInteger   puiSaltSize         16
36841>>>>>>>        
36841>>>>>>>        Property UInteger   puiOptTimeCost      420000
36842>>>>>>>    End_Procedure
36843>>>>>>>    
36843>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36845>>>>>>>        Boolean bOk
36845>>>>>>>        UInteger uiAlgo
36845>>>>>>>        Get peAlgorithm to uiAlgo
36846>>>>>>>        
36846>>>>>>>        Case Begin
36846>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36848>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36851>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36852>>>>>>>                Case Break
36853>>>>>>>            Case Else
36853>>>>>>>                Error 8710 "Invalid algorithm selected."
36854>>>>>>>>
36854>>>>>>>                Function_Return False
36855>>>>>>>        Case End
36855>>>>>>>        
36855>>>>>>>        Function_Return bOk
36856>>>>>>>    End_Function
36857>>>>>>>    
36857>>>>>>>    Function RequiredBufferSize Returns UBigInt
36859>>>>>>>        UBigInt ullSize
36859>>>>>>>        UInteger uiAlgo
36859>>>>>>>        Get peAlgorithm to uiAlgo
36860>>>>>>>        
36860>>>>>>>        Case Begin
36860>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36862>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36865>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36866>>>>>>>                Case Break
36867>>>>>>>            Case Else
36867>>>>>>>                Error 8710 "Invalid algorithm selected."
36868>>>>>>>>
36868>>>>>>>                Function_Return 0
36869>>>>>>>        Case End
36869>>>>>>>        
36869>>>>>>>        Function_Return ullSize
36870>>>>>>>    End_Function
36871>>>>>>>
36871>>>>>>>End_Class
