38338>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38341>>>
38341>>>        // if this view is being used in multiple contexts, you may need a block of code
38341>>>        // like this to handle customizations. This would include hiding rows and buttons
38341>>>        // (WebSet pbRender) and changing the values of various captions.
38341>>>        Case Begin
38341>>>            Case (NavigateData.eNavigateType = nfFromMain)
38343>>>                // If from main, this is a probably a main file Select to Zoom.
38343>>>                // This is the most typical way to navigate to a zoom.
38343>>>                Case Break
38344>>>                
38344>>>            Case (NavigateData.eNavigateType = nfFromParent)
38347>>>                // If from parent, this is a constrained drill down.
38347>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38347>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38347>>>                Case Break
38348>>>                
38348>>>            Case (NavigateData.eNavigateType = nfFromChild)
38351>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38351>>>                // This is unusual, but it might be used for adding a new child record.
38351>>>                Case Break
38352>>>                
38352>>>            Case Else // must be nfUndefined
38352>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38352>>>                // You may want to check NavigateData.NamedValues.
38352>>>                  
38352>>>        Case End
38352>>>
38352>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38352>>>        // It's best to set these buttons in their own procedure so you can change later.
38352>>>        Send SetActionButtons
38353>>>
38353>>>    End_Procedure
38354>>>
38354>>>End_Object
