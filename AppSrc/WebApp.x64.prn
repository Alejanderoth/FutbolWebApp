37298>>>    Procedure DoLogin
37301>>>        String sLoginName sPassword sPrevStateHash
37301>>>        Boolean bResult
37301>>>        
37301>>>        WebGet psValue of oLoginName to sLoginName
37302>>>        WebGet psValue of oPassword to sPassword
37303>>>        
37303>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37304>>>        
37304>>>        If (bResult) Begin
37306>>>            Send Hide of oLogin
37307>>>            Send ShowHeader of ghoWebApp
37308>>>            WebSet psCSSClass of ghoWebApp to ""
37309>>>            
37309>>>            WebGet psPrevStateHash to sPrevStateHash
37310>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37311>>>            
37311>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37311>>>            WebSet psValue of oLoginName to ""
37312>>>            WebSet psValue of oPassword  to ""
37313>>>            WebSet pbVisible of oWarning to False
37314>>>        End
37314>>>>
37314>>>        Else Begin
37315>>>            WebSet pbVisible of oWarning to True
37316>>>        End
37316>>>>
37316>>>    End_Procedure
