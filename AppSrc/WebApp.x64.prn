37327>>>        Get StateHash of ghoWebApp to sPrevStateHash
37328>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37329>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37331>>>            WebSet psPrevStateHash to sPrevStateHash
37332>>>        End
37332>>>>
37332>>>        
37332>>>    End_Procedure
