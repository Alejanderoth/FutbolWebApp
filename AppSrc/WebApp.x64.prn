36904>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36905>>>>>    
36905>>>>>    Procedure Construct_Object
36907>>>>>        Handle hoObj
36907>>>>>        
36907>>>>>        Forward Send Construct_Object
36909>>>>>        
36909>>>>>        Set pbSessionCookieHttpOnly to True
36910>>>>>        
36910>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36911>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36912>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36913>>>>>        
36913>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36914>>>>>        Set phoUserDD to hoObj
36915>>>>>        
36915>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36916>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36917>>>>>        Set phoSessionDD to hoObj
36918>>>>>        
36918>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36919>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36920>>>>>        Set phoCrypto to hoObj
36921>>>>>        
36921>>>>>        Property Boolean pbPasswordHashing True
36922>>>>>        
36922>>>>>        Property Boolean pbCreatingNewSession False
36923>>>>>        Property String psLoginName
36924>>>>>        Property String psUserName ""
36925>>>>>        Property Integer piUserRights 0
36926>>>>>    End_Procedure
36927>>>>>    
36927>>>>>    Procedure End_Construct_Object
36929>>>>>        Forward Send End_Construct_Object
36931>>>>>        
36931>>>>>        Handle hoCrypto
36931>>>>>        Integer iFieldLen
36931>>>>>        If (pbPasswordHashing(Self)) Begin
36933>>>>>            Get phoCrypto to hoCrypto
36934>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36937>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36939>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36940>>>>>>
36940>>>>>            End
36940>>>>>>
36940>>>>>        End
36940>>>>>>
36940>>>>>    End_Procedure
36941>>>>>    
36941>>>>>    Function CreateSession String sRemoteAddress Returns String
36943>>>>>        String sSessionKey
36943>>>>>        Integer iErr
36943>>>>>        Boolean bLogWebSession
36943>>>>>        Handle hoSessionDD       
36943>>>>>        Get phoSessionDD to hoSessionDD
36944>>>>>        
36944>>>>>        //  Get session key
36944>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36946>>>>>        
36946>>>>>        Get pbLogWebSession to bLogWebSession
36947>>>>>        If not bLogWebSession Begin
36949>>>>>            Function_Return sSessionKey        
36950>>>>>        End
36950>>>>>>
36950>>>>>
36950>>>>>        //  Store session
36950>>>>>        Send Clear of hoSessionDD
36951>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36952>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36953>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36954>>>>>        Get Request_Validate of hoSessionDD to iErr
36955>>>>>        If (iErr) Begin
36957>>>>>            // this should not happen. If it does its a programming error
36957>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36958>>>>>>
36958>>>>>            Function_Return ""
36959>>>>>        End
36959>>>>>>
36959>>>>>        Send Request_Save of hoSessionDD
36960>>>>>        If (Err) Begin
36962>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36962>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36963>>>>>>
36963>>>>>            Function_Return ""
36964>>>>>        End
36964>>>>>>
36964>>>>>       
36964>>>>>        Function_Return sSessionKey        
36965>>>>>    End_Function
36966>>>>>    
36966>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36968>>>>>        DateTime dtLastAccess dtCurrent
36968>>>>>        TimeSpan tsDiff
36968>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36968>>>>>        Boolean bResult bCreatingNewSession
36968>>>>>        Boolean bLogWebSession bLoadWebApp
36968>>>>>        Integer eLoginMode
36968>>>>>        String sTime
36968>>>>>        Handle hoSessionDD hoUserDD       
36968>>>>>        
36968>>>>>        Move False to bLoadWebApp
36969>>>>>        If (num_arguments >= 2) Begin
36971>>>>>            Move bOptLoadWebApp to bLoadWebApp
36972>>>>>        End
36972>>>>>>
36972>>>>>        
36972>>>>>        Get phoSessionDD to hoSessionDD
36973>>>>>        Get phoUserDD to hoUserDD
36974>>>>>        
36974>>>>>        Get pbLogWebSession to bLogWebSession
36975>>>>>        Get peLoginMode to eLoginMode
36976>>>>>        
36976>>>>>        // for this object, you can only disable logging if login completely is disabled
36976>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36978>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36979>>>>>>
36979>>>>>            Function_Return False
36980>>>>>        End
36980>>>>>>
36980>>>>>
36980>>>>>        //  Clear session properties
36980>>>>>        Set psSessionKey to ""
36981>>>>>        Send UpdateSessionProperties True
36982>>>>>        
36982>>>>>        If not bLogWebSession Begin
36984>>>>>            Forward Get ValidateSession sSessionKey to bResult
36986>>>>>            Function_Return bResult
36987>>>>>        End        
36987>>>>>>
36987>>>>>        
36987>>>>>        Move False to bResult
36988>>>>>        Get piSessionTimeout to iSessionTimeout 
36989>>>>>        
36989>>>>>        //  Check if session exists
36989>>>>>        Send Clear of hoSessionDD
36990>>>>>        Move sSessionKey to WebAppSession.SessionKey
36991>>>>>        Send Find of hoSessionDD EQ Index.1
36992>>>>>            
36992>>>>>        If (Found) Begin
36994>>>>>            //  Calculate timespan between now and last access time
36994>>>>>            Move (CurrentDateTime()) to dtCurrent
36995>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36996>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36997>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36998>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36999>>>>>            
36999>>>>>            //  Check if session didn't time out
36999>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37001>>>>>                Forward Get ValidateSession sSessionKey to bResult
37003>>>>>                   
37003>>>>>                If (bResult) Begin
37005>>>>>                    //  Update session record
37005>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37006>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37007>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37008>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37009>>>>>                    Get Request_Validate of hoSessionDD to iErr
37010>>>>>                    If (iErr) Begin
37012>>>>>                        // this should not happen. If it does its a programming error
37012>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37013>>>>>>
37013>>>>>                        Function_Return False
37014>>>>>                    End
37014>>>>>>
37014>>>>>                    Send Request_Save of hoSessionDD
37015>>>>>                    
37015>>>>>                    //  Update user properties
37015>>>>>                    Send UpdateSessionProperties False
37016>>>>>                End
37016>>>>>>
37016>>>>>            End
37016>>>>>>
37016>>>>>            Else Begin
37017>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37017>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37018>>>>>                
37018>>>>>                If (not(bCreatingNewSession)) Begin
37020>>>>>                    If (not(bLoadWebApp)) Begin
37022>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37023>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37024>>>>>>
37024>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37025>>>>>                    End
37025>>>>>>
37025>>>>>                    Else Begin
37026>>>>>                        Set pbCreatingNewSession to True                    
37027>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37028>>>>>                        Set pbCreatingNewSession to False                        
37029>>>>>                    End
37029>>>>>>
37029>>>>>                End
37029>>>>>>
37029>>>>>            End
37029>>>>>>
37029>>>>>        End
37029>>>>>>
37029>>>>>        Else Begin
37030>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37031>>>>>>
37031>>>>>        End
37031>>>>>>
37031>>>>>        
37031>>>>>        Function_Return bResult
37032>>>>>    End_Function
37033>>>>>    
37033>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37035>>>>>        If (not(pbPasswordHashing(Self))) Begin
37037>>>>>            Move sPassword to sHash
37038>>>>>            Function_Return True
37039>>>>>        End
37039>>>>>>
37039>>>>>        
37039>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37041>>>>>            Function_Return False
37042>>>>>        End
37042>>>>>>
37042>>>>>        Move ("V1$" + sHash) to sHash
37043>>>>>        Function_Return True
37044>>>>>    End_Function
37045>>>>>    
37045>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37047>>>>>        If (not(pbPasswordHashing(Self))) Begin
37049>>>>>            Move False to bShouldUpgrade
37050>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37051>>>>>        End
37051>>>>>>
37051>>>>>        
37051>>>>>        String sVersion
37051>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37052>>>>>        If (sVersion = "V1$") Begin
37054>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37057>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37058>>>>>        End
37058>>>>>>
37058>>>>>        Else Begin
37059>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37062>>>>>            Function_Return False
37063>>>>>        End
37063>>>>>>
37063>>>>>    End_Function
37064>>>>>    
37064>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37066>>>>>        Handle hoUserDD
37066>>>>>        Integer iErr
37066>>>>>        Get phoUserDD to hoUserDD
37067>>>>>        
37067>>>>>        //  Find the user
37067>>>>>        Send Clear of hoUserDD
37068>>>>>        Move sLoginName to WebAppUser.LoginName
37069>>>>>        Send Find of hoUserDD EQ Index.1
37070>>>>>        If (Found) Begin
37072>>>>>            Send Clear of hoUserDD
37073>>>>>            Function_Return False
37074>>>>>        End
37074>>>>>>
37074>>>>>        
37074>>>>>        Send Clear of hoUserDD
37075>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37076>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37077>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37079>>>>>            Send Clear of hoUserDD
37080>>>>>            Function_Return False
37081>>>>>        End
37081>>>>>>
37081>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37082>>>>>        Get Request_Validate of hoUserDD to iErr
37083>>>>>        If (iErr) Begin
37085>>>>>            Send Clear of hoUserDD
37086>>>>>            Function_Return False
37087>>>>>        End
37087>>>>>>
37087>>>>>        
37087>>>>>        Send Request_Save of hoUserDD
37088>>>>>        Function_Return (not(Err))
37089>>>>>    End_Function
37090>>>>>    
37090>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37092>>>>>        String sSessionKey sUserPassword
37092>>>>>        Handle hoSessionDD hoUserDD
37092>>>>>        Boolean bMatch bUpgrade
37092>>>>>        
37092>>>>>        Get phoSessionDD to hoSessionDD
37093>>>>>        Get phoUserDD to hoUserDD
37094>>>>>        Integer iErr eLoginMode
37094>>>>>        
37094>>>>>        // Refind session record
37094>>>>>        Get psSessionKey to sSessionKey
37095>>>>>        Send Clear of hoSessionDD
37096>>>>>        Move sSessionKey to WebAppSession.SessionKey
37097>>>>>        Send Find of hoSessionDD EQ Index.1
37098>>>>>        
37098>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37100>>>>>            Get peLoginMode to eLoginMode
37101>>>>>            
37101>>>>>            //  Find the user
37101>>>>>            Move sLoginName to WebAppUser.LoginName
37102>>>>>            Send Find of hoUserDD EQ Index.1
37103>>>>>            
37103>>>>>            // Check username and password
37103>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37105>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37106>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37107>>>>>                
37107>>>>>                If (bMatch) Begin
37109>>>>>                    // Store the login
37109>>>>>                    If (bUpgrade) Begin
37111>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37112>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37115>>>>>                    End
37115>>>>>>
37115>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37116>>>>>                    Get Request_Validate of hoSessionDD to iErr
37117>>>>>                    If (iErr) Begin
37119>>>>>                        // this should not happen. If it does its a programming error
37119>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37120>>>>>>
37120>>>>>                        Function_Return False
37121>>>>>                    End
37121>>>>>>
37121>>>>>                    
37121>>>>>                    Send Request_Save of hoSessionDD
37122>>>>>                    
37122>>>>>                    // Update session properties
37122>>>>>                    Send UpdateSessionProperties False
37123>>>>>                    Send NotifyChangeRights
37124>>>>>                    Function_Return True
37125>>>>>                End
37125>>>>>>
37125>>>>>                Else Begin
37126>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37126>>>>>                    Send Clear of hoUserDD
37127>>>>>                End
37127>>>>>>
37127>>>>>            End
37127>>>>>>
37127>>>>>            Else Begin
37128>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37128>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37129>>>>>            End
37129>>>>>>
37129>>>>>        End
37129>>>>>>
37129>>>>>        Else Begin
37130>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37130>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37131>>>>>        End
37131>>>>>>
37131>>>>>          
37131>>>>>        Function_Return False
37132>>>>>    End_Function
37133>>>>>    
37133>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37135>>>>>        Handle hoUserDD
37135>>>>>        Integer iErr
37135>>>>>        Get phoUserDD to hoUserDD
37136>>>>>        
37136>>>>>        //  Find the user
37136>>>>>        Send Clear of hoUserDD
37137>>>>>        Move sLoginName to WebAppUser.LoginName
37138>>>>>        Send Find of hoUserDD EQ Index.1
37139>>>>>        If (not(Found)) Begin
37141>>>>>            Send Clear of hoUserDD
37142>>>>>            Function_Return False
37143>>>>>        End
37143>>>>>>
37143>>>>>        
37143>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37145>>>>>            Send Clear of hoUserDD
37146>>>>>            Function_Return False
37147>>>>>        End
37147>>>>>>
37147>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37148>>>>>        Get Request_Validate of hoUserDD to iErr
37149>>>>>        If (iErr) Begin
37151>>>>>            Send Clear of hoUserDD
37152>>>>>            Function_Return False
37153>>>>>        End
37153>>>>>>
37153>>>>>        
37153>>>>>        Send Request_Save of hoUserDD
37154>>>>>        Function_Return (not(Err))
37155>>>>>    End_Function
37156>>>>>    
37156>>>>>    Function IsLoggedIn Returns Boolean
37158>>>>>        String sLoginName
37158>>>>>        Boolean bLogWebSession bLoggedIn
37158>>>>>        
37158>>>>>        Get pbLogWebSession to bLogWebSession
37159>>>>>        If not bLogWebSession Begin
37161>>>>>            Forward Get IsLoggedIn to bLoggedIn
37163>>>>>            Function_Return bLoggedIn
37164>>>>>        End
37164>>>>>>
37164>>>>>        
37164>>>>>        Get psLoginName to sLoginName
37165>>>>>        
37165>>>>>        Function_Return (sLoginName <> "")
37166>>>>>    End_Function
37167>>>>>    
37167>>>>>    
37167>>>>>    //
37167>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37167>>>>>    // update properties based on the session and user data. Augment this function to update 
37167>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37167>>>>>    // the right records when this procedure is called.
37167>>>>>    //
37167>>>>>    // Params:
37167>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37167>>>>>    //
37167>>>>>    Procedure UpdateSessionProperties Boolean bClear
37169>>>>>        Handle hoUserDD
37169>>>>>        
37169>>>>>        Get phoUserDD to hoUserDD
37170>>>>>        
37170>>>>>        //  Update user properties
37170>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37172>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37173>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37174>>>>>            Set piUserRights to WebAppUser.Rights
37175>>>>>            
37175>>>>>            Send OnSessionPropertiesSet 
37176>>>>>        End
37176>>>>>>
37176>>>>>        Else Begin
37177>>>>>            Set psUsername to ""
37178>>>>>            Set psLoginName to ""
37179>>>>>            Set piUserRights to 0
37180>>>>>            
37180>>>>>            Send OnSessionPropertiesClear
37181>>>>>        End
37181>>>>>>
37181>>>>>    End_Procedure
37182>>>>>    
37182>>>>>    Procedure OnSessionPropertiesSet
37184>>>>>        //  Empty event stub
37184>>>>>    End_Procedure
37185>>>>>    
37185>>>>>    Procedure OnSessionPropertiesClear
37187>>>>>        //  Empty event stub
37187>>>>>    End_Procedure
37188>>>>>    
37188>>>>>    Procedure EndSession
37190>>>>>        Integer iErr
37190>>>>>        Boolean bLogWebSession
37190>>>>>        Handle hoSessionDD       
37190>>>>>        
37190>>>>>        Get phoSessionDD to hoSessionDD
37191>>>>>        Get pbLogWebSession to bLogWebSession
37192>>>>>        If not bLogWebSession Begin
37194>>>>>            Forward Send EndSession
37196>>>>>            Procedure_Return
37197>>>>>        End
37197>>>>>>
37197>>>>>            
37197>>>>>        //  Check if session exists
37197>>>>>        Send Clear of hoSessionDD
37198>>>>>        Get psSessionKey to WebAppSession.SessionKey
37199>>>>>        
37199>>>>>        Send Find of hoSessionDD EQ Index.1
37200>>>>>        If (Found) Begin
37202>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37203>>>>>            Get Request_Validate of hoSessionDD to iErr
37204>>>>>            If (iErr) Begin
37206>>>>>                // this should not happen. If it does its a programming error
37206>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37207>>>>>>
37207>>>>>                Procedure_Return
37208>>>>>            End
37208>>>>>>
37208>>>>>            Send Request_Save of hoSessionDD
37209>>>>>        End
37209>>>>>>
37209>>>>>    End_Procedure
37210>>>>>
37210>>>>>End_Class
