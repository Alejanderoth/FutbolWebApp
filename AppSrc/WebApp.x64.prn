37887>>>
37887>>>    // This can be used to show and hide buttons based on context.
37887>>>    // This can be called any time the view is active.
37887>>>    Procedure SetActionButtons
37890>>>        tWebNavigateData NavigateData
37890>>>        tWebNavigateData NavigateData
37890>>>        Boolean bHasRecord
37890>>>        Handle hoDD
37890>>>
37890>>>        Get Server to hoDD
37891>>>        Get GetNavigateData to NavigateData
37892>>>        
37892>>>        If (hoDD) Begin
37894>>>            Get HasRecord of hoDD to bHasRecord
37895>>>        End
37895>>>>
37895>>>        Else Begin
37896>>>            Move False to bHasRecord
37897>>>        End
37897>>>>
37897>>>
37897>>>        // let's hide all buttons and then show the ones we want
37897>>>        WebSet pbRender of oEditBtn to False 
37898>>>        WebSet pbRender of oSaveBtn to False
37899>>>        WebSet pbRender of oCancelChangesBtn to False
37900>>>        WebSet pbRender of oDeleteBtn to False
37901>>>
37901>>>        If (NavigateData.bReadOnly) Begin 
37903>>>            WebSet pbRender of oEditBtn to True 
37904>>>        End
37904>>>>
37904>>>        Else Begin
37905>>>            WebSet pbRender of oSaveBtn to True
37906>>>            WebSet pbRender of oCancelChangesBtn to True
37907>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37908>>>        End
37908>>>>
37908>>>    End_Procedure
37909>>>
