37236>>>    Procedure DoLogin
37239>>>        String sLoginName sPassword sPrevStateHash
37239>>>        Boolean bResult
37239>>>        
37239>>>        WebGet psValue of oLoginName to sLoginName
37240>>>        WebGet psValue of oPassword to sPassword
37241>>>        
37241>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37242>>>        
37242>>>        If (bResult) Begin
37244>>>            Send Hide of oLogin
37245>>>            Send ShowHeader of ghoWebApp
37246>>>            WebSet psCSSClass of ghoWebApp to ""
37247>>>            
37247>>>            WebGet psPrevStateHash to sPrevStateHash
37248>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37249>>>            
37249>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37249>>>            WebSet psValue of oLoginName to ""
37250>>>            WebSet psValue of oPassword  to ""
37251>>>            WebSet pbVisible of oWarning to False
37252>>>        End
37252>>>>
37252>>>        Else Begin
37253>>>            WebSet pbVisible of oWarning to True
37254>>>        End
37254>>>>
37254>>>    End_Procedure
