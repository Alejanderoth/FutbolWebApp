38584>>>        tWebNavigateData NavigateData
38584>>>        tWebNavigateData NavigateData
38584>>>        Boolean bHasRecord
38584>>>        Handle hoDD
38584>>>
38584>>>        Get Server to hoDD
38585>>>        Get GetNavigateData to NavigateData
38586>>>        
38586>>>        If (hoDD) Begin
38588>>>            Get HasRecord of hoDD to bHasRecord
38589>>>        End
38589>>>>
38589>>>        Else Begin
38590>>>            Move False to bHasRecord
38591>>>        End
38591>>>>
38591>>>
38591>>>        // let's hide all buttons and then show the ones we want
38591>>>        WebSet pbRender of oEditBtn to False 
38592>>>        WebSet pbRender of oSaveBtn to False
38593>>>        WebSet pbRender of oCancelChangesBtn to False
38594>>>        WebSet pbRender of oDeleteBtn to False
38595>>>
38595>>>        If (NavigateData.bReadOnly) Begin 
38597>>>            WebSet pbRender of oEditBtn to True 
38598>>>        End
38598>>>>
38598>>>        Else Begin
38599>>>            WebSet pbRender of oSaveBtn to True
38600>>>            WebSet pbRender of oCancelChangesBtn to True
38601>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38602>>>        End
38602>>>>
38602>>>    End_Procedure
