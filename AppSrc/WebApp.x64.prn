37607>>>    // Add code to customize your Zoom View based on how it was invoked.
37607>>>    // Use NavigateData to determine the context this view will be used in.
37607>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37610>>>
37610>>>        // if this view is being used in multiple contexts, you may need a block of code
37610>>>        // like this to handle customizations. This would include hiding rows and buttons
37610>>>        // (WebSet pbRender) and changing the values of various captions.
37610>>>        Case Begin
37610>>>            Case (NavigateData.eNavigateType = nfFromMain)
37612>>>                // If from main, this is a probably a main file Select to Zoom.
37612>>>                // This is the most typical way to navigate to a zoom.
37612>>>                Case Break
37613>>>                
37613>>>            Case (NavigateData.eNavigateType = nfFromParent)
37616>>>                // If from parent, this is a constrained drill down.
37616>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
37616>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
37616>>>                Case Break
37617>>>                
37617>>>            Case (NavigateData.eNavigateType = nfFromChild)
37620>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
37620>>>                // This is unusual, but it might be used for adding a new child record.
37620>>>                Case Break
