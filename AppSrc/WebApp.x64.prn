38328>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38331>>>        Send NavigateClose Self
38332>>>    End_Procedure
38333>>>
38333>>>    // this will close the view after a delete
38333>>>    Procedure OnViewDeleted Handle hoDDO
38336>>>        Send NavigateClose Self
38337>>>    End_Procedure
