37357>>>        Get StateHash of ghoWebApp to sPrevStateHash
37358>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37359>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37361>>>            WebSet psPrevStateHash to sPrevStateHash
37362>>>        End
37362>>>>
37362>>>        
37362>>>    End_Procedure
