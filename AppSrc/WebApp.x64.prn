37360>>>    Procedure DoLogin
37363>>>        String sLoginName sPassword sPrevStateHash
37363>>>        Boolean bResult
37363>>>        
37363>>>        WebGet psValue of oLoginName to sLoginName
37364>>>        WebGet psValue of oPassword to sPassword
37365>>>        
37365>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37366>>>        
37366>>>        If (bResult) Begin
37368>>>            Send Hide of oLogin
37369>>>            Send ShowHeader of ghoWebApp
37370>>>            WebSet psCSSClass of ghoWebApp to ""
37371>>>            
37371>>>            WebGet psPrevStateHash to sPrevStateHash
37372>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37373>>>            
37373>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37373>>>            WebSet psValue of oLoginName to ""
37374>>>            WebSet psValue of oPassword  to ""
37375>>>            WebSet pbVisible of oWarning to False
37376>>>        End
37376>>>>
37376>>>        Else Begin
37377>>>            WebSet pbVisible of oWarning to True
37378>>>        End
37378>>>>
37378>>>    End_Procedure
