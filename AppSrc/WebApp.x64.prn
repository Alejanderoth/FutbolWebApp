37634>>>    // This can be used to show and hide buttons based on context.
37634>>>    // This can be called any time the view is active.
37634>>>    Procedure SetActionButtons
37637>>>        tWebNavigateData NavigateData
37637>>>        tWebNavigateData NavigateData
37637>>>        Boolean bHasRecord
37637>>>        Handle hoDD
37637>>>
37637>>>        Get Server to hoDD
37638>>>        Get GetNavigateData to NavigateData
37639>>>        
37639>>>        If (hoDD) Begin
37641>>>            Get HasRecord of hoDD to bHasRecord
37642>>>        End
37642>>>>
37642>>>        Else Begin
37643>>>            Move False to bHasRecord
37644>>>        End
37644>>>>
37644>>>
37644>>>        // let's hide all buttons and then show the ones we want
