39030>>>        //      Send NavigateClose Self
39030>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
39030>>>        //      Send NavigateForward of oZoomMainView Self
39030>>>        //      Send NavigateForward of oSelectChildView Self
39030>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
39030>>>        Procedure OnRowClick String sRowID
39033>>>
39033>>>            // If this view is being used in multiple contexts, you may need a block of code
39033>>>            // like this to handle different types of navigation
39033>>>            tWebNavigateData NavigateData
39033>>>            tWebNavigateData NavigateData
39033>>>            Get GetNavigateData to NavigateData
39034>>>            Case Begin
39034>>>                Case (NavigateData.eNavigateType=nfFromParent)
39036>>>                    // If from parent, this is a constrained drilldown.
