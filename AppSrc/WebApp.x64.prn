36698>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36699>>>>>>>                If (not(bOk)) Function_Return False
36702>>>>>>>                
36702>>>>>>>                Move True to bRequireTimeCost
36703>>>>>>>                Case Break
36704>>>>>>>            Case Else
36704>>>>>>>                Error 8710 "Invalid algorithm selected."
36705>>>>>>>>
36705>>>>>>>                Function_Return False
36706>>>>>>>        Case End
36706>>>>>>>        
36706>>>>>>>        String sSalt
36706>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36707>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36710>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36711>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36714>>>>>>>        
36714>>>>>>>        If (bRequireTimeCost) Begin
36716>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36717>>>>>>>        End
36717>>>>>>>>
36717>>>>>>>        Else Begin
36718>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36719>>>>>>>        End
36719>>>>>>>>
36719>>>>>>>        
36719>>>>>>>        Function_Return bOk
36720>>>>>>>    End_Function
36721>>>>>>>    
36721>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36723>>>>>>>        UChar[] ucaSalt
36724>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36725>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36728>>>>>>>        
36728>>>>>>>        If (num_arguments > 4) Begin
36730>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36731>>>>>>>        End
36731>>>>>>>>
36731>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36732>>>>>>>    End_Function
36733>>>>>>>    
36733>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36735>>>>>>>        Boolean bRequiresTimeCost
36735>>>>>>>        UInteger uiAlgo uiTimeCost
36735>>>>>>>        Integer iBegin iEnd
36735>>>>>>>        String sSalt
36735>>>>>>>        
36735>>>>>>>        Move 1 to iBegin
36736>>>>>>>        
36736>>>>>>>        // Parse Algo
36736>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36737>>>>>>>        If (not(iEnd)) Function_Return False
36740>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36741>>>>>>>        
36741>>>>>>>        // Parse Salt
36741>>>>>>>        Move (iEnd + 1) to iBegin
36742>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36743>>>>>>>        If (not(iEnd)) Function_Return False
36746>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36747>>>>>>>        
36747>>>>>>>        Case Begin
36747>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36749>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36752>>>>>>>                Move True to bRequiresTimeCost
36753>>>>>>>                Case Break
36754>>>>>>>            Case Else
36754>>>>>>>                Error 8710 "Invalid algorithm selected."
36755>>>>>>>>
36755>>>>>>>                Function_Return False
36756>>>>>>>        Case End
36756>>>>>>>        
36756>>>>>>>        // Parse optional timecost
36756>>>>>>>        If (bRequiresTimeCost) Begin
36758>>>>>>>            Move (iEnd + 1) to iBegin
36759>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36760>>>>>>>            If (not(iEnd)) Function_Return False
36763>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36764>>>>>>>        End
36764>>>>>>>>
36764>>>>>>>        
36764>>>>>>>        // Parse rest hash
36764>>>>>>>        Move (iEnd + 1) to iBegin
36765>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36766>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36769>>>>>>>        
36769>>>>>>>        // Base64Decode
36769>>>>>>>        UChar[] ucaSalt
36770>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36771>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36774>>>>>>>        
36774>>>>>>>        // Create new hash
36774>>>>>>>        String sNewHash
36774>>>>>>>        If (bRequiresTimeCost) Begin
36776>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36778>>>>>>>                Function_Return False 
36779>>>>>>>            End
36779>>>>>>>>
36779>>>>>>>        End
36779>>>>>>>>
36779>>>>>>>        Else Begin
36780>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36782>>>>>>>                Function_Return False 
36783>>>>>>>            End
36783>>>>>>>>
36783>>>>>>>        End
36783>>>>>>>>
36783>>>>>>>        Function_Return (sNewHash = sHash)
36784>>>>>>>    End_Function
36785>>>>>>>    
36785>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36787>>>>>>>        Boolean bRequireTimeCost
36787>>>>>>>        UBigInt ullSize
36787>>>>>>>        UChar[] ucaSalt
36788>>>>>>>        String sSalt
36788>>>>>>>        
36788>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36789>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36790>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36793>>>>>>>        
36793>>>>>>>        Case Begin
36793>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36795>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36796>>>>>>>                Move True to bRequireTimeCost
36797>>>>>>>                Case Break
36798>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36801>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36802>>>>>>>                Move True to bRequireTimeCost
36803>>>>>>>                Case Break
36804>>>>>>>            Case Else
36804>>>>>>>                Error 8710 "Invalid algorithm selected."
36805>>>>>>>>
36805>>>>>>>                Function_Return 0
36806>>>>>>>        Case End
36806>>>>>>>        
36806>>>>>>>        // calculate base64 in a non-floating-manner
36806>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36807>>>>>>>        
36807>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36808>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36809>>>>>>>        If (bRequireTimeCost) Begin
36811>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36812>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36813>>>>>>>        End
36813>>>>>>>>
36813>>>>>>>        Else Begin
36814>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36815>>>>>>>        End
36815>>>>>>>>
36815>>>>>>>        
36815>>>>>>>        Function_Return ullSize
36816>>>>>>>    End_Function
36817>>>>>>>End_Class
36818>>>>>>>
36818>>>>>>>Class cPasswordHasher is a cObject
36819>>>>>>>    
36819>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36820>>>>>>>    
36820>>>>>>>    Procedure Construct_Object
36822>>>>>>>        Forward Send Construct_Object
36824>>>>>>>        
36824>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36825>>>>>>>        Property UInteger   puiSaltSize         16
36826>>>>>>>        
36826>>>>>>>        Property UInteger   puiOptTimeCost      420000
36827>>>>>>>    End_Procedure
36828>>>>>>>    
36828>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36830>>>>>>>        Boolean bOk
36830>>>>>>>        UInteger uiAlgo
36830>>>>>>>        Get peAlgorithm to uiAlgo
36831>>>>>>>        
36831>>>>>>>        Case Begin
36831>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36833>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36836>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36837>>>>>>>                Case Break
36838>>>>>>>            Case Else
36838>>>>>>>                Error 8710 "Invalid algorithm selected."
36839>>>>>>>>
36839>>>>>>>                Function_Return False
36840>>>>>>>        Case End
36840>>>>>>>        
36840>>>>>>>        Function_Return bOk
36841>>>>>>>    End_Function
36842>>>>>>>    
36842>>>>>>>    Function RequiredBufferSize Returns UBigInt
36844>>>>>>>        UBigInt ullSize
36844>>>>>>>        UInteger uiAlgo
36844>>>>>>>        Get peAlgorithm to uiAlgo
36845>>>>>>>        
36845>>>>>>>        Case Begin
36845>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36847>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36850>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36851>>>>>>>                Case Break
36852>>>>>>>            Case Else
36852>>>>>>>                Error 8710 "Invalid algorithm selected."
36853>>>>>>>>
36853>>>>>>>                Function_Return 0
36854>>>>>>>        Case End
36854>>>>>>>        
36854>>>>>>>        Function_Return ullSize
36855>>>>>>>    End_Function
36856>>>>>>>
36856>>>>>>>End_Class
36857>>>>>
36857>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36858>>>>>    
36858>>>>>    Procedure Construct_Object
36860>>>>>        Handle hoObj
36860>>>>>        
36860>>>>>        Forward Send Construct_Object
36862>>>>>        
36862>>>>>        Set pbSessionCookieHttpOnly to True
36863>>>>>        
36863>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36864>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36865>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36866>>>>>        
36866>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36867>>>>>        Set phoUserDD to hoObj
36868>>>>>        
36868>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36869>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36870>>>>>        Set phoSessionDD to hoObj
36871>>>>>        
36871>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36872>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36873>>>>>        Set phoCrypto to hoObj
36874>>>>>        
36874>>>>>        Property Boolean pbPasswordHashing True
36875>>>>>        
36875>>>>>        Property Boolean pbCreatingNewSession False
36876>>>>>        Property String psLoginName
36877>>>>>        Property String psUserName ""
36878>>>>>        Property Integer piUserRights 0
36879>>>>>    End_Procedure
36880>>>>>    
36880>>>>>    Procedure End_Construct_Object
36882>>>>>        Forward Send End_Construct_Object
36884>>>>>        
36884>>>>>        Handle hoCrypto
36884>>>>>        Integer iFieldLen
36884>>>>>        If (pbPasswordHashing(Self)) Begin
36886>>>>>            Get phoCrypto to hoCrypto
36887>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36890>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36892>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36893>>>>>>
36893>>>>>            End
36893>>>>>>
36893>>>>>        End
36893>>>>>>
36893>>>>>    End_Procedure
36894>>>>>    
36894>>>>>    Function CreateSession String sRemoteAddress Returns String
36896>>>>>        String sSessionKey
36896>>>>>        Integer iErr
36896>>>>>        Boolean bLogWebSession
36896>>>>>        Handle hoSessionDD       
36896>>>>>        Get phoSessionDD to hoSessionDD
36897>>>>>        
36897>>>>>        //  Get session key
36897>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36899>>>>>        
36899>>>>>        Get pbLogWebSession to bLogWebSession
36900>>>>>        If not bLogWebSession Begin
36902>>>>>            Function_Return sSessionKey        
36903>>>>>        End
36903>>>>>>
36903>>>>>
36903>>>>>        //  Store session
36903>>>>>        Send Clear of hoSessionDD
36904>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36905>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36906>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36907>>>>>        Get Request_Validate of hoSessionDD to iErr
36908>>>>>        If (iErr) Begin
36910>>>>>            // this should not happen. If it does its a programming error
36910>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36911>>>>>>
36911>>>>>            Function_Return ""
36912>>>>>        End
36912>>>>>>
36912>>>>>        Send Request_Save of hoSessionDD
36913>>>>>        If (Err) Begin
36915>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36915>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36916>>>>>>
36916>>>>>            Function_Return ""
36917>>>>>        End
36917>>>>>>
36917>>>>>       
36917>>>>>        Function_Return sSessionKey        
36918>>>>>    End_Function
36919>>>>>    
36919>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36921>>>>>        DateTime dtLastAccess dtCurrent
36921>>>>>        TimeSpan tsDiff
36921>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36921>>>>>        Boolean bResult bCreatingNewSession
36921>>>>>        Boolean bLogWebSession bLoadWebApp
36921>>>>>        Integer eLoginMode
36921>>>>>        String sTime
36921>>>>>        Handle hoSessionDD hoUserDD       
36921>>>>>        
36921>>>>>        Move False to bLoadWebApp
36922>>>>>        If (num_arguments >= 2) Begin
36924>>>>>            Move bOptLoadWebApp to bLoadWebApp
36925>>>>>        End
36925>>>>>>
36925>>>>>        
36925>>>>>        Get phoSessionDD to hoSessionDD
36926>>>>>        Get phoUserDD to hoUserDD
36927>>>>>        
36927>>>>>        Get pbLogWebSession to bLogWebSession
36928>>>>>        Get peLoginMode to eLoginMode
36929>>>>>        
36929>>>>>        // for this object, you can only disable logging if login completely is disabled
36929>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36931>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36932>>>>>>
36932>>>>>            Function_Return False
36933>>>>>        End
36933>>>>>>
36933>>>>>
36933>>>>>        //  Clear session properties
36933>>>>>        Set psSessionKey to ""
36934>>>>>        Send UpdateSessionProperties True
36935>>>>>        
36935>>>>>        If not bLogWebSession Begin
36937>>>>>            Forward Get ValidateSession sSessionKey to bResult
36939>>>>>            Function_Return bResult
36940>>>>>        End        
36940>>>>>>
36940>>>>>        
36940>>>>>        Move False to bResult
36941>>>>>        Get piSessionTimeout to iSessionTimeout 
36942>>>>>        
36942>>>>>        //  Check if session exists
36942>>>>>        Send Clear of hoSessionDD
36943>>>>>        Move sSessionKey to WebAppSession.SessionKey
36944>>>>>        Send Find of hoSessionDD EQ Index.1
36945>>>>>            
36945>>>>>        If (Found) Begin
36947>>>>>            //  Calculate timespan between now and last access time
36947>>>>>            Move (CurrentDateTime()) to dtCurrent
36948>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36949>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36950>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36951>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36952>>>>>            
36952>>>>>            //  Check if session didn't time out
36952>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
36954>>>>>                Forward Get ValidateSession sSessionKey to bResult
36956>>>>>                   
36956>>>>>                If (bResult) Begin
36958>>>>>                    //  Update session record
36958>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
36959>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
36960>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
36961>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
36962>>>>>                    Get Request_Validate of hoSessionDD to iErr
36963>>>>>                    If (iErr) Begin
36965>>>>>                        // this should not happen. If it does its a programming error
36965>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36966>>>>>>
36966>>>>>                        Function_Return False
36967>>>>>                    End
36967>>>>>>
36967>>>>>                    Send Request_Save of hoSessionDD
36968>>>>>                    
36968>>>>>                    //  Update user properties
36968>>>>>                    Send UpdateSessionProperties False
36969>>>>>                End
36969>>>>>>
36969>>>>>            End
36969>>>>>>
36969>>>>>            Else Begin
36970>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
36970>>>>>                Get pbCreatingNewSession to bCreatingNewSession
36971>>>>>                
36971>>>>>                If (not(bCreatingNewSession)) Begin
36973>>>>>                    If (not(bLoadWebApp)) Begin
36975>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
36976>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
36977>>>>>>
36977>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
36978>>>>>                    End
36978>>>>>>
36978>>>>>                    Else Begin
36979>>>>>                        Set pbCreatingNewSession to True                    
36980>>>>>                        Get RecreateSession of ghoWebApp to bResult 
36981>>>>>                        Set pbCreatingNewSession to False                        
36982>>>>>                    End
36982>>>>>>
36982>>>>>                End
36982>>>>>>
36982>>>>>            End
36982>>>>>>
36982>>>>>        End
36982>>>>>>
36982>>>>>        Else Begin
36983>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
36984>>>>>>
36984>>>>>        End
36984>>>>>>
36984>>>>>        
36984>>>>>        Function_Return bResult
36985>>>>>    End_Function
36986>>>>>    
36986>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36988>>>>>        If (not(pbPasswordHashing(Self))) Begin
36990>>>>>            Move sPassword to sHash
36991>>>>>            Function_Return True
36992>>>>>        End
36992>>>>>>
36992>>>>>        
36992>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
36994>>>>>            Function_Return False
36995>>>>>        End
36995>>>>>>
36995>>>>>        Move ("V1$" + sHash) to sHash
36996>>>>>        Function_Return True
36997>>>>>    End_Function
36998>>>>>    
36998>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37000>>>>>        If (not(pbPasswordHashing(Self))) Begin
37002>>>>>            Move False to bShouldUpgrade
37003>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37004>>>>>        End
37004>>>>>>
37004>>>>>        
37004>>>>>        String sVersion
37004>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37005>>>>>        If (sVersion = "V1$") Begin
37007>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37010>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37011>>>>>        End
37011>>>>>>
37011>>>>>        Else Begin
37012>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37015>>>>>            Function_Return False
37016>>>>>        End
37016>>>>>>
37016>>>>>    End_Function
37017>>>>>    
37017>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37019>>>>>        Handle hoUserDD
37019>>>>>        Integer iErr
37019>>>>>        Get phoUserDD to hoUserDD
37020>>>>>        
37020>>>>>        //  Find the user
37020>>>>>        Send Clear of hoUserDD
37021>>>>>        Move sLoginName to WebAppUser.LoginName
37022>>>>>        Send Find of hoUserDD EQ Index.1
37023>>>>>        If (Found) Begin
37025>>>>>            Send Clear of hoUserDD
37026>>>>>            Function_Return False
37027>>>>>        End
37027>>>>>>
37027>>>>>        
37027>>>>>        Send Clear of hoUserDD
37028>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37029>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37030>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37032>>>>>            Send Clear of hoUserDD
37033>>>>>            Function_Return False
37034>>>>>        End
37034>>>>>>
37034>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37035>>>>>        Get Request_Validate of hoUserDD to iErr
37036>>>>>        If (iErr) Begin
37038>>>>>            Send Clear of hoUserDD
37039>>>>>            Function_Return False
37040>>>>>        End
37040>>>>>>
37040>>>>>        
37040>>>>>        Send Request_Save of hoUserDD
37041>>>>>        Function_Return (not(Err))
37042>>>>>    End_Function
37043>>>>>    
37043>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37045>>>>>        String sSessionKey sUserPassword
37045>>>>>        Handle hoSessionDD hoUserDD
37045>>>>>        Boolean bMatch bUpgrade
37045>>>>>        
37045>>>>>        Get phoSessionDD to hoSessionDD
37046>>>>>        Get phoUserDD to hoUserDD
37047>>>>>        Integer iErr eLoginMode
37047>>>>>        
37047>>>>>        // Refind session record
37047>>>>>        Get psSessionKey to sSessionKey
37048>>>>>        Send Clear of hoSessionDD
37049>>>>>        Move sSessionKey to WebAppSession.SessionKey
37050>>>>>        Send Find of hoSessionDD EQ Index.1
37051>>>>>        
37051>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37053>>>>>            Get peLoginMode to eLoginMode
37054>>>>>            
37054>>>>>            //  Find the user
37054>>>>>            Move sLoginName to WebAppUser.LoginName
37055>>>>>            Send Find of hoUserDD EQ Index.1
37056>>>>>            
37056>>>>>            // Check username and password
37056>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37058>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37059>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37060>>>>>                
37060>>>>>                If (bMatch) Begin
37062>>>>>                    // Store the login
37062>>>>>                    If (bUpgrade) Begin
37064>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37065>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37068>>>>>                    End
37068>>>>>>
37068>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37069>>>>>                    Get Request_Validate of hoSessionDD to iErr
37070>>>>>                    If (iErr) Begin
37072>>>>>                        // this should not happen. If it does its a programming error
37072>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37073>>>>>>
37073>>>>>                        Function_Return False
37074>>>>>                    End
37074>>>>>>
37074>>>>>                    
37074>>>>>                    Send Request_Save of hoSessionDD
37075>>>>>                    
37075>>>>>                    // Update session properties
37075>>>>>                    Send UpdateSessionProperties False
37076>>>>>                    Send NotifyChangeRights
37077>>>>>                    Function_Return True
37078>>>>>                End
37078>>>>>>
37078>>>>>                Else Begin
37079>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37079>>>>>                    Send Clear of hoUserDD
37080>>>>>                End
37080>>>>>>
37080>>>>>            End
37080>>>>>>
37080>>>>>            Else Begin
37081>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37081>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37082>>>>>            End
37082>>>>>>
37082>>>>>        End
37082>>>>>>
37082>>>>>        Else Begin
37083>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37083>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37084>>>>>        End
37084>>>>>>
37084>>>>>          
37084>>>>>        Function_Return False
37085>>>>>    End_Function
37086>>>>>    
37086>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37088>>>>>        Handle hoUserDD
37088>>>>>        Integer iErr
37088>>>>>        Get phoUserDD to hoUserDD
37089>>>>>        
37089>>>>>        //  Find the user
37089>>>>>        Send Clear of hoUserDD
37090>>>>>        Move sLoginName to WebAppUser.LoginName
37091>>>>>        Send Find of hoUserDD EQ Index.1
37092>>>>>        If (not(Found)) Begin
37094>>>>>            Send Clear of hoUserDD
37095>>>>>            Function_Return False
37096>>>>>        End
37096>>>>>>
37096>>>>>        
37096>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37098>>>>>            Send Clear of hoUserDD
37099>>>>>            Function_Return False
37100>>>>>        End
37100>>>>>>
37100>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37101>>>>>        Get Request_Validate of hoUserDD to iErr
37102>>>>>        If (iErr) Begin
37104>>>>>            Send Clear of hoUserDD
37105>>>>>            Function_Return False
37106>>>>>        End
37106>>>>>>
37106>>>>>        
37106>>>>>        Send Request_Save of hoUserDD
37107>>>>>        Function_Return (not(Err))
