37266>>>    Procedure DoLogin
37269>>>        String sLoginName sPassword sPrevStateHash
37269>>>        Boolean bResult
37269>>>        
37269>>>        WebGet psValue of oLoginName to sLoginName
37270>>>        WebGet psValue of oPassword to sPassword
37271>>>        
37271>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37272>>>        
37272>>>        If (bResult) Begin
37274>>>            Send Hide of oLogin
37275>>>            Send ShowHeader of ghoWebApp
37276>>>            WebSet psCSSClass of ghoWebApp to ""
37277>>>            
37277>>>            WebGet psPrevStateHash to sPrevStateHash
37278>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37279>>>            
37279>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37279>>>            WebSet psValue of oLoginName to ""
37280>>>            WebSet psValue of oPassword  to ""
37281>>>            WebSet pbVisible of oWarning to False
37282>>>        End
37282>>>>
37282>>>        Else Begin
37283>>>            WebSet pbVisible of oWarning to True
37284>>>        End
37284>>>>
37284>>>    End_Procedure
