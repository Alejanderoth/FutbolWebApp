36756>>>>>>>    
36756>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
36758>>>>>>>        Integer iErr
36758>>>>>>>        Pointer pBase64
36758>>>>>>>        String sBase64
36758>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
36759>>>>>>>        If (not(pBase64)) Begin
36761>>>>>>>            Function_Return sBase64
36762>>>>>>>        End
36762>>>>>>>>
36762>>>>>>>        Move (PointerToString(pBase64)) to sBase64
36763>>>>>>>        Move (Free(pBase64)) to iErr
36764>>>>>>>        Function_Return sBase64
36765>>>>>>>    End_Function
36766>>>>>>>    
36766>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36768>>>>>>>        Integer iLen
36768>>>>>>>        Pointer pBase64
36768>>>>>>>        UChar[] ucaBuffer
36769>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36770>>>>>>>        If (not(pBase64)) Begin
36772>>>>>>>            Function_Return ucaBuffer
36773>>>>>>>        End
36773>>>>>>>>
36773>>>>>>>        
36773>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36774>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36775>>>>>>>        Move (Free(pBase64)) to iLen
36776>>>>>>>        Function_Return ucaBuffer
36777>>>>>>>    End_Function
36778>>>>>>>    
36778>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36780>>>>>>>        Boolean bOk bRequireTimeCost
36780>>>>>>>        UChar[] ucaHash
36781>>>>>>>        
36781>>>>>>>        Case Begin
36781>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36783>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36784>>>>>>>                If (not(bOk)) Function_Return False
36787>>>>>>>                
36787>>>>>>>                Move True to bRequireTimeCost
36788>>>>>>>                Case Break
36789>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36792>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36793>>>>>>>                If (not(bOk)) Function_Return False
36796>>>>>>>                
36796>>>>>>>                Move True to bRequireTimeCost
36797>>>>>>>                Case Break
36798>>>>>>>            Case Else
36798>>>>>>>                Error 8710 "Invalid algorithm selected."
36799>>>>>>>>
36799>>>>>>>                Function_Return False
36800>>>>>>>        Case End
36800>>>>>>>        
36800>>>>>>>        String sSalt
36800>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36801>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36804>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36805>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36808>>>>>>>        
36808>>>>>>>        If (bRequireTimeCost) Begin
36810>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36811>>>>>>>        End
36811>>>>>>>>
36811>>>>>>>        Else Begin
36812>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36813>>>>>>>        End
36813>>>>>>>>
36813>>>>>>>        
36813>>>>>>>        Function_Return bOk
36814>>>>>>>    End_Function
36815>>>>>>>    
36815>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36817>>>>>>>        UChar[] ucaSalt
36818>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36819>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36822>>>>>>>        
36822>>>>>>>        If (num_arguments > 4) Begin
36824>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36825>>>>>>>        End
36825>>>>>>>>
36825>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36826>>>>>>>    End_Function
36827>>>>>>>    
36827>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36829>>>>>>>        Boolean bRequiresTimeCost
36829>>>>>>>        UInteger uiAlgo uiTimeCost
36829>>>>>>>        Integer iBegin iEnd
36829>>>>>>>        String sSalt
36829>>>>>>>        
36829>>>>>>>        Move 1 to iBegin
36830>>>>>>>        
36830>>>>>>>        // Parse Algo
36830>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36831>>>>>>>        If (not(iEnd)) Function_Return False
36834>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36835>>>>>>>        
36835>>>>>>>        // Parse Salt
36835>>>>>>>        Move (iEnd + 1) to iBegin
36836>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36837>>>>>>>        If (not(iEnd)) Function_Return False
36840>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36841>>>>>>>        
36841>>>>>>>        Case Begin
36841>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36843>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36846>>>>>>>                Move True to bRequiresTimeCost
36847>>>>>>>                Case Break
36848>>>>>>>            Case Else
36848>>>>>>>                Error 8710 "Invalid algorithm selected."
36849>>>>>>>>
36849>>>>>>>                Function_Return False
36850>>>>>>>        Case End
36850>>>>>>>        
36850>>>>>>>        // Parse optional timecost
36850>>>>>>>        If (bRequiresTimeCost) Begin
36852>>>>>>>            Move (iEnd + 1) to iBegin
36853>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36854>>>>>>>            If (not(iEnd)) Function_Return False
36857>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36858>>>>>>>        End
36858>>>>>>>>
36858>>>>>>>        
36858>>>>>>>        // Parse rest hash
36858>>>>>>>        Move (iEnd + 1) to iBegin
36859>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36860>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36863>>>>>>>        
36863>>>>>>>        // Base64Decode
36863>>>>>>>        UChar[] ucaSalt
36864>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36865>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36868>>>>>>>        
36868>>>>>>>        // Create new hash
36868>>>>>>>        String sNewHash
36868>>>>>>>        If (bRequiresTimeCost) Begin
36870>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36872>>>>>>>                Function_Return False 
36873>>>>>>>            End
36873>>>>>>>>
36873>>>>>>>        End
36873>>>>>>>>
36873>>>>>>>        Else Begin
36874>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36876>>>>>>>                Function_Return False 
36877>>>>>>>            End
36877>>>>>>>>
36877>>>>>>>        End
36877>>>>>>>>
36877>>>>>>>        Function_Return (sNewHash = sHash)
36878>>>>>>>    End_Function
36879>>>>>>>    
36879>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36881>>>>>>>        Boolean bRequireTimeCost
36881>>>>>>>        UBigInt ullSize
36881>>>>>>>        UChar[] ucaSalt
36882>>>>>>>        String sSalt
36882>>>>>>>        
36882>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36883>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36884>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36887>>>>>>>        
36887>>>>>>>        Case Begin
36887>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36889>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36890>>>>>>>                Move True to bRequireTimeCost
36891>>>>>>>                Case Break
36892>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36895>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36896>>>>>>>                Move True to bRequireTimeCost
36897>>>>>>>                Case Break
36898>>>>>>>            Case Else
36898>>>>>>>                Error 8710 "Invalid algorithm selected."
36899>>>>>>>>
36899>>>>>>>                Function_Return 0
36900>>>>>>>        Case End
36900>>>>>>>        
36900>>>>>>>        // calculate base64 in a non-floating-manner
36900>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36901>>>>>>>        
36901>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36902>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36903>>>>>>>        If (bRequireTimeCost) Begin
36905>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36906>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36907>>>>>>>        End
36907>>>>>>>>
36907>>>>>>>        Else Begin
36908>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36909>>>>>>>        End
36909>>>>>>>>
36909>>>>>>>        
36909>>>>>>>        Function_Return ullSize
36910>>>>>>>    End_Function
36911>>>>>>>End_Class
36912>>>>>>>
36912>>>>>>>Class cPasswordHasher is a cObject
36913>>>>>>>    
36913>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36914>>>>>>>    
36914>>>>>>>    Procedure Construct_Object
36916>>>>>>>        Forward Send Construct_Object
36918>>>>>>>        
36918>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36919>>>>>>>        Property UInteger   puiSaltSize         16
36920>>>>>>>        
36920>>>>>>>        Property UInteger   puiOptTimeCost      420000
36921>>>>>>>    End_Procedure
36922>>>>>>>    
36922>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36924>>>>>>>        Boolean bOk
36924>>>>>>>        UInteger uiAlgo
36924>>>>>>>        Get peAlgorithm to uiAlgo
36925>>>>>>>        
36925>>>>>>>        Case Begin
36925>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36927>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36930>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36931>>>>>>>                Case Break
36932>>>>>>>            Case Else
36932>>>>>>>                Error 8710 "Invalid algorithm selected."
36933>>>>>>>>
36933>>>>>>>                Function_Return False
36934>>>>>>>        Case End
36934>>>>>>>        
36934>>>>>>>        Function_Return bOk
36935>>>>>>>    End_Function
36936>>>>>>>    
36936>>>>>>>    Function RequiredBufferSize Returns UBigInt
36938>>>>>>>        UBigInt ullSize
36938>>>>>>>        UInteger uiAlgo
36938>>>>>>>        Get peAlgorithm to uiAlgo
36939>>>>>>>        
36939>>>>>>>        Case Begin
36939>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36941>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36944>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36945>>>>>>>                Case Break
36946>>>>>>>            Case Else
36946>>>>>>>                Error 8710 "Invalid algorithm selected."
36947>>>>>>>>
36947>>>>>>>                Function_Return 0
36948>>>>>>>        Case End
36948>>>>>>>        
36948>>>>>>>        Function_Return ullSize
36949>>>>>>>    End_Function
36950>>>>>>>
36950>>>>>>>End_Class
36951>>>>>
36951>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36952>>>>>    
36952>>>>>    Procedure Construct_Object
36954>>>>>        Handle hoObj
36954>>>>>        
36954>>>>>        Forward Send Construct_Object
36956>>>>>        
36956>>>>>        Set pbSessionCookieHttpOnly to True
36957>>>>>        
36957>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36958>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36959>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36960>>>>>        
36960>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36961>>>>>        Set phoUserDD to hoObj
36962>>>>>        
36962>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36963>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36964>>>>>        Set phoSessionDD to hoObj
36965>>>>>        
36965>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36966>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36967>>>>>        Set phoCrypto to hoObj
36968>>>>>        
36968>>>>>        Property Boolean pbPasswordHashing True
36969>>>>>        
36969>>>>>        Property Boolean pbCreatingNewSession False
36970>>>>>        Property String psLoginName
36971>>>>>        Property String psUserName ""
36972>>>>>        Property Integer piUserRights 0
36973>>>>>    End_Procedure
36974>>>>>    
36974>>>>>    Procedure End_Construct_Object
36976>>>>>        Forward Send End_Construct_Object
36978>>>>>        
36978>>>>>        Handle hoCrypto
36978>>>>>        Integer iFieldLen
36978>>>>>        If (pbPasswordHashing(Self)) Begin
36980>>>>>            Get phoCrypto to hoCrypto
36981>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36984>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36986>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36987>>>>>>
36987>>>>>            End
36987>>>>>>
36987>>>>>        End
36987>>>>>>
36987>>>>>    End_Procedure
36988>>>>>    
36988>>>>>    Function CreateSession String sRemoteAddress Returns String
36990>>>>>        String sSessionKey
36990>>>>>        Integer iErr
36990>>>>>        Boolean bLogWebSession
36990>>>>>        Handle hoSessionDD       
36990>>>>>        Get phoSessionDD to hoSessionDD
36991>>>>>        
36991>>>>>        //  Get session key
36991>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36993>>>>>        
36993>>>>>        Get pbLogWebSession to bLogWebSession
36994>>>>>        If not bLogWebSession Begin
36996>>>>>            Function_Return sSessionKey        
36997>>>>>        End
36997>>>>>>
36997>>>>>
36997>>>>>        //  Store session
36997>>>>>        Send Clear of hoSessionDD
36998>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36999>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37000>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37001>>>>>        Get Request_Validate of hoSessionDD to iErr
37002>>>>>        If (iErr) Begin
37004>>>>>            // this should not happen. If it does its a programming error
37004>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37005>>>>>>
37005>>>>>            Function_Return ""
37006>>>>>        End
37006>>>>>>
37006>>>>>        Send Request_Save of hoSessionDD
37007>>>>>        If (Err) Begin
37009>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37009>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37010>>>>>>
37010>>>>>            Function_Return ""
37011>>>>>        End
37011>>>>>>
37011>>>>>       
37011>>>>>        Function_Return sSessionKey        
37012>>>>>    End_Function
37013>>>>>    
37013>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37015>>>>>        DateTime dtLastAccess dtCurrent
37015>>>>>        TimeSpan tsDiff
37015>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37015>>>>>        Boolean bResult bCreatingNewSession
37015>>>>>        Boolean bLogWebSession bLoadWebApp
37015>>>>>        Integer eLoginMode
37015>>>>>        String sTime
37015>>>>>        Handle hoSessionDD hoUserDD       
37015>>>>>        
37015>>>>>        Move False to bLoadWebApp
37016>>>>>        If (num_arguments >= 2) Begin
37018>>>>>            Move bOptLoadWebApp to bLoadWebApp
37019>>>>>        End
37019>>>>>>
37019>>>>>        
37019>>>>>        Get phoSessionDD to hoSessionDD
37020>>>>>        Get phoUserDD to hoUserDD
37021>>>>>        
37021>>>>>        Get pbLogWebSession to bLogWebSession
37022>>>>>        Get peLoginMode to eLoginMode
37023>>>>>        
37023>>>>>        // for this object, you can only disable logging if login completely is disabled
37023>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37025>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37026>>>>>>
37026>>>>>            Function_Return False
37027>>>>>        End
37027>>>>>>
37027>>>>>
37027>>>>>        //  Clear session properties
37027>>>>>        Set psSessionKey to ""
37028>>>>>        Send UpdateSessionProperties True
37029>>>>>        
37029>>>>>        If not bLogWebSession Begin
37031>>>>>            Forward Get ValidateSession sSessionKey to bResult
37033>>>>>            Function_Return bResult
37034>>>>>        End        
37034>>>>>>
37034>>>>>        
37034>>>>>        Move False to bResult
37035>>>>>        Get piSessionTimeout to iSessionTimeout 
37036>>>>>        
37036>>>>>        //  Check if session exists
37036>>>>>        Send Clear of hoSessionDD
37037>>>>>        Move sSessionKey to WebAppSession.SessionKey
37038>>>>>        Send Find of hoSessionDD EQ Index.1
37039>>>>>            
37039>>>>>        If (Found) Begin
37041>>>>>            //  Calculate timespan between now and last access time
37041>>>>>            Move (CurrentDateTime()) to dtCurrent
37042>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37043>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37044>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37045>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37046>>>>>            
37046>>>>>            //  Check if session didn't time out
37046>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37048>>>>>                Forward Get ValidateSession sSessionKey to bResult
37050>>>>>                   
37050>>>>>                If (bResult) Begin
37052>>>>>                    //  Update session record
37052>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37053>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37054>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37055>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37056>>>>>                    Get Request_Validate of hoSessionDD to iErr
37057>>>>>                    If (iErr) Begin
37059>>>>>                        // this should not happen. If it does its a programming error
37059>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37060>>>>>>
37060>>>>>                        Function_Return False
37061>>>>>                    End
37061>>>>>>
37061>>>>>                    Send Request_Save of hoSessionDD
37062>>>>>                    
37062>>>>>                    //  Update user properties
37062>>>>>                    Send UpdateSessionProperties False
37063>>>>>                End
37063>>>>>>
37063>>>>>            End
37063>>>>>>
37063>>>>>            Else Begin
37064>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37064>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37065>>>>>                
37065>>>>>                If (not(bCreatingNewSession)) Begin
37067>>>>>                    If (not(bLoadWebApp)) Begin
37069>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37070>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37071>>>>>>
37071>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37072>>>>>                    End
37072>>>>>>
37072>>>>>                    Else Begin
37073>>>>>                        Set pbCreatingNewSession to True                    
37074>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37075>>>>>                        Set pbCreatingNewSession to False                        
37076>>>>>                    End
37076>>>>>>
37076>>>>>                End
37076>>>>>>
37076>>>>>            End
37076>>>>>>
37076>>>>>        End
37076>>>>>>
37076>>>>>        Else Begin
37077>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37078>>>>>>
37078>>>>>        End
37078>>>>>>
37078>>>>>        
37078>>>>>        Function_Return bResult
37079>>>>>    End_Function
37080>>>>>    
37080>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37082>>>>>        If (not(pbPasswordHashing(Self))) Begin
37084>>>>>            Move sPassword to sHash
37085>>>>>            Function_Return True
37086>>>>>        End
37086>>>>>>
37086>>>>>        
37086>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37088>>>>>            Function_Return False
37089>>>>>        End
37089>>>>>>
37089>>>>>        Move ("V1$" + sHash) to sHash
37090>>>>>        Function_Return True
37091>>>>>    End_Function
37092>>>>>    
37092>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37094>>>>>        If (not(pbPasswordHashing(Self))) Begin
37096>>>>>            Move False to bShouldUpgrade
37097>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37098>>>>>        End
37098>>>>>>
37098>>>>>        
37098>>>>>        String sVersion
37098>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37099>>>>>        If (sVersion = "V1$") Begin
37101>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37104>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37105>>>>>        End
37105>>>>>>
37105>>>>>        Else Begin
37106>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37109>>>>>            Function_Return False
37110>>>>>        End
37110>>>>>>
37110>>>>>    End_Function
37111>>>>>    
37111>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37113>>>>>        Handle hoUserDD
37113>>>>>        Integer iErr
37113>>>>>        Get phoUserDD to hoUserDD
37114>>>>>        
37114>>>>>        //  Find the user
37114>>>>>        Send Clear of hoUserDD
37115>>>>>        Move sLoginName to WebAppUser.LoginName
37116>>>>>        Send Find of hoUserDD EQ Index.1
37117>>>>>        If (Found) Begin
37119>>>>>            Send Clear of hoUserDD
37120>>>>>            Function_Return False
37121>>>>>        End
37121>>>>>>
37121>>>>>        
37121>>>>>        Send Clear of hoUserDD
37122>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37123>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37124>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37126>>>>>            Send Clear of hoUserDD
37127>>>>>            Function_Return False
37128>>>>>        End
37128>>>>>>
37128>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37129>>>>>        Get Request_Validate of hoUserDD to iErr
37130>>>>>        If (iErr) Begin
37132>>>>>            Send Clear of hoUserDD
37133>>>>>            Function_Return False
37134>>>>>        End
37134>>>>>>
37134>>>>>        
37134>>>>>        Send Request_Save of hoUserDD
37135>>>>>        Function_Return (not(Err))
37136>>>>>    End_Function
37137>>>>>    
37137>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37139>>>>>        String sSessionKey sUserPassword
37139>>>>>        Handle hoSessionDD hoUserDD
37139>>>>>        Boolean bMatch bUpgrade
37139>>>>>        
37139>>>>>        Get phoSessionDD to hoSessionDD
37140>>>>>        Get phoUserDD to hoUserDD
37141>>>>>        Integer iErr eLoginMode
37141>>>>>        
37141>>>>>        // Refind session record
37141>>>>>        Get psSessionKey to sSessionKey
37142>>>>>        Send Clear of hoSessionDD
37143>>>>>        Move sSessionKey to WebAppSession.SessionKey
37144>>>>>        Send Find of hoSessionDD EQ Index.1
37145>>>>>        
37145>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37147>>>>>            Get peLoginMode to eLoginMode
37148>>>>>            
37148>>>>>            //  Find the user
37148>>>>>            Move sLoginName to WebAppUser.LoginName
37149>>>>>            Send Find of hoUserDD EQ Index.1
37150>>>>>            
37150>>>>>            // Check username and password
37150>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37152>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37153>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37154>>>>>                
37154>>>>>                If (bMatch) Begin
37156>>>>>                    // Store the login
37156>>>>>                    If (bUpgrade) Begin
37158>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37159>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37162>>>>>                    End
37162>>>>>>
37162>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37163>>>>>                    Get Request_Validate of hoSessionDD to iErr
37164>>>>>                    If (iErr) Begin
37166>>>>>                        // this should not happen. If it does its a programming error
37166>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37167>>>>>>
37167>>>>>                        Function_Return False
37168>>>>>                    End
37168>>>>>>
37168>>>>>                    
37168>>>>>                    Send Request_Save of hoSessionDD
37169>>>>>                    
37169>>>>>                    // Update session properties
37169>>>>>                    Send UpdateSessionProperties False
37170>>>>>                    Send NotifyChangeRights
37171>>>>>                    Function_Return True
37172>>>>>                End
37172>>>>>>
37172>>>>>                Else Begin
37173>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37173>>>>>                    Send Clear of hoUserDD
37174>>>>>                End
37174>>>>>>
37174>>>>>            End
37174>>>>>>
37174>>>>>            Else Begin
37175>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37175>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37176>>>>>            End
37176>>>>>>
37176>>>>>        End
37176>>>>>>
37176>>>>>        Else Begin
37177>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37177>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37178>>>>>        End
37178>>>>>>
37178>>>>>          
37178>>>>>        Function_Return False
37179>>>>>    End_Function
37180>>>>>    
37180>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37182>>>>>        Handle hoUserDD
37182>>>>>        Integer iErr
37182>>>>>        Get phoUserDD to hoUserDD
37183>>>>>        
37183>>>>>        //  Find the user
37183>>>>>        Send Clear of hoUserDD
37184>>>>>        Move sLoginName to WebAppUser.LoginName
37185>>>>>        Send Find of hoUserDD EQ Index.1
37186>>>>>        If (not(Found)) Begin
37188>>>>>            Send Clear of hoUserDD
37189>>>>>            Function_Return False
37190>>>>>        End
37190>>>>>>
37190>>>>>        
37190>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37192>>>>>            Send Clear of hoUserDD
37193>>>>>            Function_Return False
37194>>>>>        End
37194>>>>>>
37194>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37195>>>>>        Get Request_Validate of hoUserDD to iErr
37196>>>>>        If (iErr) Begin
37198>>>>>            Send Clear of hoUserDD
37199>>>>>            Function_Return False
37200>>>>>        End
37200>>>>>>
37200>>>>>        
37200>>>>>        Send Request_Save of hoUserDD
37201>>>>>        Function_Return (not(Err))
37202>>>>>    End_Function
