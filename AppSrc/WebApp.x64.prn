38183>>>    // This can be used to show and hide buttons based on context.
38183>>>    // This can be called any time the view is active.
38183>>>    Procedure SetActionButtons
38186>>>        tWebNavigateData NavigateData
38186>>>        tWebNavigateData NavigateData
38186>>>        Boolean bHasRecord
38186>>>        Handle hoDD
38186>>>
38186>>>        Get Server to hoDD
38187>>>        Get GetNavigateData to NavigateData
38188>>>        
38188>>>        If (hoDD) Begin
38190>>>            Get HasRecord of hoDD to bHasRecord
38191>>>        End
38191>>>>
38191>>>        Else Begin
38192>>>            Move False to bHasRecord
38193>>>        End
38193>>>>
38193>>>
38193>>>        // let's hide all buttons and then show the ones we want
38193>>>        WebSet pbRender of oEditBtn to False 
38194>>>        WebSet pbRender of oSaveBtn to False
38195>>>        WebSet pbRender of oCancelChangesBtn to False
38196>>>        WebSet pbRender of oDeleteBtn to False
38197>>>
38197>>>        If (NavigateData.bReadOnly) Begin 
38199>>>            WebSet pbRender of oEditBtn to True 
38200>>>        End
38200>>>>
38200>>>        Else Begin
38201>>>            WebSet pbRender of oSaveBtn to True
38202>>>            WebSet pbRender of oCancelChangesBtn to True
38203>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38204>>>        End
38204>>>>
38204>>>    End_Procedure
38205>>>
38205>>>    // this will close the view after a save
38205>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38208>>>        Send NavigateClose Self
38209>>>    End_Procedure
38210>>>
38210>>>    // this will close the view after a delete
38210>>>    Procedure OnViewDeleted Handle hoDDO
38213>>>        Send NavigateClose Self
38214>>>    End_Procedure
