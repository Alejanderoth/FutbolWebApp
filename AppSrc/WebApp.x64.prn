36983>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36984>>>>>    
36984>>>>>    Procedure Construct_Object
36986>>>>>        Handle hoObj
36986>>>>>        
36986>>>>>        Forward Send Construct_Object
36988>>>>>        
36988>>>>>        Set pbSessionCookieHttpOnly to True
36989>>>>>        
36989>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36990>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36991>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36992>>>>>        
36992>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36993>>>>>        Set phoUserDD to hoObj
36994>>>>>        
36994>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36995>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36996>>>>>        Set phoSessionDD to hoObj
36997>>>>>        
36997>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36998>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36999>>>>>        Set phoCrypto to hoObj
37000>>>>>        
37000>>>>>        Property Boolean pbPasswordHashing True
37001>>>>>        
37001>>>>>        Property Boolean pbCreatingNewSession False
37002>>>>>        Property String psLoginName
37003>>>>>        Property String psUserName ""
37004>>>>>        Property Integer piUserRights 0
37005>>>>>    End_Procedure
37006>>>>>    
37006>>>>>    Procedure End_Construct_Object
37008>>>>>        Forward Send End_Construct_Object
37010>>>>>        
37010>>>>>        Handle hoCrypto
37010>>>>>        Integer iFieldLen
37010>>>>>        If (pbPasswordHashing(Self)) Begin
37012>>>>>            Get phoCrypto to hoCrypto
37013>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
37016>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
37018>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
37019>>>>>>
37019>>>>>            End
37019>>>>>>
37019>>>>>        End
37019>>>>>>
37019>>>>>    End_Procedure
37020>>>>>    
37020>>>>>    Function CreateSession String sRemoteAddress Returns String
37022>>>>>        String sSessionKey
37022>>>>>        Integer iErr
37022>>>>>        Boolean bLogWebSession
37022>>>>>        Handle hoSessionDD       
37022>>>>>        Get phoSessionDD to hoSessionDD
37023>>>>>        
37023>>>>>        //  Get session key
37023>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37025>>>>>        
37025>>>>>        Get pbLogWebSession to bLogWebSession
37026>>>>>        If not bLogWebSession Begin
37028>>>>>            Function_Return sSessionKey        
37029>>>>>        End
37029>>>>>>
37029>>>>>
37029>>>>>        //  Store session
37029>>>>>        Send Clear of hoSessionDD
37030>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37031>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37032>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37033>>>>>        Get Request_Validate of hoSessionDD to iErr
37034>>>>>        If (iErr) Begin
37036>>>>>            // this should not happen. If it does its a programming error
37036>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37037>>>>>>
37037>>>>>            Function_Return ""
37038>>>>>        End
37038>>>>>>
37038>>>>>        Send Request_Save of hoSessionDD
37039>>>>>        If (Err) Begin
37041>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37041>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37042>>>>>>
37042>>>>>            Function_Return ""
37043>>>>>        End
37043>>>>>>
37043>>>>>       
37043>>>>>        Function_Return sSessionKey        
37044>>>>>    End_Function
37045>>>>>    
37045>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37047>>>>>        DateTime dtLastAccess dtCurrent
37047>>>>>        TimeSpan tsDiff
37047>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37047>>>>>        Boolean bResult bCreatingNewSession
37047>>>>>        Boolean bLogWebSession bLoadWebApp
37047>>>>>        Integer eLoginMode
37047>>>>>        String sTime
37047>>>>>        Handle hoSessionDD hoUserDD       
37047>>>>>        
37047>>>>>        Move False to bLoadWebApp
37048>>>>>        If (num_arguments >= 2) Begin
37050>>>>>            Move bOptLoadWebApp to bLoadWebApp
37051>>>>>        End
37051>>>>>>
37051>>>>>        
37051>>>>>        Get phoSessionDD to hoSessionDD
37052>>>>>        Get phoUserDD to hoUserDD
37053>>>>>        
37053>>>>>        Get pbLogWebSession to bLogWebSession
37054>>>>>        Get peLoginMode to eLoginMode
37055>>>>>        
37055>>>>>        // for this object, you can only disable logging if login completely is disabled
37055>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37057>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37058>>>>>>
37058>>>>>            Function_Return False
37059>>>>>        End
37059>>>>>>
37059>>>>>
37059>>>>>        //  Clear session properties
37059>>>>>        Set psSessionKey to ""
37060>>>>>        Send UpdateSessionProperties True
37061>>>>>        
37061>>>>>        If not bLogWebSession Begin
37063>>>>>            Forward Get ValidateSession sSessionKey to bResult
37065>>>>>            Function_Return bResult
37066>>>>>        End        
37066>>>>>>
37066>>>>>        
37066>>>>>        Move False to bResult
37067>>>>>        Get piSessionTimeout to iSessionTimeout 
37068>>>>>        
37068>>>>>        //  Check if session exists
37068>>>>>        Send Clear of hoSessionDD
37069>>>>>        Move sSessionKey to WebAppSession.SessionKey
37070>>>>>        Send Find of hoSessionDD EQ Index.1
37071>>>>>            
37071>>>>>        If (Found) Begin
37073>>>>>            //  Calculate timespan between now and last access time
37073>>>>>            Move (CurrentDateTime()) to dtCurrent
37074>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37075>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37076>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37077>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37078>>>>>            
37078>>>>>            //  Check if session didn't time out
37078>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37080>>>>>                Forward Get ValidateSession sSessionKey to bResult
37082>>>>>                   
37082>>>>>                If (bResult) Begin
37084>>>>>                    //  Update session record
37084>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37085>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37086>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37087>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37088>>>>>                    Get Request_Validate of hoSessionDD to iErr
37089>>>>>                    If (iErr) Begin
37091>>>>>                        // this should not happen. If it does its a programming error
37091>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37092>>>>>>
37092>>>>>                        Function_Return False
37093>>>>>                    End
37093>>>>>>
37093>>>>>                    Send Request_Save of hoSessionDD
37094>>>>>                    
37094>>>>>                    //  Update user properties
37094>>>>>                    Send UpdateSessionProperties False
37095>>>>>                End
37095>>>>>>
37095>>>>>            End
37095>>>>>>
37095>>>>>            Else Begin
37096>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37096>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37097>>>>>                
37097>>>>>                If (not(bCreatingNewSession)) Begin
37099>>>>>                    If (not(bLoadWebApp)) Begin
37101>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37102>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37103>>>>>>
37103>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37104>>>>>                    End
37104>>>>>>
37104>>>>>                    Else Begin
37105>>>>>                        Set pbCreatingNewSession to True                    
37106>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37107>>>>>                        Set pbCreatingNewSession to False                        
37108>>>>>                    End
37108>>>>>>
37108>>>>>                End
37108>>>>>>
37108>>>>>            End
37108>>>>>>
37108>>>>>        End
37108>>>>>>
37108>>>>>        Else Begin
37109>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37110>>>>>>
37110>>>>>        End
37110>>>>>>
37110>>>>>        
37110>>>>>        Function_Return bResult
37111>>>>>    End_Function
37112>>>>>    
37112>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37114>>>>>        If (not(pbPasswordHashing(Self))) Begin
37116>>>>>            Move sPassword to sHash
37117>>>>>            Function_Return True
37118>>>>>        End
37118>>>>>>
37118>>>>>        
37118>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37120>>>>>            Function_Return False
37121>>>>>        End
37121>>>>>>
37121>>>>>        Move ("V1$" + sHash) to sHash
37122>>>>>        Function_Return True
37123>>>>>    End_Function
37124>>>>>    
37124>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37126>>>>>        If (not(pbPasswordHashing(Self))) Begin
37128>>>>>            Move False to bShouldUpgrade
37129>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37130>>>>>        End
37130>>>>>>
37130>>>>>        
37130>>>>>        String sVersion
37130>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37131>>>>>        If (sVersion = "V1$") Begin
37133>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37136>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37137>>>>>        End
37137>>>>>>
37137>>>>>        Else Begin
37138>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37141>>>>>            Function_Return False
37142>>>>>        End
37142>>>>>>
37142>>>>>    End_Function
37143>>>>>    
37143>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37145>>>>>        Handle hoUserDD
37145>>>>>        Integer iErr
37145>>>>>        Get phoUserDD to hoUserDD
37146>>>>>        
37146>>>>>        //  Find the user
37146>>>>>        Send Clear of hoUserDD
37147>>>>>        Move sLoginName to WebAppUser.LoginName
37148>>>>>        Send Find of hoUserDD EQ Index.1
37149>>>>>        If (Found) Begin
37151>>>>>            Send Clear of hoUserDD
37152>>>>>            Function_Return False
37153>>>>>        End
37153>>>>>>
37153>>>>>        
37153>>>>>        Send Clear of hoUserDD
37154>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37155>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37156>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37158>>>>>            Send Clear of hoUserDD
37159>>>>>            Function_Return False
37160>>>>>        End
37160>>>>>>
37160>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37161>>>>>        Get Request_Validate of hoUserDD to iErr
37162>>>>>        If (iErr) Begin
37164>>>>>            Send Clear of hoUserDD
37165>>>>>            Function_Return False
37166>>>>>        End
37166>>>>>>
37166>>>>>        
37166>>>>>        Send Request_Save of hoUserDD
37167>>>>>        Function_Return (not(Err))
37168>>>>>    End_Function
37169>>>>>    
37169>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37171>>>>>        String sSessionKey sUserPassword
37171>>>>>        Handle hoSessionDD hoUserDD
37171>>>>>        Boolean bMatch bUpgrade
37171>>>>>        
37171>>>>>        Get phoSessionDD to hoSessionDD
37172>>>>>        Get phoUserDD to hoUserDD
37173>>>>>        Integer iErr eLoginMode
37173>>>>>        
37173>>>>>        // Refind session record
37173>>>>>        Get psSessionKey to sSessionKey
37174>>>>>        Send Clear of hoSessionDD
37175>>>>>        Move sSessionKey to WebAppSession.SessionKey
37176>>>>>        Send Find of hoSessionDD EQ Index.1
37177>>>>>        
37177>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37179>>>>>            Get peLoginMode to eLoginMode
37180>>>>>            
37180>>>>>            //  Find the user
37180>>>>>            Move sLoginName to WebAppUser.LoginName
37181>>>>>            Send Find of hoUserDD EQ Index.1
37182>>>>>            
37182>>>>>            // Check username and password
37182>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37184>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37185>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37186>>>>>                
37186>>>>>                If (bMatch) Begin
37188>>>>>                    // Store the login
37188>>>>>                    If (bUpgrade) Begin
37190>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37191>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37194>>>>>                    End
37194>>>>>>
37194>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37195>>>>>                    Get Request_Validate of hoSessionDD to iErr
37196>>>>>                    If (iErr) Begin
37198>>>>>                        // this should not happen. If it does its a programming error
37198>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37199>>>>>>
37199>>>>>                        Function_Return False
37200>>>>>                    End
37200>>>>>>
37200>>>>>                    
37200>>>>>                    Send Request_Save of hoSessionDD
37201>>>>>                    
37201>>>>>                    // Update session properties
37201>>>>>                    Send UpdateSessionProperties False
37202>>>>>                    Send NotifyChangeRights
37203>>>>>                    Function_Return True
37204>>>>>                End
37204>>>>>>
37204>>>>>                Else Begin
37205>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37205>>>>>                    Send Clear of hoUserDD
37206>>>>>                End
37206>>>>>>
37206>>>>>            End
37206>>>>>>
37206>>>>>            Else Begin
37207>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37207>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37208>>>>>            End
37208>>>>>>
37208>>>>>        End
37208>>>>>>
37208>>>>>        Else Begin
37209>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37209>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37210>>>>>        End
37210>>>>>>
37210>>>>>          
37210>>>>>        Function_Return False
37211>>>>>    End_Function
37212>>>>>    
37212>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37214>>>>>        Handle hoUserDD
37214>>>>>        Integer iErr
37214>>>>>        Get phoUserDD to hoUserDD
37215>>>>>        
37215>>>>>        //  Find the user
37215>>>>>        Send Clear of hoUserDD
37216>>>>>        Move sLoginName to WebAppUser.LoginName
37217>>>>>        Send Find of hoUserDD EQ Index.1
37218>>>>>        If (not(Found)) Begin
37220>>>>>            Send Clear of hoUserDD
37221>>>>>            Function_Return False
37222>>>>>        End
37222>>>>>>
37222>>>>>        
37222>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37224>>>>>            Send Clear of hoUserDD
37225>>>>>            Function_Return False
37226>>>>>        End
37226>>>>>>
37226>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37227>>>>>        Get Request_Validate of hoUserDD to iErr
37228>>>>>        If (iErr) Begin
37230>>>>>            Send Clear of hoUserDD
37231>>>>>            Function_Return False
37232>>>>>        End
37232>>>>>>
37232>>>>>        
37232>>>>>        Send Request_Save of hoUserDD
37233>>>>>        Function_Return (not(Err))
37234>>>>>    End_Function
