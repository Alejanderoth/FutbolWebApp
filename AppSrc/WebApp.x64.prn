36590>>>>>>>    //
36590>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36590>>>>>>>    //
36590>>>>>>>    //  Params:
36590>>>>>>>    //      dtTime  Time to convert
36590>>>>>>>    //  Returns:
36590>>>>>>>    //      String with "HH:MM:SS" format
36590>>>>>>>    //
36590>>>>>>>    Function TimeToString DateTime dtTime Returns String
36592>>>>>>>        String sHours sMinutes sSeconds
36592>>>>>>>        
36592>>>>>>>        //  Extract parts
36592>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36593>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36594>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36595>>>>>>>        
36595>>>>>>>        //  Fill out with 0
36595>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36598>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36601>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36604>>>>>>>        
36604>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36605>>>>>>>    End_Function
36606>>>>>>>    
36606>>>>>>>    //
36606>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36606>>>>>>>    //
36606>>>>>>>    //  Params:
36606>>>>>>>    //      dtTime  Datetime variable to add time to
36606>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36606>>>>>>>    //  Returns:
