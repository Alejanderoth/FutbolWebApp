37808>>>    // This can be used to show and hide buttons based on context.
37808>>>    // This can be called any time the view is active.
37808>>>    Procedure SetActionButtons
37811>>>        tWebNavigateData NavigateData
37811>>>        tWebNavigateData NavigateData
37811>>>        Boolean bHasRecord
37811>>>        Handle hoDD
37811>>>
37811>>>        Get Server to hoDD
37812>>>        Get GetNavigateData to NavigateData
37813>>>        
37813>>>        If (hoDD) Begin
37815>>>            Get HasRecord of hoDD to bHasRecord
37816>>>        End
37816>>>>
37816>>>        Else Begin
37817>>>            Move False to bHasRecord
37818>>>        End
37818>>>>
37818>>>
37818>>>        // let's hide all buttons and then show the ones we want
37818>>>        WebSet pbRender of oEditBtn to False 
37819>>>        WebSet pbRender of oSaveBtn to False
37820>>>        WebSet pbRender of oCancelChangesBtn to False
37821>>>        WebSet pbRender of oDeleteBtn to False
37822>>>
37822>>>        If (NavigateData.bReadOnly) Begin 
37824>>>            WebSet pbRender of oEditBtn to True 
37825>>>        End
37825>>>>
37825>>>        Else Begin
37826>>>            WebSet pbRender of oSaveBtn to True
37827>>>            WebSet pbRender of oCancelChangesBtn to True
37828>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37829>>>        End
37829>>>>
37829>>>    End_Procedure
