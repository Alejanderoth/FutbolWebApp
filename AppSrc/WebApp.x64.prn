36745>>>>>>>        End
36745>>>>>>>>
36745>>>>>>>        Move (PointerToString(pBase64)) to sBase64
36746>>>>>>>        Move (Free(pBase64)) to iErr
36747>>>>>>>        Function_Return sBase64
36748>>>>>>>    End_Function
36749>>>>>>>    
36749>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36751>>>>>>>        Integer iLen
36751>>>>>>>        Pointer pBase64
36751>>>>>>>        UChar[] ucaBuffer
36752>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36753>>>>>>>        If (not(pBase64)) Begin
36755>>>>>>>            Function_Return ucaBuffer
36756>>>>>>>        End
36756>>>>>>>>
36756>>>>>>>        
36756>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36757>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36758>>>>>>>        Move (Free(pBase64)) to iLen
36759>>>>>>>        Function_Return ucaBuffer
36760>>>>>>>    End_Function
36761>>>>>>>    
36761>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36763>>>>>>>        Boolean bOk bRequireTimeCost
36763>>>>>>>        UChar[] ucaHash
36764>>>>>>>        
36764>>>>>>>        Case Begin
36764>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36766>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36767>>>>>>>                If (not(bOk)) Function_Return False
36770>>>>>>>                
36770>>>>>>>                Move True to bRequireTimeCost
36771>>>>>>>                Case Break
36772>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36775>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36776>>>>>>>                If (not(bOk)) Function_Return False
36779>>>>>>>                
36779>>>>>>>                Move True to bRequireTimeCost
36780>>>>>>>                Case Break
36781>>>>>>>            Case Else
36781>>>>>>>                Error 8710 "Invalid algorithm selected."
36782>>>>>>>>
36782>>>>>>>                Function_Return False
36783>>>>>>>        Case End
36783>>>>>>>        
36783>>>>>>>        String sSalt
36783>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36784>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36787>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36788>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36791>>>>>>>        
36791>>>>>>>        If (bRequireTimeCost) Begin
36793>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36794>>>>>>>        End
36794>>>>>>>>
36794>>>>>>>        Else Begin
36795>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36796>>>>>>>        End
36796>>>>>>>>
36796>>>>>>>        
36796>>>>>>>        Function_Return bOk
36797>>>>>>>    End_Function
36798>>>>>>>    
36798>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36800>>>>>>>        UChar[] ucaSalt
36801>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36802>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36805>>>>>>>        
36805>>>>>>>        If (num_arguments > 4) Begin
36807>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36808>>>>>>>        End
36808>>>>>>>>
36808>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36809>>>>>>>    End_Function
36810>>>>>>>    
36810>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36812>>>>>>>        Boolean bRequiresTimeCost
36812>>>>>>>        UInteger uiAlgo uiTimeCost
36812>>>>>>>        Integer iBegin iEnd
36812>>>>>>>        String sSalt
36812>>>>>>>        
36812>>>>>>>        Move 1 to iBegin
36813>>>>>>>        
36813>>>>>>>        // Parse Algo
36813>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36814>>>>>>>        If (not(iEnd)) Function_Return False
36817>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36818>>>>>>>        
36818>>>>>>>        // Parse Salt
36818>>>>>>>        Move (iEnd + 1) to iBegin
36819>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36820>>>>>>>        If (not(iEnd)) Function_Return False
36823>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36824>>>>>>>        
36824>>>>>>>        Case Begin
36824>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36826>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36829>>>>>>>                Move True to bRequiresTimeCost
36830>>>>>>>                Case Break
36831>>>>>>>            Case Else
36831>>>>>>>                Error 8710 "Invalid algorithm selected."
36832>>>>>>>>
36832>>>>>>>                Function_Return False
36833>>>>>>>        Case End
36833>>>>>>>        
36833>>>>>>>        // Parse optional timecost
36833>>>>>>>        If (bRequiresTimeCost) Begin
36835>>>>>>>            Move (iEnd + 1) to iBegin
36836>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36837>>>>>>>            If (not(iEnd)) Function_Return False
36840>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36841>>>>>>>        End
36841>>>>>>>>
36841>>>>>>>        
36841>>>>>>>        // Parse rest hash
36841>>>>>>>        Move (iEnd + 1) to iBegin
36842>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36843>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36846>>>>>>>        
36846>>>>>>>        // Base64Decode
36846>>>>>>>        UChar[] ucaSalt
36847>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36848>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36851>>>>>>>        
36851>>>>>>>        // Create new hash
36851>>>>>>>        String sNewHash
36851>>>>>>>        If (bRequiresTimeCost) Begin
36853>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36855>>>>>>>                Function_Return False 
36856>>>>>>>            End
36856>>>>>>>>
36856>>>>>>>        End
36856>>>>>>>>
36856>>>>>>>        Else Begin
36857>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36859>>>>>>>                Function_Return False 
36860>>>>>>>            End
36860>>>>>>>>
36860>>>>>>>        End
36860>>>>>>>>
36860>>>>>>>        Function_Return (sNewHash = sHash)
36861>>>>>>>    End_Function
36862>>>>>>>    
36862>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36864>>>>>>>        Boolean bRequireTimeCost
36864>>>>>>>        UBigInt ullSize
36864>>>>>>>        UChar[] ucaSalt
36865>>>>>>>        String sSalt
36865>>>>>>>        
36865>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36866>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36867>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36870>>>>>>>        
36870>>>>>>>        Case Begin
36870>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36872>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36873>>>>>>>                Move True to bRequireTimeCost
36874>>>>>>>                Case Break
36875>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36878>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36879>>>>>>>                Move True to bRequireTimeCost
36880>>>>>>>                Case Break
36881>>>>>>>            Case Else
36881>>>>>>>                Error 8710 "Invalid algorithm selected."
36882>>>>>>>>
36882>>>>>>>                Function_Return 0
36883>>>>>>>        Case End
36883>>>>>>>        
36883>>>>>>>        // calculate base64 in a non-floating-manner
36883>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36884>>>>>>>        
36884>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36885>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36886>>>>>>>        If (bRequireTimeCost) Begin
36888>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36889>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36890>>>>>>>        End
36890>>>>>>>>
36890>>>>>>>        Else Begin
36891>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36892>>>>>>>        End
36892>>>>>>>>
36892>>>>>>>        
36892>>>>>>>        Function_Return ullSize
36893>>>>>>>    End_Function
36894>>>>>>>End_Class
36895>>>>>>>
36895>>>>>>>Class cPasswordHasher is a cObject
36896>>>>>>>    
36896>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36897>>>>>>>    
36897>>>>>>>    Procedure Construct_Object
36899>>>>>>>        Forward Send Construct_Object
36901>>>>>>>        
36901>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36902>>>>>>>        Property UInteger   puiSaltSize         16
36903>>>>>>>        
36903>>>>>>>        Property UInteger   puiOptTimeCost      420000
36904>>>>>>>    End_Procedure
36905>>>>>>>    
36905>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36907>>>>>>>        Boolean bOk
36907>>>>>>>        UInteger uiAlgo
36907>>>>>>>        Get peAlgorithm to uiAlgo
36908>>>>>>>        
36908>>>>>>>        Case Begin
36908>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36910>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36913>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36914>>>>>>>                Case Break
36915>>>>>>>            Case Else
36915>>>>>>>                Error 8710 "Invalid algorithm selected."
36916>>>>>>>>
36916>>>>>>>                Function_Return False
36917>>>>>>>        Case End
36917>>>>>>>        
36917>>>>>>>        Function_Return bOk
36918>>>>>>>    End_Function
36919>>>>>>>    
36919>>>>>>>    Function RequiredBufferSize Returns UBigInt
36921>>>>>>>        UBigInt ullSize
36921>>>>>>>        UInteger uiAlgo
36921>>>>>>>        Get peAlgorithm to uiAlgo
36922>>>>>>>        
36922>>>>>>>        Case Begin
36922>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36924>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36927>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36928>>>>>>>                Case Break
36929>>>>>>>            Case Else
36929>>>>>>>                Error 8710 "Invalid algorithm selected."
36930>>>>>>>>
36930>>>>>>>                Function_Return 0
36931>>>>>>>        Case End
36931>>>>>>>        
36931>>>>>>>        Function_Return ullSize
36932>>>>>>>    End_Function
36933>>>>>>>
36933>>>>>>>End_Class
