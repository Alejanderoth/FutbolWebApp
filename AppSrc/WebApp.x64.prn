36746>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36748>>>>>>>        Boolean bOk bRequireTimeCost
36748>>>>>>>        UChar[] ucaHash
36749>>>>>>>        
36749>>>>>>>        Case Begin
36749>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36751>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36752>>>>>>>                If (not(bOk)) Function_Return False
36755>>>>>>>                
36755>>>>>>>                Move True to bRequireTimeCost
36756>>>>>>>                Case Break
36757>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36760>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36761>>>>>>>                If (not(bOk)) Function_Return False
36764>>>>>>>                
36764>>>>>>>                Move True to bRequireTimeCost
36765>>>>>>>                Case Break
36766>>>>>>>            Case Else
36766>>>>>>>                Error 8710 "Invalid algorithm selected."
36767>>>>>>>>
36767>>>>>>>                Function_Return False
36768>>>>>>>        Case End
36768>>>>>>>        
36768>>>>>>>        String sSalt
36768>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36769>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36772>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36773>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36776>>>>>>>        
36776>>>>>>>        If (bRequireTimeCost) Begin
36778>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36779>>>>>>>        End
36779>>>>>>>>
36779>>>>>>>        Else Begin
36780>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36781>>>>>>>        End
36781>>>>>>>>
36781>>>>>>>        
36781>>>>>>>        Function_Return bOk
36782>>>>>>>    End_Function
36783>>>>>>>    
36783>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36785>>>>>>>        UChar[] ucaSalt
36786>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36787>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36790>>>>>>>        
36790>>>>>>>        If (num_arguments > 4) Begin
36792>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36793>>>>>>>        End
36793>>>>>>>>
36793>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36794>>>>>>>    End_Function
36795>>>>>>>    
36795>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36797>>>>>>>        Boolean bRequiresTimeCost
36797>>>>>>>        UInteger uiAlgo uiTimeCost
36797>>>>>>>        Integer iBegin iEnd
36797>>>>>>>        String sSalt
36797>>>>>>>        
36797>>>>>>>        Move 1 to iBegin
36798>>>>>>>        
36798>>>>>>>        // Parse Algo
36798>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36799>>>>>>>        If (not(iEnd)) Function_Return False
36802>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36803>>>>>>>        
36803>>>>>>>        // Parse Salt
36803>>>>>>>        Move (iEnd + 1) to iBegin
36804>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36805>>>>>>>        If (not(iEnd)) Function_Return False
36808>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36809>>>>>>>        
36809>>>>>>>        Case Begin
36809>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36811>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36814>>>>>>>                Move True to bRequiresTimeCost
36815>>>>>>>                Case Break
36816>>>>>>>            Case Else
36816>>>>>>>                Error 8710 "Invalid algorithm selected."
36817>>>>>>>>
36817>>>>>>>                Function_Return False
36818>>>>>>>        Case End
36818>>>>>>>        
36818>>>>>>>        // Parse optional timecost
36818>>>>>>>        If (bRequiresTimeCost) Begin
36820>>>>>>>            Move (iEnd + 1) to iBegin
36821>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36822>>>>>>>            If (not(iEnd)) Function_Return False
36825>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36826>>>>>>>        End
36826>>>>>>>>
36826>>>>>>>        
36826>>>>>>>        // Parse rest hash
36826>>>>>>>        Move (iEnd + 1) to iBegin
36827>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36828>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36831>>>>>>>        
36831>>>>>>>        // Base64Decode
36831>>>>>>>        UChar[] ucaSalt
36832>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36833>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36836>>>>>>>        
36836>>>>>>>        // Create new hash
36836>>>>>>>        String sNewHash
36836>>>>>>>        If (bRequiresTimeCost) Begin
36838>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36840>>>>>>>                Function_Return False 
36841>>>>>>>            End
36841>>>>>>>>
36841>>>>>>>        End
36841>>>>>>>>
36841>>>>>>>        Else Begin
36842>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36844>>>>>>>                Function_Return False 
36845>>>>>>>            End
36845>>>>>>>>
36845>>>>>>>        End
36845>>>>>>>>
36845>>>>>>>        Function_Return (sNewHash = sHash)
36846>>>>>>>    End_Function
36847>>>>>>>    
36847>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36849>>>>>>>        Boolean bRequireTimeCost
36849>>>>>>>        UBigInt ullSize
36849>>>>>>>        UChar[] ucaSalt
36850>>>>>>>        String sSalt
36850>>>>>>>        
36850>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36851>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36852>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36855>>>>>>>        
36855>>>>>>>        Case Begin
36855>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36857>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36858>>>>>>>                Move True to bRequireTimeCost
36859>>>>>>>                Case Break
36860>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36863>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36864>>>>>>>                Move True to bRequireTimeCost
36865>>>>>>>                Case Break
36866>>>>>>>            Case Else
36866>>>>>>>                Error 8710 "Invalid algorithm selected."
36867>>>>>>>>
36867>>>>>>>                Function_Return 0
36868>>>>>>>        Case End
36868>>>>>>>        
36868>>>>>>>        // calculate base64 in a non-floating-manner
36868>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36869>>>>>>>        
36869>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36870>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36871>>>>>>>        If (bRequireTimeCost) Begin
36873>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36874>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36875>>>>>>>        End
36875>>>>>>>>
36875>>>>>>>        Else Begin
36876>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36877>>>>>>>        End
36877>>>>>>>>
36877>>>>>>>        
36877>>>>>>>        Function_Return ullSize
36878>>>>>>>    End_Function
36879>>>>>>>End_Class
36880>>>>>>>
36880>>>>>>>Class cPasswordHasher is a cObject
36881>>>>>>>    
36881>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36882>>>>>>>    
36882>>>>>>>    Procedure Construct_Object
36884>>>>>>>        Forward Send Construct_Object
36886>>>>>>>        
36886>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36887>>>>>>>        Property UInteger   puiSaltSize         16
36888>>>>>>>        
36888>>>>>>>        Property UInteger   puiOptTimeCost      420000
36889>>>>>>>    End_Procedure
36890>>>>>>>    
36890>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36892>>>>>>>        Boolean bOk
36892>>>>>>>        UInteger uiAlgo
36892>>>>>>>        Get peAlgorithm to uiAlgo
36893>>>>>>>        
36893>>>>>>>        Case Begin
36893>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36895>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36898>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36899>>>>>>>                Case Break
36900>>>>>>>            Case Else
36900>>>>>>>                Error 8710 "Invalid algorithm selected."
36901>>>>>>>>
36901>>>>>>>                Function_Return False
36902>>>>>>>        Case End
36902>>>>>>>        
36902>>>>>>>        Function_Return bOk
36903>>>>>>>    End_Function
36904>>>>>>>    
36904>>>>>>>    Function RequiredBufferSize Returns UBigInt
36906>>>>>>>        UBigInt ullSize
36906>>>>>>>        UInteger uiAlgo
36906>>>>>>>        Get peAlgorithm to uiAlgo
36907>>>>>>>        
36907>>>>>>>        Case Begin
36907>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36909>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36912>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36913>>>>>>>                Case Break
36914>>>>>>>            Case Else
36914>>>>>>>                Error 8710 "Invalid algorithm selected."
36915>>>>>>>>
36915>>>>>>>                Function_Return 0
36916>>>>>>>        Case End
36916>>>>>>>        
36916>>>>>>>        Function_Return ullSize
36917>>>>>>>    End_Function
36918>>>>>>>
36918>>>>>>>End_Class
