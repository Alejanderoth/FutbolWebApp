36558>>>>>>>    //
36558>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36558>>>>>>>    //
36558>>>>>>>    //  Params:
36558>>>>>>>    //      dtTime  Time to convert
36558>>>>>>>    //  Returns:
36558>>>>>>>    //      String with "HH:MM:SS" format
36558>>>>>>>    //
36558>>>>>>>    Function TimeToString DateTime dtTime Returns String
36560>>>>>>>        String sHours sMinutes sSeconds
36560>>>>>>>        
36560>>>>>>>        //  Extract parts
36560>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36561>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36562>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36563>>>>>>>        
36563>>>>>>>        //  Fill out with 0
36563>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36566>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36569>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36572>>>>>>>        
36572>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36573>>>>>>>    End_Function
36574>>>>>>>    
36574>>>>>>>    //
36574>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36574>>>>>>>    //
36574>>>>>>>    //  Params:
36574>>>>>>>    //      dtTime  Datetime variable to add time to
36574>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36574>>>>>>>    //  Returns:
36574>>>>>>>    //      dtDateTime with the loaded time
36574>>>>>>>    //
36574>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36576>>>>>>>        String sHours sMinutes sSeconds
36576>>>>>>>        
36576>>>>>>>        //  Extract parts
36576>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36577>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36578>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36579>>>>>>>        
36579>>>>>>>        //  Set to DateTime
36579>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36580>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36581>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36582>>>>>>>        
36582>>>>>>>        Function_Return dtTime
36583>>>>>>>    End_Function
