37575>>>    // This can be used to show and hide buttons based on context.
37575>>>    // This can be called any time the view is active.
37575>>>    Procedure SetActionButtons
37578>>>        tWebNavigateData NavigateData
37578>>>        tWebNavigateData NavigateData
37578>>>        Boolean bHasRecord
37578>>>        Handle hoDD
37578>>>
37578>>>        Get Server to hoDD
37579>>>        Get GetNavigateData to NavigateData
37580>>>        
37580>>>        If (hoDD) Begin
37582>>>            Get HasRecord of hoDD to bHasRecord
37583>>>        End
37583>>>>
37583>>>        Else Begin
37584>>>            Move False to bHasRecord
37585>>>        End
37585>>>>
37585>>>
37585>>>        // let's hide all buttons and then show the ones we want
37585>>>        WebSet pbRender of oEditBtn to False 
37586>>>        WebSet pbRender of oSaveBtn to False
37587>>>        WebSet pbRender of oCancelChangesBtn to False
37588>>>        WebSet pbRender of oDeleteBtn to False
37589>>>
37589>>>        If (NavigateData.bReadOnly) Begin 
37591>>>            WebSet pbRender of oEditBtn to True 
37592>>>        End
37592>>>>
37592>>>        Else Begin
37593>>>            WebSet pbRender of oSaveBtn to True
37594>>>            WebSet pbRender of oCancelChangesBtn to True
37595>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37596>>>        End
37596>>>>
37596>>>    End_Procedure
