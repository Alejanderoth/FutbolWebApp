37909>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37912>>>        Send NavigateClose Self
37913>>>    End_Procedure
37914>>>
37914>>>    // this will close the view after a delete
37914>>>    Procedure OnViewDeleted Handle hoDDO
37917>>>        Send NavigateClose Self
37918>>>    End_Procedure
