38278>>>        // What to do when the row is selected.
38278>>>        //
38278>>>        // Depending on how you are using this view, you may wish to
38278>>>        // 1. Close the view, which will update the invoking view:
38278>>>        //      Send NavigateClose Self
38278>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
38278>>>        //      Send NavigateForward of oZoomMainView Self
38278>>>        //      Send NavigateForward of oSelectChildView Self
38278>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
38278>>>        Procedure OnRowClick String sRowID
38281>>>
38281>>>            // If this view is being used in multiple contexts, you may need a block of code
38281>>>            // like this to handle different types of navigation
38281>>>            tWebNavigateData NavigateData
38281>>>            tWebNavigateData NavigateData
38281>>>            Get GetNavigateData to NavigateData
38282>>>            Case Begin
38282>>>                Case (NavigateData.eNavigateType=nfFromParent)
38284>>>                    // If from parent, this is a constrained drilldown.
38284>>>                    // If here, you probably want to Zoom this record or continue to drilldown
38284>>>                    //   (See 2 above). 
38284>>>                    Case Break
38285>>>                Case (NavigateData.eNavigateType=nfFromChild)
38288>>>                    // If from child, this is a probably a parent lookup from a Zoom,
38288>>>                    // so you just want to close (See 1 above)
38288>>>                    Send NavigateClose Self
38289>>>                    Case Break
38290>>>                Case (NavigateData.eNavigateType=nfFromMain)
