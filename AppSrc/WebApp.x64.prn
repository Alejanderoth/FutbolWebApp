36810>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36812>>>>>>>        Boolean bOk bRequireTimeCost
36812>>>>>>>        UChar[] ucaHash
36813>>>>>>>        
36813>>>>>>>        Case Begin
36813>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36815>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36816>>>>>>>                If (not(bOk)) Function_Return False
36819>>>>>>>                
36819>>>>>>>                Move True to bRequireTimeCost
36820>>>>>>>                Case Break
36821>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36824>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36825>>>>>>>                If (not(bOk)) Function_Return False
36828>>>>>>>                
36828>>>>>>>                Move True to bRequireTimeCost
36829>>>>>>>                Case Break
36830>>>>>>>            Case Else
36830>>>>>>>                Error 8710 "Invalid algorithm selected."
36831>>>>>>>>
36831>>>>>>>                Function_Return False
36832>>>>>>>        Case End
36832>>>>>>>        
36832>>>>>>>        String sSalt
36832>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36833>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36836>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36837>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36840>>>>>>>        
36840>>>>>>>        If (bRequireTimeCost) Begin
36842>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36843>>>>>>>        End
36843>>>>>>>>
36843>>>>>>>        Else Begin
36844>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36845>>>>>>>        End
36845>>>>>>>>
36845>>>>>>>        
36845>>>>>>>        Function_Return bOk
36846>>>>>>>    End_Function
36847>>>>>>>    
36847>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36849>>>>>>>        UChar[] ucaSalt
36850>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36851>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36854>>>>>>>        
36854>>>>>>>        If (num_arguments > 4) Begin
36856>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36857>>>>>>>        End
36857>>>>>>>>
36857>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36858>>>>>>>    End_Function
36859>>>>>>>    
36859>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36861>>>>>>>        Boolean bRequiresTimeCost
36861>>>>>>>        UInteger uiAlgo uiTimeCost
36861>>>>>>>        Integer iBegin iEnd
36861>>>>>>>        String sSalt
36861>>>>>>>        
36861>>>>>>>        Move 1 to iBegin
36862>>>>>>>        
36862>>>>>>>        // Parse Algo
36862>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36863>>>>>>>        If (not(iEnd)) Function_Return False
36866>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36867>>>>>>>        
36867>>>>>>>        // Parse Salt
36867>>>>>>>        Move (iEnd + 1) to iBegin
36868>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36869>>>>>>>        If (not(iEnd)) Function_Return False
36872>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36873>>>>>>>        
36873>>>>>>>        Case Begin
36873>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36875>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36878>>>>>>>                Move True to bRequiresTimeCost
36879>>>>>>>                Case Break
36880>>>>>>>            Case Else
36880>>>>>>>                Error 8710 "Invalid algorithm selected."
36881>>>>>>>>
36881>>>>>>>                Function_Return False
36882>>>>>>>        Case End
36882>>>>>>>        
36882>>>>>>>        // Parse optional timecost
36882>>>>>>>        If (bRequiresTimeCost) Begin
36884>>>>>>>            Move (iEnd + 1) to iBegin
36885>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36886>>>>>>>            If (not(iEnd)) Function_Return False
36889>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36890>>>>>>>        End
36890>>>>>>>>
36890>>>>>>>        
36890>>>>>>>        // Parse rest hash
36890>>>>>>>        Move (iEnd + 1) to iBegin
36891>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36892>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36895>>>>>>>        
36895>>>>>>>        // Base64Decode
36895>>>>>>>        UChar[] ucaSalt
36896>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36897>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36900>>>>>>>        
36900>>>>>>>        // Create new hash
36900>>>>>>>        String sNewHash
36900>>>>>>>        If (bRequiresTimeCost) Begin
36902>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36904>>>>>>>                Function_Return False 
36905>>>>>>>            End
36905>>>>>>>>
36905>>>>>>>        End
36905>>>>>>>>
36905>>>>>>>        Else Begin
36906>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36908>>>>>>>                Function_Return False 
36909>>>>>>>            End
36909>>>>>>>>
36909>>>>>>>        End
36909>>>>>>>>
36909>>>>>>>        Function_Return (sNewHash = sHash)
36910>>>>>>>    End_Function
36911>>>>>>>    
36911>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36913>>>>>>>        Boolean bRequireTimeCost
36913>>>>>>>        UBigInt ullSize
36913>>>>>>>        UChar[] ucaSalt
36914>>>>>>>        String sSalt
36914>>>>>>>        
36914>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36915>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36916>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36919>>>>>>>        
36919>>>>>>>        Case Begin
36919>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36921>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36922>>>>>>>                Move True to bRequireTimeCost
36923>>>>>>>                Case Break
36924>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36927>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36928>>>>>>>                Move True to bRequireTimeCost
36929>>>>>>>                Case Break
36930>>>>>>>            Case Else
36930>>>>>>>                Error 8710 "Invalid algorithm selected."
36931>>>>>>>>
36931>>>>>>>                Function_Return 0
36932>>>>>>>        Case End
36932>>>>>>>        
36932>>>>>>>        // calculate base64 in a non-floating-manner
36932>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36933>>>>>>>        
36933>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36934>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36935>>>>>>>        If (bRequireTimeCost) Begin
36937>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36938>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36939>>>>>>>        End
36939>>>>>>>>
36939>>>>>>>        Else Begin
36940>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36941>>>>>>>        End
36941>>>>>>>>
36941>>>>>>>        
36941>>>>>>>        Function_Return ullSize
36942>>>>>>>    End_Function
36943>>>>>>>End_Class
36944>>>>>>>
36944>>>>>>>Class cPasswordHasher is a cObject
36945>>>>>>>    
36945>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36946>>>>>>>    
36946>>>>>>>    Procedure Construct_Object
36948>>>>>>>        Forward Send Construct_Object
36950>>>>>>>        
36950>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36951>>>>>>>        Property UInteger   puiSaltSize         16
36952>>>>>>>        
36952>>>>>>>        Property UInteger   puiOptTimeCost      420000
36953>>>>>>>    End_Procedure
36954>>>>>>>    
36954>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36956>>>>>>>        Boolean bOk
36956>>>>>>>        UInteger uiAlgo
36956>>>>>>>        Get peAlgorithm to uiAlgo
36957>>>>>>>        
36957>>>>>>>        Case Begin
36957>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36959>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36962>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36963>>>>>>>                Case Break
36964>>>>>>>            Case Else
36964>>>>>>>                Error 8710 "Invalid algorithm selected."
36965>>>>>>>>
36965>>>>>>>                Function_Return False
36966>>>>>>>        Case End
36966>>>>>>>        
36966>>>>>>>        Function_Return bOk
36967>>>>>>>    End_Function
36968>>>>>>>    
36968>>>>>>>    Function RequiredBufferSize Returns UBigInt
36970>>>>>>>        UBigInt ullSize
36970>>>>>>>        UInteger uiAlgo
36970>>>>>>>        Get peAlgorithm to uiAlgo
36971>>>>>>>        
36971>>>>>>>        Case Begin
36971>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36973>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36976>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36977>>>>>>>                Case Break
36978>>>>>>>            Case Else
36978>>>>>>>                Error 8710 "Invalid algorithm selected."
36979>>>>>>>>
36979>>>>>>>                Function_Return 0
36980>>>>>>>        Case End
36980>>>>>>>        
36980>>>>>>>        Function_Return ullSize
36981>>>>>>>    End_Function
36982>>>>>>>
36982>>>>>>>End_Class
