36934>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36935>>>>>    
36935>>>>>    Procedure Construct_Object
36937>>>>>        Handle hoObj
36937>>>>>        
36937>>>>>        Forward Send Construct_Object
36939>>>>>        
36939>>>>>        Set pbSessionCookieHttpOnly to True
36940>>>>>        
36940>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36941>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36942>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36943>>>>>        
36943>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36944>>>>>        Set phoUserDD to hoObj
36945>>>>>        
36945>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36946>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36947>>>>>        Set phoSessionDD to hoObj
36948>>>>>        
36948>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36949>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36950>>>>>        Set phoCrypto to hoObj
36951>>>>>        
36951>>>>>        Property Boolean pbPasswordHashing True
36952>>>>>        
36952>>>>>        Property Boolean pbCreatingNewSession False
36953>>>>>        Property String psLoginName
36954>>>>>        Property String psUserName ""
36955>>>>>        Property Integer piUserRights 0
36956>>>>>    End_Procedure
36957>>>>>    
36957>>>>>    Procedure End_Construct_Object
36959>>>>>        Forward Send End_Construct_Object
36961>>>>>        
36961>>>>>        Handle hoCrypto
36961>>>>>        Integer iFieldLen
36961>>>>>        If (pbPasswordHashing(Self)) Begin
36963>>>>>            Get phoCrypto to hoCrypto
36964>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36967>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36969>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36970>>>>>>
36970>>>>>            End
36970>>>>>>
36970>>>>>        End
36970>>>>>>
36970>>>>>    End_Procedure
36971>>>>>    
36971>>>>>    Function CreateSession String sRemoteAddress Returns String
36973>>>>>        String sSessionKey
36973>>>>>        Integer iErr
36973>>>>>        Boolean bLogWebSession
36973>>>>>        Handle hoSessionDD       
36973>>>>>        Get phoSessionDD to hoSessionDD
36974>>>>>        
36974>>>>>        //  Get session key
36974>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36976>>>>>        
36976>>>>>        Get pbLogWebSession to bLogWebSession
36977>>>>>        If not bLogWebSession Begin
36979>>>>>            Function_Return sSessionKey        
36980>>>>>        End
36980>>>>>>
36980>>>>>
36980>>>>>        //  Store session
36980>>>>>        Send Clear of hoSessionDD
36981>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36982>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36983>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36984>>>>>        Get Request_Validate of hoSessionDD to iErr
36985>>>>>        If (iErr) Begin
36987>>>>>            // this should not happen. If it does its a programming error
36987>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36988>>>>>>
36988>>>>>            Function_Return ""
36989>>>>>        End
36989>>>>>>
36989>>>>>        Send Request_Save of hoSessionDD
36990>>>>>        If (Err) Begin
36992>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36992>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36993>>>>>>
36993>>>>>            Function_Return ""
36994>>>>>        End
36994>>>>>>
36994>>>>>       
36994>>>>>        Function_Return sSessionKey        
36995>>>>>    End_Function
36996>>>>>    
36996>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36998>>>>>        DateTime dtLastAccess dtCurrent
36998>>>>>        TimeSpan tsDiff
36998>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36998>>>>>        Boolean bResult bCreatingNewSession
36998>>>>>        Boolean bLogWebSession bLoadWebApp
36998>>>>>        Integer eLoginMode
36998>>>>>        String sTime
36998>>>>>        Handle hoSessionDD hoUserDD       
36998>>>>>        
36998>>>>>        Move False to bLoadWebApp
36999>>>>>        If (num_arguments >= 2) Begin
37001>>>>>            Move bOptLoadWebApp to bLoadWebApp
37002>>>>>        End
37002>>>>>>
37002>>>>>        
37002>>>>>        Get phoSessionDD to hoSessionDD
37003>>>>>        Get phoUserDD to hoUserDD
37004>>>>>        
37004>>>>>        Get pbLogWebSession to bLogWebSession
37005>>>>>        Get peLoginMode to eLoginMode
37006>>>>>        
37006>>>>>        // for this object, you can only disable logging if login completely is disabled
37006>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37008>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37009>>>>>>
37009>>>>>            Function_Return False
37010>>>>>        End
37010>>>>>>
37010>>>>>
37010>>>>>        //  Clear session properties
37010>>>>>        Set psSessionKey to ""
37011>>>>>        Send UpdateSessionProperties True
37012>>>>>        
37012>>>>>        If not bLogWebSession Begin
37014>>>>>            Forward Get ValidateSession sSessionKey to bResult
37016>>>>>            Function_Return bResult
37017>>>>>        End        
37017>>>>>>
37017>>>>>        
37017>>>>>        Move False to bResult
37018>>>>>        Get piSessionTimeout to iSessionTimeout 
37019>>>>>        
37019>>>>>        //  Check if session exists
37019>>>>>        Send Clear of hoSessionDD
37020>>>>>        Move sSessionKey to WebAppSession.SessionKey
37021>>>>>        Send Find of hoSessionDD EQ Index.1
37022>>>>>            
37022>>>>>        If (Found) Begin
37024>>>>>            //  Calculate timespan between now and last access time
37024>>>>>            Move (CurrentDateTime()) to dtCurrent
37025>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37026>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37027>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37028>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37029>>>>>            
37029>>>>>            //  Check if session didn't time out
37029>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37031>>>>>                Forward Get ValidateSession sSessionKey to bResult
37033>>>>>                   
37033>>>>>                If (bResult) Begin
37035>>>>>                    //  Update session record
37035>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37036>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37037>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37038>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37039>>>>>                    Get Request_Validate of hoSessionDD to iErr
37040>>>>>                    If (iErr) Begin
37042>>>>>                        // this should not happen. If it does its a programming error
37042>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37043>>>>>>
37043>>>>>                        Function_Return False
37044>>>>>                    End
37044>>>>>>
37044>>>>>                    Send Request_Save of hoSessionDD
37045>>>>>                    
37045>>>>>                    //  Update user properties
37045>>>>>                    Send UpdateSessionProperties False
37046>>>>>                End
37046>>>>>>
37046>>>>>            End
37046>>>>>>
37046>>>>>            Else Begin
37047>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37047>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37048>>>>>                
37048>>>>>                If (not(bCreatingNewSession)) Begin
37050>>>>>                    If (not(bLoadWebApp)) Begin
37052>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37053>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37054>>>>>>
37054>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37055>>>>>                    End
37055>>>>>>
37055>>>>>                    Else Begin
37056>>>>>                        Set pbCreatingNewSession to True                    
37057>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37058>>>>>                        Set pbCreatingNewSession to False                        
37059>>>>>                    End
37059>>>>>>
37059>>>>>                End
37059>>>>>>
37059>>>>>            End
37059>>>>>>
37059>>>>>        End
37059>>>>>>
37059>>>>>        Else Begin
37060>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37061>>>>>>
37061>>>>>        End
37061>>>>>>
37061>>>>>        
37061>>>>>        Function_Return bResult
37062>>>>>    End_Function
37063>>>>>    
37063>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37065>>>>>        If (not(pbPasswordHashing(Self))) Begin
37067>>>>>            Move sPassword to sHash
37068>>>>>            Function_Return True
37069>>>>>        End
37069>>>>>>
37069>>>>>        
37069>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37071>>>>>            Function_Return False
37072>>>>>        End
37072>>>>>>
37072>>>>>        Move ("V1$" + sHash) to sHash
37073>>>>>        Function_Return True
37074>>>>>    End_Function
37075>>>>>    
37075>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37077>>>>>        If (not(pbPasswordHashing(Self))) Begin
37079>>>>>            Move False to bShouldUpgrade
37080>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37081>>>>>        End
37081>>>>>>
37081>>>>>        
37081>>>>>        String sVersion
37081>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37082>>>>>        If (sVersion = "V1$") Begin
37084>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37087>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37088>>>>>        End
37088>>>>>>
37088>>>>>        Else Begin
37089>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37092>>>>>            Function_Return False
37093>>>>>        End
37093>>>>>>
37093>>>>>    End_Function
37094>>>>>    
37094>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37096>>>>>        Handle hoUserDD
37096>>>>>        Integer iErr
37096>>>>>        Get phoUserDD to hoUserDD
37097>>>>>        
37097>>>>>        //  Find the user
37097>>>>>        Send Clear of hoUserDD
37098>>>>>        Move sLoginName to WebAppUser.LoginName
37099>>>>>        Send Find of hoUserDD EQ Index.1
37100>>>>>        If (Found) Begin
37102>>>>>            Send Clear of hoUserDD
37103>>>>>            Function_Return False
37104>>>>>        End
37104>>>>>>
37104>>>>>        
37104>>>>>        Send Clear of hoUserDD
37105>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37106>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37107>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37109>>>>>            Send Clear of hoUserDD
37110>>>>>            Function_Return False
37111>>>>>        End
37111>>>>>>
37111>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37112>>>>>        Get Request_Validate of hoUserDD to iErr
37113>>>>>        If (iErr) Begin
37115>>>>>            Send Clear of hoUserDD
37116>>>>>            Function_Return False
37117>>>>>        End
37117>>>>>>
37117>>>>>        
37117>>>>>        Send Request_Save of hoUserDD
37118>>>>>        Function_Return (not(Err))
37119>>>>>    End_Function
37120>>>>>    
37120>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37122>>>>>        String sSessionKey sUserPassword
37122>>>>>        Handle hoSessionDD hoUserDD
37122>>>>>        Boolean bMatch bUpgrade
37122>>>>>        
37122>>>>>        Get phoSessionDD to hoSessionDD
37123>>>>>        Get phoUserDD to hoUserDD
37124>>>>>        Integer iErr eLoginMode
37124>>>>>        
37124>>>>>        // Refind session record
37124>>>>>        Get psSessionKey to sSessionKey
37125>>>>>        Send Clear of hoSessionDD
37126>>>>>        Move sSessionKey to WebAppSession.SessionKey
37127>>>>>        Send Find of hoSessionDD EQ Index.1
37128>>>>>        
37128>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37130>>>>>            Get peLoginMode to eLoginMode
37131>>>>>            
37131>>>>>            //  Find the user
37131>>>>>            Move sLoginName to WebAppUser.LoginName
37132>>>>>            Send Find of hoUserDD EQ Index.1
37133>>>>>            
37133>>>>>            // Check username and password
37133>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37135>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37136>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37137>>>>>                
37137>>>>>                If (bMatch) Begin
37139>>>>>                    // Store the login
37139>>>>>                    If (bUpgrade) Begin
37141>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37142>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37145>>>>>                    End
37145>>>>>>
37145>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37146>>>>>                    Get Request_Validate of hoSessionDD to iErr
37147>>>>>                    If (iErr) Begin
37149>>>>>                        // this should not happen. If it does its a programming error
37149>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37150>>>>>>
37150>>>>>                        Function_Return False
37151>>>>>                    End
37151>>>>>>
37151>>>>>                    
37151>>>>>                    Send Request_Save of hoSessionDD
37152>>>>>                    
37152>>>>>                    // Update session properties
37152>>>>>                    Send UpdateSessionProperties False
37153>>>>>                    Send NotifyChangeRights
37154>>>>>                    Function_Return True
37155>>>>>                End
37155>>>>>>
37155>>>>>                Else Begin
37156>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37156>>>>>                    Send Clear of hoUserDD
37157>>>>>                End
37157>>>>>>
37157>>>>>            End
37157>>>>>>
37157>>>>>            Else Begin
37158>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37158>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37159>>>>>            End
37159>>>>>>
37159>>>>>        End
37159>>>>>>
37159>>>>>        Else Begin
37160>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37160>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37161>>>>>        End
37161>>>>>>
37161>>>>>          
37161>>>>>        Function_Return False
37162>>>>>    End_Function
