36766>>>>>>>        If (CNG_BCryptGenRandom(0, AddressOf(ucaBuffer), uiSize, |CI$00000002 /*BCRYPT_USE_SYSTEM_PREFERRED_RNG*/)) Begin
36768>>>>>>>            Error 8710 "Failed to create random buffer."
36769>>>>>>>>
36769>>>>>>>        End
36769>>>>>>>>
36769>>>>>>>        Function_Return ucaBuffer
36770>>>>>>>    End_Function
36771>>>>>>>    
36771>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
36773>>>>>>>        Integer iErr
36773>>>>>>>        Pointer pBase64
36773>>>>>>>        String sBase64
36773>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
36774>>>>>>>        If (not(pBase64)) Begin
36776>>>>>>>            Function_Return sBase64
36777>>>>>>>        End
36777>>>>>>>>
36777>>>>>>>        Move (PointerToString(pBase64)) to sBase64
36778>>>>>>>        Move (Free(pBase64)) to iErr
36779>>>>>>>        Function_Return sBase64
36780>>>>>>>    End_Function
36781>>>>>>>    
36781>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36783>>>>>>>        Integer iLen
36783>>>>>>>        Pointer pBase64
36783>>>>>>>        UChar[] ucaBuffer
36784>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36785>>>>>>>        If (not(pBase64)) Begin
36787>>>>>>>            Function_Return ucaBuffer
36788>>>>>>>        End
36788>>>>>>>>
36788>>>>>>>        
36788>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36789>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36790>>>>>>>        Move (Free(pBase64)) to iLen
36791>>>>>>>        Function_Return ucaBuffer
36792>>>>>>>    End_Function
36793>>>>>>>    
36793>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36795>>>>>>>        Boolean bOk bRequireTimeCost
36795>>>>>>>        UChar[] ucaHash
36796>>>>>>>        
36796>>>>>>>        Case Begin
36796>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36798>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36799>>>>>>>                If (not(bOk)) Function_Return False
36802>>>>>>>                
36802>>>>>>>                Move True to bRequireTimeCost
36803>>>>>>>                Case Break
36804>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36807>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36808>>>>>>>                If (not(bOk)) Function_Return False
36811>>>>>>>                
36811>>>>>>>                Move True to bRequireTimeCost
36812>>>>>>>                Case Break
36813>>>>>>>            Case Else
36813>>>>>>>                Error 8710 "Invalid algorithm selected."
36814>>>>>>>>
36814>>>>>>>                Function_Return False
36815>>>>>>>        Case End
36815>>>>>>>        
36815>>>>>>>        String sSalt
36815>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36816>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36819>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36820>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36823>>>>>>>        
36823>>>>>>>        If (bRequireTimeCost) Begin
36825>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36826>>>>>>>        End
36826>>>>>>>>
36826>>>>>>>        Else Begin
36827>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36828>>>>>>>        End
36828>>>>>>>>
36828>>>>>>>        
36828>>>>>>>        Function_Return bOk
36829>>>>>>>    End_Function
36830>>>>>>>    
36830>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36832>>>>>>>        UChar[] ucaSalt
36833>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36834>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36837>>>>>>>        
36837>>>>>>>        If (num_arguments > 4) Begin
36839>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36840>>>>>>>        End
36840>>>>>>>>
36840>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36841>>>>>>>    End_Function
36842>>>>>>>    
36842>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36844>>>>>>>        Boolean bRequiresTimeCost
36844>>>>>>>        UInteger uiAlgo uiTimeCost
36844>>>>>>>        Integer iBegin iEnd
36844>>>>>>>        String sSalt
36844>>>>>>>        
36844>>>>>>>        Move 1 to iBegin
36845>>>>>>>        
36845>>>>>>>        // Parse Algo
36845>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36846>>>>>>>        If (not(iEnd)) Function_Return False
36849>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36850>>>>>>>        
36850>>>>>>>        // Parse Salt
36850>>>>>>>        Move (iEnd + 1) to iBegin
36851>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36852>>>>>>>        If (not(iEnd)) Function_Return False
36855>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36856>>>>>>>        
36856>>>>>>>        Case Begin
36856>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36858>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36861>>>>>>>                Move True to bRequiresTimeCost
36862>>>>>>>                Case Break
36863>>>>>>>            Case Else
36863>>>>>>>                Error 8710 "Invalid algorithm selected."
36864>>>>>>>>
36864>>>>>>>                Function_Return False
36865>>>>>>>        Case End
36865>>>>>>>        
36865>>>>>>>        // Parse optional timecost
36865>>>>>>>        If (bRequiresTimeCost) Begin
36867>>>>>>>            Move (iEnd + 1) to iBegin
36868>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36869>>>>>>>            If (not(iEnd)) Function_Return False
36872>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36873>>>>>>>        End
36873>>>>>>>>
36873>>>>>>>        
36873>>>>>>>        // Parse rest hash
36873>>>>>>>        Move (iEnd + 1) to iBegin
36874>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36875>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36878>>>>>>>        
36878>>>>>>>        // Base64Decode
36878>>>>>>>        UChar[] ucaSalt
36879>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36880>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36883>>>>>>>        
36883>>>>>>>        // Create new hash
36883>>>>>>>        String sNewHash
36883>>>>>>>        If (bRequiresTimeCost) Begin
36885>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36887>>>>>>>                Function_Return False 
36888>>>>>>>            End
36888>>>>>>>>
36888>>>>>>>        End
36888>>>>>>>>
36888>>>>>>>        Else Begin
36889>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36891>>>>>>>                Function_Return False 
36892>>>>>>>            End
36892>>>>>>>>
36892>>>>>>>        End
36892>>>>>>>>
36892>>>>>>>        Function_Return (sNewHash = sHash)
36893>>>>>>>    End_Function
36894>>>>>>>    
36894>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36896>>>>>>>        Boolean bRequireTimeCost
36896>>>>>>>        UBigInt ullSize
36896>>>>>>>        UChar[] ucaSalt
36897>>>>>>>        String sSalt
36897>>>>>>>        
36897>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36898>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36899>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36902>>>>>>>        
36902>>>>>>>        Case Begin
36902>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36904>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36905>>>>>>>                Move True to bRequireTimeCost
36906>>>>>>>                Case Break
36907>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36910>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36911>>>>>>>                Move True to bRequireTimeCost
36912>>>>>>>                Case Break
36913>>>>>>>            Case Else
36913>>>>>>>                Error 8710 "Invalid algorithm selected."
36914>>>>>>>>
36914>>>>>>>                Function_Return 0
36915>>>>>>>        Case End
36915>>>>>>>        
36915>>>>>>>        // calculate base64 in a non-floating-manner
36915>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36916>>>>>>>        
36916>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36917>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36918>>>>>>>        If (bRequireTimeCost) Begin
36920>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36921>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36922>>>>>>>        End
36922>>>>>>>>
36922>>>>>>>        Else Begin
36923>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36924>>>>>>>        End
36924>>>>>>>>
36924>>>>>>>        
36924>>>>>>>        Function_Return ullSize
36925>>>>>>>    End_Function
36926>>>>>>>End_Class
36927>>>>>>>
36927>>>>>>>Class cPasswordHasher is a cObject
36928>>>>>>>    
36928>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36929>>>>>>>    
36929>>>>>>>    Procedure Construct_Object
36931>>>>>>>        Forward Send Construct_Object
36933>>>>>>>        
36933>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36934>>>>>>>        Property UInteger   puiSaltSize         16
36935>>>>>>>        
36935>>>>>>>        Property UInteger   puiOptTimeCost      420000
36936>>>>>>>    End_Procedure
36937>>>>>>>    
36937>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36939>>>>>>>        Boolean bOk
36939>>>>>>>        UInteger uiAlgo
36939>>>>>>>        Get peAlgorithm to uiAlgo
36940>>>>>>>        
36940>>>>>>>        Case Begin
36940>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36942>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36945>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36946>>>>>>>                Case Break
36947>>>>>>>            Case Else
36947>>>>>>>                Error 8710 "Invalid algorithm selected."
36948>>>>>>>>
36948>>>>>>>                Function_Return False
36949>>>>>>>        Case End
36949>>>>>>>        
36949>>>>>>>        Function_Return bOk
36950>>>>>>>    End_Function
36951>>>>>>>    
36951>>>>>>>    Function RequiredBufferSize Returns UBigInt
36953>>>>>>>        UBigInt ullSize
36953>>>>>>>        UInteger uiAlgo
36953>>>>>>>        Get peAlgorithm to uiAlgo
36954>>>>>>>        
36954>>>>>>>        Case Begin
36954>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36956>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36959>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36960>>>>>>>                Case Break
36961>>>>>>>            Case Else
36961>>>>>>>                Error 8710 "Invalid algorithm selected."
36962>>>>>>>>
36962>>>>>>>                Function_Return 0
36963>>>>>>>        Case End
36963>>>>>>>        
36963>>>>>>>        Function_Return ullSize
36964>>>>>>>    End_Function
36965>>>>>>>
36965>>>>>>>End_Class
