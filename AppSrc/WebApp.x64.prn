36620>>>>>>>    //
36620>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36620>>>>>>>    //
36620>>>>>>>    //  Params:
36620>>>>>>>    //      dtTime  Time to convert
36620>>>>>>>    //  Returns:
36620>>>>>>>    //      String with "HH:MM:SS" format
36620>>>>>>>    //
36620>>>>>>>    Function TimeToString DateTime dtTime Returns String
36622>>>>>>>        String sHours sMinutes sSeconds
36622>>>>>>>        
36622>>>>>>>        //  Extract parts
36622>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36623>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36624>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36625>>>>>>>        
36625>>>>>>>        //  Fill out with 0
36625>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36628>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36631>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36634>>>>>>>        
36634>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36635>>>>>>>    End_Function
36636>>>>>>>    
36636>>>>>>>    //
36636>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36636>>>>>>>    //
36636>>>>>>>    //  Params:
36636>>>>>>>    //      dtTime  Datetime variable to add time to
36636>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36636>>>>>>>    //  Returns:
36636>>>>>>>    //      dtDateTime with the loaded time
36636>>>>>>>    //
36636>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36638>>>>>>>        String sHours sMinutes sSeconds
36638>>>>>>>        
36638>>>>>>>        //  Extract parts
36638>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36639>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36640>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36641>>>>>>>        
36641>>>>>>>        //  Set to DateTime
36641>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36642>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36643>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36644>>>>>>>        
36644>>>>>>>        Function_Return dtTime
36645>>>>>>>    End_Function
