36543>>>>>>>    //
36543>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36543>>>>>>>    //
36543>>>>>>>    //  Params:
36543>>>>>>>    //      dtTime  Time to convert
36543>>>>>>>    //  Returns:
36543>>>>>>>    //      String with "HH:MM:SS" format
36543>>>>>>>    //
36543>>>>>>>    Function TimeToString DateTime dtTime Returns String
36545>>>>>>>        String sHours sMinutes sSeconds
36545>>>>>>>        
36545>>>>>>>        //  Extract parts
36545>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36546>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36547>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36548>>>>>>>        
36548>>>>>>>        //  Fill out with 0
36548>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36551>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36554>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36557>>>>>>>        
36557>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36558>>>>>>>    End_Function
36559>>>>>>>    
36559>>>>>>>    //
36559>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36559>>>>>>>    //
36559>>>>>>>    //  Params:
36559>>>>>>>    //      dtTime  Datetime variable to add time to
36559>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36559>>>>>>>    //  Returns:
36559>>>>>>>    //      dtDateTime with the loaded time
36559>>>>>>>    //
36559>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36561>>>>>>>        String sHours sMinutes sSeconds
36561>>>>>>>        
36561>>>>>>>        //  Extract parts
36561>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36562>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36563>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36564>>>>>>>        
36564>>>>>>>        //  Set to DateTime
36564>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36565>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36566>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36567>>>>>>>        
36567>>>>>>>        Function_Return dtTime
36568>>>>>>>    End_Function
