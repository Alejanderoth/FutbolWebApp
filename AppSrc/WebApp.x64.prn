38567>>>        WebSet pbRender of oDeleteBtn to False
38568>>>
38568>>>        If (NavigateData.bReadOnly) Begin 
38570>>>            WebSet pbRender of oEditBtn to True 
38571>>>        End
38571>>>>
38571>>>        Else Begin
38572>>>            WebSet pbRender of oSaveBtn to True
38573>>>            WebSet pbRender of oCancelChangesBtn to True
38574>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38575>>>        End
38575>>>>
38575>>>    End_Procedure
