38293>>>                    // so you just want to close (see 1 above). 
38293>>>                    // This is not used often with the drilldown style
38293>>>                    Send NavigateClose Self
38294>>>                    Case Break
38295>>>                Case Else // must be nfUndefined
38295>>>                    // This may be the start of a drilldown query or some kind of custom query.
38295>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
38295>>>            Case End
38295>>>
38295>>>        End_Procedure
