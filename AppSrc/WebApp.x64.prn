38168>>>    // This can be used to show and hide buttons based on context.
38168>>>    // This can be called any time the view is active.
38168>>>    Procedure SetActionButtons
38171>>>        tWebNavigateData NavigateData
38171>>>        tWebNavigateData NavigateData
38171>>>        Boolean bHasRecord
38171>>>        Handle hoDD
38171>>>
38171>>>        Get Server to hoDD
38172>>>        Get GetNavigateData to NavigateData
38173>>>        
38173>>>        If (hoDD) Begin
38175>>>            Get HasRecord of hoDD to bHasRecord
38176>>>        End
38176>>>>
38176>>>        Else Begin
38177>>>            Move False to bHasRecord
38178>>>        End
38178>>>>
38178>>>
38178>>>        // let's hide all buttons and then show the ones we want
38178>>>        WebSet pbRender of oEditBtn to False 
38179>>>        WebSet pbRender of oSaveBtn to False
38180>>>        WebSet pbRender of oCancelChangesBtn to False
38181>>>        WebSet pbRender of oDeleteBtn to False
38182>>>
38182>>>        If (NavigateData.bReadOnly) Begin 
38184>>>            WebSet pbRender of oEditBtn to True 
38185>>>        End
38185>>>>
38185>>>        Else Begin
38186>>>            WebSet pbRender of oSaveBtn to True
38187>>>            WebSet pbRender of oCancelChangesBtn to True
38188>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38189>>>        End
38189>>>>
38189>>>    End_Procedure
