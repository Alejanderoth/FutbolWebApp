36669>>>>>>>    //
36669>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36669>>>>>>>    //
36669>>>>>>>    //  Params:
36669>>>>>>>    //      dtTime  Time to convert
36669>>>>>>>    //  Returns:
36669>>>>>>>    //      String with "HH:MM:SS" format
36669>>>>>>>    //
36669>>>>>>>    Function TimeToString DateTime dtTime Returns String
36671>>>>>>>        String sHours sMinutes sSeconds
36671>>>>>>>        
36671>>>>>>>        //  Extract parts
36671>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36672>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36673>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36674>>>>>>>        
36674>>>>>>>        //  Fill out with 0
36674>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36677>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36680>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36683>>>>>>>        
36683>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36684>>>>>>>    End_Function
36685>>>>>>>    
36685>>>>>>>    //
36685>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36685>>>>>>>    //
36685>>>>>>>    //  Params:
36685>>>>>>>    //      dtTime  Datetime variable to add time to
36685>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36685>>>>>>>    //  Returns:
36685>>>>>>>    //      dtDateTime with the loaded time
36685>>>>>>>    //
36685>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36687>>>>>>>        String sHours sMinutes sSeconds
36687>>>>>>>        
36687>>>>>>>        //  Extract parts
36687>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36688>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36689>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36690>>>>>>>        
36690>>>>>>>        //  Set to DateTime
36690>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36691>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36692>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36693>>>>>>>        
36693>>>>>>>        Function_Return dtTime
36694>>>>>>>    End_Function
