38625>>>    // This can be used to show and hide buttons based on context.
38625>>>    // This can be called any time the view is active.
38625>>>    Procedure SetActionButtons
38628>>>        tWebNavigateData NavigateData
38628>>>        tWebNavigateData NavigateData
38628>>>        Boolean bHasRecord
38628>>>        Handle hoDD
38628>>>
38628>>>        Get Server to hoDD
38629>>>        Get GetNavigateData to NavigateData
38630>>>        
38630>>>        If (hoDD) Begin
38632>>>            Get HasRecord of hoDD to bHasRecord
38633>>>        End
38633>>>>
38633>>>        Else Begin
38634>>>            Move False to bHasRecord
38635>>>        End
38635>>>>
38635>>>
38635>>>        // let's hide all buttons and then show the ones we want
38635>>>        WebSet pbRender of oEditBtn to False 
38636>>>        WebSet pbRender of oSaveBtn to False
38637>>>        WebSet pbRender of oCancelChangesBtn to False
38638>>>        WebSet pbRender of oDeleteBtn to False
38639>>>
38639>>>        If (NavigateData.bReadOnly) Begin 
38641>>>            WebSet pbRender of oEditBtn to True 
38642>>>        End
38642>>>>
38642>>>        Else Begin
38643>>>            WebSet pbRender of oSaveBtn to True
38644>>>            WebSet pbRender of oCancelChangesBtn to True
38645>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38646>>>        End
38646>>>>
38646>>>    End_Procedure
