37528>>>    // This can be used to show and hide buttons based on context.
37528>>>    // This can be called any time the view is active.
37528>>>    Procedure SetActionButtons
37531>>>        tWebNavigateData NavigateData
37531>>>        tWebNavigateData NavigateData
37531>>>        Boolean bHasRecord
37531>>>        Handle hoDD
37531>>>
37531>>>        Get Server to hoDD
37532>>>        Get GetNavigateData to NavigateData
37533>>>        
37533>>>        If (hoDD) Begin
37535>>>            Get HasRecord of hoDD to bHasRecord
37536>>>        End
37536>>>>
37536>>>        Else Begin
37537>>>            Move False to bHasRecord
37538>>>        End
37538>>>>
37538>>>
37538>>>        // let's hide all buttons and then show the ones we want
37538>>>        WebSet pbRender of oEditBtn to False 
37539>>>        WebSet pbRender of oSaveBtn to False
37540>>>        WebSet pbRender of oCancelChangesBtn to False
37541>>>        WebSet pbRender of oDeleteBtn to False
37542>>>
37542>>>        If (NavigateData.bReadOnly) Begin 
37544>>>            WebSet pbRender of oEditBtn to True 
37545>>>        End
37545>>>>
37545>>>        Else Begin
37546>>>            WebSet pbRender of oSaveBtn to True
37547>>>            WebSet pbRender of oCancelChangesBtn to True
37548>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37549>>>        End
37549>>>>
37549>>>    End_Procedure
