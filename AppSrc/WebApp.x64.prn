38306>>>    // This can be used to show and hide buttons based on context.
38306>>>    // This can be called any time the view is active.
38306>>>    Procedure SetActionButtons
38309>>>        tWebNavigateData NavigateData
38309>>>        tWebNavigateData NavigateData
38309>>>        Boolean bHasRecord
38309>>>        Handle hoDD
38309>>>
38309>>>        Get Server to hoDD
38310>>>        Get GetNavigateData to NavigateData
38311>>>        
38311>>>        If (hoDD) Begin
38313>>>            Get HasRecord of hoDD to bHasRecord
38314>>>        End
38314>>>>
38314>>>        Else Begin
38315>>>            Move False to bHasRecord
38316>>>        End
38316>>>>
38316>>>
38316>>>        // let's hide all buttons and then show the ones we want
38316>>>        WebSet pbRender of oEditBtn to False 
38317>>>        WebSet pbRender of oSaveBtn to False
38318>>>        WebSet pbRender of oCancelChangesBtn to False
38319>>>        WebSet pbRender of oDeleteBtn to False
38320>>>
38320>>>        If (NavigateData.bReadOnly) Begin 
38322>>>            WebSet pbRender of oEditBtn to True 
38323>>>        End
38323>>>>
38323>>>        Else Begin
38324>>>            WebSet pbRender of oSaveBtn to True
38325>>>            WebSet pbRender of oCancelChangesBtn to True
38326>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38327>>>        End
38327>>>>
38327>>>    End_Procedure
38328>>>
