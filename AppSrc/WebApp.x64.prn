37313>>>    Procedure DoLogin
37316>>>        String sLoginName sPassword sPrevStateHash
37316>>>        Boolean bResult
37316>>>        
37316>>>        WebGet psValue of oLoginName to sLoginName
37317>>>        WebGet psValue of oPassword to sPassword
37318>>>        
37318>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37319>>>        
37319>>>        If (bResult) Begin
37321>>>            Send Hide of oLogin
37322>>>            Send ShowHeader of ghoWebApp
37323>>>            WebSet psCSSClass of ghoWebApp to ""
37324>>>            
37324>>>            WebGet psPrevStateHash to sPrevStateHash
37325>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37326>>>            
37326>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37326>>>            WebSet psValue of oLoginName to ""
37327>>>            WebSet psValue of oPassword  to ""
37328>>>            WebSet pbVisible of oWarning to False
37329>>>        End
37329>>>>
37329>>>        Else Begin
37330>>>            WebSet pbVisible of oWarning to True
37331>>>        End
37331>>>>
37331>>>    End_Procedure
