37543>>>    // This can be used to show and hide buttons based on context.
37543>>>    // This can be called any time the view is active.
37543>>>    Procedure SetActionButtons
37546>>>        tWebNavigateData NavigateData
37546>>>        tWebNavigateData NavigateData
37546>>>        Boolean bHasRecord
37546>>>        Handle hoDD
37546>>>
37546>>>        Get Server to hoDD
37547>>>        Get GetNavigateData to NavigateData
37548>>>        
37548>>>        If (hoDD) Begin
37550>>>            Get HasRecord of hoDD to bHasRecord
37551>>>        End
37551>>>>
37551>>>        Else Begin
37552>>>            Move False to bHasRecord
37553>>>        End
37553>>>>
37553>>>
37553>>>        // let's hide all buttons and then show the ones we want
37553>>>        WebSet pbRender of oEditBtn to False 
37554>>>        WebSet pbRender of oSaveBtn to False
37555>>>        WebSet pbRender of oCancelChangesBtn to False
37556>>>        WebSet pbRender of oDeleteBtn to False
37557>>>
37557>>>        If (NavigateData.bReadOnly) Begin 
37559>>>            WebSet pbRender of oEditBtn to True 
37560>>>        End
37560>>>>
37560>>>        Else Begin
37561>>>            WebSet pbRender of oSaveBtn to True
37562>>>            WebSet pbRender of oCancelChangesBtn to True
37563>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37564>>>        End
37564>>>>
37564>>>    End_Procedure
