36731>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36733>>>>>>>        Boolean bOk bRequireTimeCost
36733>>>>>>>        UChar[] ucaHash
36734>>>>>>>        
36734>>>>>>>        Case Begin
36734>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36736>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36737>>>>>>>                If (not(bOk)) Function_Return False
36740>>>>>>>                
36740>>>>>>>                Move True to bRequireTimeCost
36741>>>>>>>                Case Break
36742>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36745>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36746>>>>>>>                If (not(bOk)) Function_Return False
36749>>>>>>>                
36749>>>>>>>                Move True to bRequireTimeCost
36750>>>>>>>                Case Break
36751>>>>>>>            Case Else
36751>>>>>>>                Error 8710 "Invalid algorithm selected."
36752>>>>>>>>
36752>>>>>>>                Function_Return False
36753>>>>>>>        Case End
36753>>>>>>>        
36753>>>>>>>        String sSalt
36753>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36754>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36757>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36758>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36761>>>>>>>        
36761>>>>>>>        If (bRequireTimeCost) Begin
36763>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36764>>>>>>>        End
36764>>>>>>>>
36764>>>>>>>        Else Begin
36765>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36766>>>>>>>        End
36766>>>>>>>>
36766>>>>>>>        
36766>>>>>>>        Function_Return bOk
36767>>>>>>>    End_Function
