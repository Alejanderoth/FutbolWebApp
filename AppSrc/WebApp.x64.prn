36966>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36967>>>>>    
36967>>>>>    Procedure Construct_Object
36969>>>>>        Handle hoObj
36969>>>>>        
36969>>>>>        Forward Send Construct_Object
36971>>>>>        
36971>>>>>        Set pbSessionCookieHttpOnly to True
36972>>>>>        
36972>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36973>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36974>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36975>>>>>        
36975>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36976>>>>>        Set phoUserDD to hoObj
36977>>>>>        
36977>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36978>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36979>>>>>        Set phoSessionDD to hoObj
36980>>>>>        
36980>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36981>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36982>>>>>        Set phoCrypto to hoObj
36983>>>>>        
36983>>>>>        Property Boolean pbPasswordHashing True
36984>>>>>        
36984>>>>>        Property Boolean pbCreatingNewSession False
36985>>>>>        Property String psLoginName
36986>>>>>        Property String psUserName ""
36987>>>>>        Property Integer piUserRights 0
36988>>>>>    End_Procedure
36989>>>>>    
36989>>>>>    Procedure End_Construct_Object
36991>>>>>        Forward Send End_Construct_Object
36993>>>>>        
36993>>>>>        Handle hoCrypto
36993>>>>>        Integer iFieldLen
36993>>>>>        If (pbPasswordHashing(Self)) Begin
36995>>>>>            Get phoCrypto to hoCrypto
36996>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36999>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
37001>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
37002>>>>>>
37002>>>>>            End
37002>>>>>>
37002>>>>>        End
37002>>>>>>
37002>>>>>    End_Procedure
37003>>>>>    
37003>>>>>    Function CreateSession String sRemoteAddress Returns String
37005>>>>>        String sSessionKey
37005>>>>>        Integer iErr
37005>>>>>        Boolean bLogWebSession
37005>>>>>        Handle hoSessionDD       
37005>>>>>        Get phoSessionDD to hoSessionDD
37006>>>>>        
37006>>>>>        //  Get session key
37006>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37008>>>>>        
37008>>>>>        Get pbLogWebSession to bLogWebSession
37009>>>>>        If not bLogWebSession Begin
37011>>>>>            Function_Return sSessionKey        
37012>>>>>        End
37012>>>>>>
37012>>>>>
37012>>>>>        //  Store session
37012>>>>>        Send Clear of hoSessionDD
37013>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37014>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37015>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37016>>>>>        Get Request_Validate of hoSessionDD to iErr
37017>>>>>        If (iErr) Begin
37019>>>>>            // this should not happen. If it does its a programming error
37019>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37020>>>>>>
37020>>>>>            Function_Return ""
37021>>>>>        End
37021>>>>>>
37021>>>>>        Send Request_Save of hoSessionDD
37022>>>>>        If (Err) Begin
37024>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37024>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37025>>>>>>
37025>>>>>            Function_Return ""
37026>>>>>        End
37026>>>>>>
37026>>>>>       
37026>>>>>        Function_Return sSessionKey        
37027>>>>>    End_Function
37028>>>>>    
37028>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37030>>>>>        DateTime dtLastAccess dtCurrent
37030>>>>>        TimeSpan tsDiff
37030>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37030>>>>>        Boolean bResult bCreatingNewSession
37030>>>>>        Boolean bLogWebSession bLoadWebApp
37030>>>>>        Integer eLoginMode
37030>>>>>        String sTime
37030>>>>>        Handle hoSessionDD hoUserDD       
37030>>>>>        
37030>>>>>        Move False to bLoadWebApp
37031>>>>>        If (num_arguments >= 2) Begin
37033>>>>>            Move bOptLoadWebApp to bLoadWebApp
37034>>>>>        End
37034>>>>>>
37034>>>>>        
37034>>>>>        Get phoSessionDD to hoSessionDD
37035>>>>>        Get phoUserDD to hoUserDD
37036>>>>>        
37036>>>>>        Get pbLogWebSession to bLogWebSession
37037>>>>>        Get peLoginMode to eLoginMode
37038>>>>>        
37038>>>>>        // for this object, you can only disable logging if login completely is disabled
37038>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37040>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37041>>>>>>
37041>>>>>            Function_Return False
37042>>>>>        End
37042>>>>>>
37042>>>>>
37042>>>>>        //  Clear session properties
37042>>>>>        Set psSessionKey to ""
37043>>>>>        Send UpdateSessionProperties True
37044>>>>>        
37044>>>>>        If not bLogWebSession Begin
37046>>>>>            Forward Get ValidateSession sSessionKey to bResult
37048>>>>>            Function_Return bResult
37049>>>>>        End        
37049>>>>>>
37049>>>>>        
37049>>>>>        Move False to bResult
37050>>>>>        Get piSessionTimeout to iSessionTimeout 
37051>>>>>        
37051>>>>>        //  Check if session exists
37051>>>>>        Send Clear of hoSessionDD
37052>>>>>        Move sSessionKey to WebAppSession.SessionKey
37053>>>>>        Send Find of hoSessionDD EQ Index.1
37054>>>>>            
37054>>>>>        If (Found) Begin
37056>>>>>            //  Calculate timespan between now and last access time
37056>>>>>            Move (CurrentDateTime()) to dtCurrent
37057>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37058>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37059>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37060>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37061>>>>>            
37061>>>>>            //  Check if session didn't time out
37061>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37063>>>>>                Forward Get ValidateSession sSessionKey to bResult
37065>>>>>                   
37065>>>>>                If (bResult) Begin
37067>>>>>                    //  Update session record
37067>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37068>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37069>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37070>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37071>>>>>                    Get Request_Validate of hoSessionDD to iErr
37072>>>>>                    If (iErr) Begin
37074>>>>>                        // this should not happen. If it does its a programming error
37074>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37075>>>>>>
37075>>>>>                        Function_Return False
37076>>>>>                    End
37076>>>>>>
37076>>>>>                    Send Request_Save of hoSessionDD
37077>>>>>                    
37077>>>>>                    //  Update user properties
37077>>>>>                    Send UpdateSessionProperties False
37078>>>>>                End
37078>>>>>>
37078>>>>>            End
37078>>>>>>
37078>>>>>            Else Begin
37079>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37079>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37080>>>>>                
37080>>>>>                If (not(bCreatingNewSession)) Begin
37082>>>>>                    If (not(bLoadWebApp)) Begin
37084>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37085>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37086>>>>>>
37086>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37087>>>>>                    End
37087>>>>>>
37087>>>>>                    Else Begin
37088>>>>>                        Set pbCreatingNewSession to True                    
37089>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37090>>>>>                        Set pbCreatingNewSession to False                        
37091>>>>>                    End
37091>>>>>>
37091>>>>>                End
37091>>>>>>
37091>>>>>            End
37091>>>>>>
37091>>>>>        End
37091>>>>>>
37091>>>>>        Else Begin
37092>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37093>>>>>>
37093>>>>>        End
37093>>>>>>
37093>>>>>        
37093>>>>>        Function_Return bResult
37094>>>>>    End_Function
37095>>>>>    
37095>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37097>>>>>        If (not(pbPasswordHashing(Self))) Begin
37099>>>>>            Move sPassword to sHash
37100>>>>>            Function_Return True
37101>>>>>        End
37101>>>>>>
37101>>>>>        
37101>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37103>>>>>            Function_Return False
37104>>>>>        End
37104>>>>>>
37104>>>>>        Move ("V1$" + sHash) to sHash
37105>>>>>        Function_Return True
37106>>>>>    End_Function
37107>>>>>    
37107>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37109>>>>>        If (not(pbPasswordHashing(Self))) Begin
37111>>>>>            Move False to bShouldUpgrade
37112>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37113>>>>>        End
37113>>>>>>
37113>>>>>        
37113>>>>>        String sVersion
37113>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37114>>>>>        If (sVersion = "V1$") Begin
37116>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37119>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37120>>>>>        End
37120>>>>>>
37120>>>>>        Else Begin
37121>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37124>>>>>            Function_Return False
37125>>>>>        End
37125>>>>>>
37125>>>>>    End_Function
37126>>>>>    
37126>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37128>>>>>        Handle hoUserDD
37128>>>>>        Integer iErr
37128>>>>>        Get phoUserDD to hoUserDD
37129>>>>>        
37129>>>>>        //  Find the user
37129>>>>>        Send Clear of hoUserDD
37130>>>>>        Move sLoginName to WebAppUser.LoginName
37131>>>>>        Send Find of hoUserDD EQ Index.1
37132>>>>>        If (Found) Begin
37134>>>>>            Send Clear of hoUserDD
37135>>>>>            Function_Return False
37136>>>>>        End
37136>>>>>>
37136>>>>>        
37136>>>>>        Send Clear of hoUserDD
37137>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37138>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37139>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37141>>>>>            Send Clear of hoUserDD
37142>>>>>            Function_Return False
37143>>>>>        End
37143>>>>>>
37143>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37144>>>>>        Get Request_Validate of hoUserDD to iErr
37145>>>>>        If (iErr) Begin
37147>>>>>            Send Clear of hoUserDD
37148>>>>>            Function_Return False
37149>>>>>        End
37149>>>>>>
37149>>>>>        
37149>>>>>        Send Request_Save of hoUserDD
37150>>>>>        Function_Return (not(Err))
37151>>>>>    End_Function
37152>>>>>    
37152>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37154>>>>>        String sSessionKey sUserPassword
37154>>>>>        Handle hoSessionDD hoUserDD
37154>>>>>        Boolean bMatch bUpgrade
37154>>>>>        
37154>>>>>        Get phoSessionDD to hoSessionDD
37155>>>>>        Get phoUserDD to hoUserDD
37156>>>>>        Integer iErr eLoginMode
37156>>>>>        
37156>>>>>        // Refind session record
37156>>>>>        Get psSessionKey to sSessionKey
37157>>>>>        Send Clear of hoSessionDD
37158>>>>>        Move sSessionKey to WebAppSession.SessionKey
37159>>>>>        Send Find of hoSessionDD EQ Index.1
37160>>>>>        
37160>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37162>>>>>            Get peLoginMode to eLoginMode
37163>>>>>            
37163>>>>>            //  Find the user
37163>>>>>            Move sLoginName to WebAppUser.LoginName
37164>>>>>            Send Find of hoUserDD EQ Index.1
37165>>>>>            
37165>>>>>            // Check username and password
37165>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37167>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37168>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37169>>>>>                
37169>>>>>                If (bMatch) Begin
37171>>>>>                    // Store the login
37171>>>>>                    If (bUpgrade) Begin
37173>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37174>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37177>>>>>                    End
37177>>>>>>
37177>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37178>>>>>                    Get Request_Validate of hoSessionDD to iErr
37179>>>>>                    If (iErr) Begin
37181>>>>>                        // this should not happen. If it does its a programming error
37181>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37182>>>>>>
37182>>>>>                        Function_Return False
37183>>>>>                    End
37183>>>>>>
37183>>>>>                    
37183>>>>>                    Send Request_Save of hoSessionDD
37184>>>>>                    
37184>>>>>                    // Update session properties
37184>>>>>                    Send UpdateSessionProperties False
37185>>>>>                    Send NotifyChangeRights
37186>>>>>                    Function_Return True
37187>>>>>                End
37187>>>>>>
37187>>>>>                Else Begin
37188>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37188>>>>>                    Send Clear of hoUserDD
37189>>>>>                End
37189>>>>>>
37189>>>>>            End
37189>>>>>>
37189>>>>>            Else Begin
37190>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37190>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37191>>>>>            End
37191>>>>>>
37191>>>>>        End
37191>>>>>>
37191>>>>>        Else Begin
37192>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37192>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37193>>>>>        End
37193>>>>>>
37193>>>>>          
37193>>>>>        Function_Return False
