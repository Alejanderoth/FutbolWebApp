37407>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37408>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37410>>>            WebSet psPrevStateHash to sPrevStateHash
37411>>>        End
37411>>>>
37411>>>        
37411>>>    End_Procedure
