37496>>>    // This can be used to show and hide buttons based on context.
37496>>>    // This can be called any time the view is active.
37496>>>    Procedure SetActionButtons
37499>>>        tWebNavigateData NavigateData
37499>>>        tWebNavigateData NavigateData
37499>>>        Boolean bHasRecord
37499>>>        Handle hoDD
37499>>>
37499>>>        Get Server to hoDD
37500>>>        Get GetNavigateData to NavigateData
37501>>>        
37501>>>        If (hoDD) Begin
37503>>>            Get HasRecord of hoDD to bHasRecord
37504>>>        End
37504>>>>
37504>>>        Else Begin
37505>>>            Move False to bHasRecord
37506>>>        End
37506>>>>
37506>>>
37506>>>        // let's hide all buttons and then show the ones we want
37506>>>        WebSet pbRender of oEditBtn to False 
37507>>>        WebSet pbRender of oSaveBtn to False
37508>>>        WebSet pbRender of oCancelChangesBtn to False
37509>>>        WebSet pbRender of oDeleteBtn to False
37510>>>
37510>>>        If (NavigateData.bReadOnly) Begin 
37512>>>            WebSet pbRender of oEditBtn to True 
37513>>>        End
37513>>>>
37513>>>        Else Begin
37514>>>            WebSet pbRender of oSaveBtn to True
37515>>>            WebSet pbRender of oCancelChangesBtn to True
37516>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37517>>>        End
37517>>>>
37517>>>    End_Procedure
