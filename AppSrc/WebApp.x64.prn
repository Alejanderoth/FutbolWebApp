37840>>>    // This can be used to show and hide buttons based on context.
37840>>>    // This can be called any time the view is active.
37840>>>    Procedure SetActionButtons
37843>>>        tWebNavigateData NavigateData
37843>>>        tWebNavigateData NavigateData
37843>>>        Boolean bHasRecord
37843>>>        Handle hoDD
37843>>>
37843>>>        Get Server to hoDD
37844>>>        Get GetNavigateData to NavigateData
37845>>>        
37845>>>        If (hoDD) Begin
37847>>>            Get HasRecord of hoDD to bHasRecord
37848>>>        End
37848>>>>
37848>>>        Else Begin
37849>>>            Move False to bHasRecord
37850>>>        End
37850>>>>
37850>>>
37850>>>        // let's hide all buttons and then show the ones we want
37850>>>        WebSet pbRender of oEditBtn to False 
37851>>>        WebSet pbRender of oSaveBtn to False
37852>>>        WebSet pbRender of oCancelChangesBtn to False
37853>>>        WebSet pbRender of oDeleteBtn to False
37854>>>
37854>>>        If (NavigateData.bReadOnly) Begin 
37856>>>            WebSet pbRender of oEditBtn to True 
37857>>>        End
37857>>>>
37857>>>        Else Begin
37858>>>            WebSet pbRender of oSaveBtn to True
37859>>>            WebSet pbRender of oCancelChangesBtn to True
37860>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37861>>>        End
37861>>>>
37861>>>    End_Procedure
37862>>>
