37328>>>    Procedure DoLogin
37331>>>        String sLoginName sPassword sPrevStateHash
37331>>>        Boolean bResult
37331>>>        
37331>>>        WebGet psValue of oLoginName to sLoginName
37332>>>        WebGet psValue of oPassword to sPassword
37333>>>        
37333>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37334>>>        
37334>>>        If (bResult) Begin
37336>>>            Send Hide of oLogin
37337>>>            Send ShowHeader of ghoWebApp
37338>>>            WebSet psCSSClass of ghoWebApp to ""
37339>>>            
37339>>>            WebGet psPrevStateHash to sPrevStateHash
37340>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37341>>>            
37341>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37341>>>            WebSet psValue of oLoginName to ""
37342>>>            WebSet psValue of oPassword  to ""
37343>>>            WebSet pbVisible of oWarning to False
37344>>>        End
37344>>>>
37344>>>        Else Begin
37345>>>            WebSet pbVisible of oWarning to True
37346>>>        End
37346>>>>
37346>>>    End_Procedure
