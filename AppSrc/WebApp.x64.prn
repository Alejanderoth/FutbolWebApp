37389>>>        Get StateHash of ghoWebApp to sPrevStateHash
37390>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37391>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37393>>>            WebSet psPrevStateHash to sPrevStateHash
37394>>>        End
37394>>>>
37394>>>        
37394>>>    End_Procedure
