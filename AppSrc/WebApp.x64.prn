37340>>>        String sPrevStateHash sView
37340>>>        
37340>>>        Forward Send OnLoad
37342>>>        
37342>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37342>>>        Get StateHash of ghoWebApp to sPrevStateHash
37343>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37344>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37346>>>            WebSet psPrevStateHash to sPrevStateHash
37347>>>        End
37347>>>>
37347>>>        
37347>>>    End_Procedure
