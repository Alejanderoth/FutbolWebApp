37870>>>
37870>>>    // This can be used to show and hide buttons based on context.
37870>>>    // This can be called any time the view is active.
37870>>>    Procedure SetActionButtons
37873>>>        tWebNavigateData NavigateData
37873>>>        tWebNavigateData NavigateData
37873>>>        Boolean bHasRecord
37873>>>        Handle hoDD
37873>>>
37873>>>        Get Server to hoDD
37874>>>        Get GetNavigateData to NavigateData
37875>>>        
37875>>>        If (hoDD) Begin
37877>>>            Get HasRecord of hoDD to bHasRecord
37878>>>        End
37878>>>>
37878>>>        Else Begin
37879>>>            Move False to bHasRecord
37880>>>        End
37880>>>>
37880>>>
37880>>>        // let's hide all buttons and then show the ones we want
37880>>>        WebSet pbRender of oEditBtn to False 
37881>>>        WebSet pbRender of oSaveBtn to False
37882>>>        WebSet pbRender of oCancelChangesBtn to False
37883>>>        WebSet pbRender of oDeleteBtn to False
37884>>>
37884>>>        If (NavigateData.bReadOnly) Begin 
37886>>>            WebSet pbRender of oEditBtn to True 
37887>>>        End
37887>>>>
37887>>>        Else Begin
37888>>>            WebSet pbRender of oSaveBtn to True
37889>>>            WebSet pbRender of oCancelChangesBtn to True
37890>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37891>>>        End
37891>>>>
37891>>>    End_Procedure
37892>>>
