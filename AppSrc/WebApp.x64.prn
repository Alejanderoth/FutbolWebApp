38239>>>    // This can be used to show and hide buttons based on context.
38239>>>    // This can be called any time the view is active.
38239>>>    Procedure SetActionButtons
38242>>>        tWebNavigateData NavigateData
38242>>>        tWebNavigateData NavigateData
38242>>>        Boolean bHasRecord
38242>>>        Handle hoDD
38242>>>
38242>>>        Get Server to hoDD
38243>>>        Get GetNavigateData to NavigateData
38244>>>        
38244>>>        If (hoDD) Begin
38246>>>            Get HasRecord of hoDD to bHasRecord
38247>>>        End
38247>>>>
38247>>>        Else Begin
38248>>>            Move False to bHasRecord
38249>>>        End
38249>>>>
38249>>>
38249>>>        // let's hide all buttons and then show the ones we want
38249>>>        WebSet pbRender of oEditBtn to False 
38250>>>        WebSet pbRender of oSaveBtn to False
38251>>>        WebSet pbRender of oCancelChangesBtn to False
38252>>>        WebSet pbRender of oDeleteBtn to False
38253>>>
38253>>>        If (NavigateData.bReadOnly) Begin 
38255>>>            WebSet pbRender of oEditBtn to True 
38256>>>        End
38256>>>>
38256>>>        Else Begin
38257>>>            WebSet pbRender of oSaveBtn to True
38258>>>            WebSet pbRender of oCancelChangesBtn to True
38259>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38260>>>        End
38260>>>>
38260>>>    End_Procedure
38261>>>
38261>>>    // this will close the view after a save
38261>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38264>>>        Send NavigateClose Self
38265>>>    End_Procedure
38266>>>
38266>>>    // this will close the view after a delete
38266>>>    Procedure OnViewDeleted Handle hoDDO
38269>>>        Send NavigateClose Self
38270>>>    End_Procedure
38271>>>
38271>>>    // Add code to customize your Zoom View based on how it was invoked.
38271>>>    // Use NavigateData to determine the context this view will be used in.
38271>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38274>>>
38274>>>        // if this view is being used in multiple contexts, you may need a block of code
38274>>>        // like this to handle customizations. This would include hiding rows and buttons
38274>>>        // (WebSet pbRender) and changing the values of various captions.
38274>>>        Case Begin
38274>>>            Case (NavigateData.eNavigateType = nfFromMain)
38276>>>                // If from main, this is a probably a main file Select to Zoom.
38276>>>                // This is the most typical way to navigate to a zoom.
38276>>>                Case Break
38277>>>                
38277>>>            Case (NavigateData.eNavigateType = nfFromParent)
38280>>>                // If from parent, this is a constrained drill down.
38280>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38280>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38280>>>                Case Break
38281>>>                
38281>>>            Case (NavigateData.eNavigateType = nfFromChild)
38284>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38284>>>                // This is unusual, but it might be used for adding a new child record.
38284>>>                Case Break
38285>>>                
38285>>>            Case Else // must be nfUndefined
38285>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38285>>>                // You may want to check NavigateData.NamedValues.
38285>>>                  
38285>>>        Case End
38285>>>
38285>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38285>>>        // It's best to set these buttons in their own procedure so you can change later.
38285>>>        Send SetActionButtons
38286>>>
38286>>>    End_Procedure
38287>>>
38287>>>End_Object
