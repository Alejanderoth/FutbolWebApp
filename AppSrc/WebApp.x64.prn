37466>>>    // This can be used to show and hide buttons based on context.
37466>>>    // This can be called any time the view is active.
37466>>>    Procedure SetActionButtons
37469>>>        tWebNavigateData NavigateData
37469>>>        tWebNavigateData NavigateData
37469>>>        Boolean bHasRecord
37469>>>        Handle hoDD
37469>>>
37469>>>        Get Server to hoDD
37470>>>        Get GetNavigateData to NavigateData
37471>>>        
37471>>>        If (hoDD) Begin
37473>>>            Get HasRecord of hoDD to bHasRecord
37474>>>        End
37474>>>>
37474>>>        Else Begin
37475>>>            Move False to bHasRecord
37476>>>        End
37476>>>>
37476>>>
37476>>>        // let's hide all buttons and then show the ones we want
37476>>>        WebSet pbRender of oEditBtn to False 
37477>>>        WebSet pbRender of oSaveBtn to False
37478>>>        WebSet pbRender of oCancelChangesBtn to False
37479>>>        WebSet pbRender of oDeleteBtn to False
37480>>>
37480>>>        If (NavigateData.bReadOnly) Begin 
37482>>>            WebSet pbRender of oEditBtn to True 
37483>>>        End
37483>>>>
37483>>>        Else Begin
37484>>>            WebSet pbRender of oSaveBtn to True
37485>>>            WebSet pbRender of oCancelChangesBtn to True
37486>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37487>>>        End
37487>>>>
37487>>>    End_Procedure
