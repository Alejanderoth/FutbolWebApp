37345>>>    Procedure DoLogin
37348>>>        String sLoginName sPassword sPrevStateHash
37348>>>        Boolean bResult
37348>>>        
37348>>>        WebGet psValue of oLoginName to sLoginName
37349>>>        WebGet psValue of oPassword to sPassword
37350>>>        
37350>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37351>>>        
37351>>>        If (bResult) Begin
37353>>>            Send Hide of oLogin
37354>>>            Send ShowHeader of ghoWebApp
37355>>>            WebSet psCSSClass of ghoWebApp to ""
37356>>>            
37356>>>            WebGet psPrevStateHash to sPrevStateHash
37357>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37358>>>            
37358>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37358>>>            WebSet psValue of oLoginName to ""
37359>>>            WebSet psValue of oPassword  to ""
37360>>>            WebSet pbVisible of oWarning to False
37361>>>        End
37361>>>>
37361>>>        Else Begin
37362>>>            WebSet pbVisible of oWarning to True
37363>>>        End
37363>>>>
37363>>>    End_Procedure
