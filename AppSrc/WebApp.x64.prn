36605>>>>>>>    //
36605>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36605>>>>>>>    //
36605>>>>>>>    //  Params:
36605>>>>>>>    //      dtTime  Time to convert
36605>>>>>>>    //  Returns:
36605>>>>>>>    //      String with "HH:MM:SS" format
36605>>>>>>>    //
36605>>>>>>>    Function TimeToString DateTime dtTime Returns String
36607>>>>>>>        String sHours sMinutes sSeconds
36607>>>>>>>        
36607>>>>>>>        //  Extract parts
36607>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36608>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36609>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36610>>>>>>>        
36610>>>>>>>        //  Fill out with 0
36610>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36613>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36616>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36619>>>>>>>        
36619>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36620>>>>>>>    End_Function
36621>>>>>>>    
36621>>>>>>>    //
36621>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36621>>>>>>>    //
36621>>>>>>>    //  Params:
36621>>>>>>>    //      dtTime  Datetime variable to add time to
36621>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36621>>>>>>>    //  Returns:
36621>>>>>>>    //      dtDateTime with the loaded time
36621>>>>>>>    //
36621>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36623>>>>>>>        String sHours sMinutes sSeconds
36623>>>>>>>        
36623>>>>>>>        //  Extract parts
36623>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36624>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36625>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36626>>>>>>>        
36626>>>>>>>        //  Set to DateTime
36626>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36627>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36628>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36629>>>>>>>        
36629>>>>>>>        Function_Return dtTime
36630>>>>>>>    End_Function
