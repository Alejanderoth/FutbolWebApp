36637>>>>>>>    //
36637>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36637>>>>>>>    //
36637>>>>>>>    //  Params:
36637>>>>>>>    //      dtTime  Time to convert
36637>>>>>>>    //  Returns:
36637>>>>>>>    //      String with "HH:MM:SS" format
36637>>>>>>>    //
36637>>>>>>>    Function TimeToString DateTime dtTime Returns String
36639>>>>>>>        String sHours sMinutes sSeconds
36639>>>>>>>        
36639>>>>>>>        //  Extract parts
36639>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36640>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36641>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36642>>>>>>>        
36642>>>>>>>        //  Fill out with 0
36642>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36645>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36648>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36651>>>>>>>        
36651>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36652>>>>>>>    End_Function
36653>>>>>>>    
36653>>>>>>>    //
36653>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36653>>>>>>>    //
36653>>>>>>>    //  Params:
36653>>>>>>>    //      dtTime  Datetime variable to add time to
36653>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36653>>>>>>>    //  Returns:
36653>>>>>>>    //      dtDateTime with the loaded time
36653>>>>>>>    //
36653>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36655>>>>>>>        String sHours sMinutes sSeconds
36655>>>>>>>        
36655>>>>>>>        //  Extract parts
36655>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36656>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36657>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36658>>>>>>>        
36658>>>>>>>        //  Set to DateTime
36658>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36659>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36660>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36661>>>>>>>        
36661>>>>>>>        Function_Return dtTime
36662>>>>>>>    End_Function
36663>>>>>>>End_Class
