38262>>>    // This can be used to show and hide buttons based on context.
38262>>>    // This can be called any time the view is active.
38262>>>    Procedure SetActionButtons
38265>>>        tWebNavigateData NavigateData
38265>>>        tWebNavigateData NavigateData
38265>>>        Boolean bHasRecord
38265>>>        Handle hoDD
38265>>>
38265>>>        Get Server to hoDD
38266>>>        Get GetNavigateData to NavigateData
38267>>>        
38267>>>        If (hoDD) Begin
38269>>>            Get HasRecord of hoDD to bHasRecord
38270>>>        End
38270>>>>
38270>>>        Else Begin
38271>>>            Move False to bHasRecord
38272>>>        End
38272>>>>
38272>>>
38272>>>        // let's hide all buttons and then show the ones we want
38272>>>        WebSet pbRender of oEditBtn to False 
38273>>>        WebSet pbRender of oSaveBtn to False
38274>>>        WebSet pbRender of oCancelChangesBtn to False
38275>>>        WebSet pbRender of oDeleteBtn to False
38276>>>
38276>>>        If (NavigateData.bReadOnly) Begin 
38278>>>            WebSet pbRender of oEditBtn to True 
38279>>>        End
38279>>>>
38279>>>        Else Begin
38280>>>            WebSet pbRender of oSaveBtn to True
38281>>>            WebSet pbRender of oCancelChangesBtn to True
38282>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38283>>>        End
38283>>>>
38283>>>    End_Procedure
38284>>>
38284>>>    // this will close the view after a save
38284>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38287>>>        Send NavigateClose Self
38288>>>    End_Procedure
38289>>>
38289>>>    // this will close the view after a delete
38289>>>    Procedure OnViewDeleted Handle hoDDO
38292>>>        Send NavigateClose Self
38293>>>    End_Procedure
