37251>>>    Procedure DoLogin
37254>>>        String sLoginName sPassword sPrevStateHash
37254>>>        Boolean bResult
37254>>>        
37254>>>        WebGet psValue of oLoginName to sLoginName
37255>>>        WebGet psValue of oPassword to sPassword
37256>>>        
37256>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37257>>>        
37257>>>        If (bResult) Begin
37259>>>            Send Hide of oLogin
37260>>>            Send ShowHeader of ghoWebApp
37261>>>            WebSet psCSSClass of ghoWebApp to ""
37262>>>            
37262>>>            WebGet psPrevStateHash to sPrevStateHash
37263>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37264>>>            
37264>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37264>>>            WebSet psValue of oLoginName to ""
37265>>>            WebSet psValue of oPassword  to ""
37266>>>            WebSet pbVisible of oWarning to False
37267>>>        End
37267>>>>
37267>>>        Else Begin
37268>>>            WebSet pbVisible of oWarning to True
37269>>>        End
37269>>>>
37269>>>    End_Procedure
37270>>>    
37270>>>    Procedure OnSubmit
37273>>>        Send DoLogin
37274>>>    End_Procedure
