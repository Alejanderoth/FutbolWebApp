36606>>>>>>>    //
36606>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36608>>>>>>>        String sHours sMinutes sSeconds
36608>>>>>>>        
36608>>>>>>>        //  Extract parts
36608>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36609>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36610>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36611>>>>>>>        
36611>>>>>>>        //  Set to DateTime
36611>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36612>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36613>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36614>>>>>>>        
36614>>>>>>>        Function_Return dtTime
36615>>>>>>>    End_Function
