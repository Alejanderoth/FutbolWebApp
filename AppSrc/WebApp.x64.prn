36919>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36920>>>>>    
36920>>>>>    Procedure Construct_Object
36922>>>>>        Handle hoObj
36922>>>>>        
36922>>>>>        Forward Send Construct_Object
36924>>>>>        
36924>>>>>        Set pbSessionCookieHttpOnly to True
36925>>>>>        
36925>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36926>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36927>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36928>>>>>        
36928>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36929>>>>>        Set phoUserDD to hoObj
36930>>>>>        
36930>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36931>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36932>>>>>        Set phoSessionDD to hoObj
36933>>>>>        
36933>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36934>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36935>>>>>        Set phoCrypto to hoObj
36936>>>>>        
36936>>>>>        Property Boolean pbPasswordHashing True
36937>>>>>        
36937>>>>>        Property Boolean pbCreatingNewSession False
36938>>>>>        Property String psLoginName
36939>>>>>        Property String psUserName ""
36940>>>>>        Property Integer piUserRights 0
36941>>>>>    End_Procedure
36942>>>>>    
36942>>>>>    Procedure End_Construct_Object
36944>>>>>        Forward Send End_Construct_Object
36946>>>>>        
36946>>>>>        Handle hoCrypto
36946>>>>>        Integer iFieldLen
36946>>>>>        If (pbPasswordHashing(Self)) Begin
36948>>>>>            Get phoCrypto to hoCrypto
36949>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36952>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36954>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36955>>>>>>
36955>>>>>            End
36955>>>>>>
36955>>>>>        End
36955>>>>>>
36955>>>>>    End_Procedure
36956>>>>>    
36956>>>>>    Function CreateSession String sRemoteAddress Returns String
36958>>>>>        String sSessionKey
36958>>>>>        Integer iErr
36958>>>>>        Boolean bLogWebSession
36958>>>>>        Handle hoSessionDD       
36958>>>>>        Get phoSessionDD to hoSessionDD
36959>>>>>        
36959>>>>>        //  Get session key
36959>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36961>>>>>        
36961>>>>>        Get pbLogWebSession to bLogWebSession
36962>>>>>        If not bLogWebSession Begin
36964>>>>>            Function_Return sSessionKey        
36965>>>>>        End
36965>>>>>>
36965>>>>>
36965>>>>>        //  Store session
36965>>>>>        Send Clear of hoSessionDD
36966>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36967>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36968>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36969>>>>>        Get Request_Validate of hoSessionDD to iErr
36970>>>>>        If (iErr) Begin
36972>>>>>            // this should not happen. If it does its a programming error
36972>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36973>>>>>>
36973>>>>>            Function_Return ""
36974>>>>>        End
36974>>>>>>
36974>>>>>        Send Request_Save of hoSessionDD
36975>>>>>        If (Err) Begin
36977>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36977>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36978>>>>>>
36978>>>>>            Function_Return ""
36979>>>>>        End
36979>>>>>>
36979>>>>>       
36979>>>>>        Function_Return sSessionKey        
36980>>>>>    End_Function
36981>>>>>    
36981>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36983>>>>>        DateTime dtLastAccess dtCurrent
36983>>>>>        TimeSpan tsDiff
36983>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36983>>>>>        Boolean bResult bCreatingNewSession
36983>>>>>        Boolean bLogWebSession bLoadWebApp
36983>>>>>        Integer eLoginMode
36983>>>>>        String sTime
36983>>>>>        Handle hoSessionDD hoUserDD       
36983>>>>>        
36983>>>>>        Move False to bLoadWebApp
36984>>>>>        If (num_arguments >= 2) Begin
36986>>>>>            Move bOptLoadWebApp to bLoadWebApp
36987>>>>>        End
36987>>>>>>
36987>>>>>        
36987>>>>>        Get phoSessionDD to hoSessionDD
36988>>>>>        Get phoUserDD to hoUserDD
36989>>>>>        
36989>>>>>        Get pbLogWebSession to bLogWebSession
36990>>>>>        Get peLoginMode to eLoginMode
36991>>>>>        
36991>>>>>        // for this object, you can only disable logging if login completely is disabled
36991>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36993>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36994>>>>>>
36994>>>>>            Function_Return False
36995>>>>>        End
36995>>>>>>
36995>>>>>
36995>>>>>        //  Clear session properties
36995>>>>>        Set psSessionKey to ""
36996>>>>>        Send UpdateSessionProperties True
36997>>>>>        
36997>>>>>        If not bLogWebSession Begin
36999>>>>>            Forward Get ValidateSession sSessionKey to bResult
37001>>>>>            Function_Return bResult
37002>>>>>        End        
37002>>>>>>
37002>>>>>        
37002>>>>>        Move False to bResult
37003>>>>>        Get piSessionTimeout to iSessionTimeout 
37004>>>>>        
37004>>>>>        //  Check if session exists
37004>>>>>        Send Clear of hoSessionDD
37005>>>>>        Move sSessionKey to WebAppSession.SessionKey
37006>>>>>        Send Find of hoSessionDD EQ Index.1
37007>>>>>            
37007>>>>>        If (Found) Begin
37009>>>>>            //  Calculate timespan between now and last access time
37009>>>>>            Move (CurrentDateTime()) to dtCurrent
37010>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37011>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37012>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37013>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37014>>>>>            
37014>>>>>            //  Check if session didn't time out
37014>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37016>>>>>                Forward Get ValidateSession sSessionKey to bResult
37018>>>>>                   
37018>>>>>                If (bResult) Begin
37020>>>>>                    //  Update session record
37020>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37021>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37022>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37023>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37024>>>>>                    Get Request_Validate of hoSessionDD to iErr
37025>>>>>                    If (iErr) Begin
37027>>>>>                        // this should not happen. If it does its a programming error
37027>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37028>>>>>>
37028>>>>>                        Function_Return False
37029>>>>>                    End
37029>>>>>>
37029>>>>>                    Send Request_Save of hoSessionDD
37030>>>>>                    
37030>>>>>                    //  Update user properties
37030>>>>>                    Send UpdateSessionProperties False
37031>>>>>                End
37031>>>>>>
37031>>>>>            End
37031>>>>>>
37031>>>>>            Else Begin
37032>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37032>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37033>>>>>                
37033>>>>>                If (not(bCreatingNewSession)) Begin
37035>>>>>                    If (not(bLoadWebApp)) Begin
37037>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37038>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37039>>>>>>
37039>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37040>>>>>                    End
37040>>>>>>
37040>>>>>                    Else Begin
37041>>>>>                        Set pbCreatingNewSession to True                    
37042>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37043>>>>>                        Set pbCreatingNewSession to False                        
37044>>>>>                    End
37044>>>>>>
37044>>>>>                End
37044>>>>>>
37044>>>>>            End
37044>>>>>>
37044>>>>>        End
37044>>>>>>
37044>>>>>        Else Begin
37045>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37046>>>>>>
37046>>>>>        End
37046>>>>>>
37046>>>>>        
37046>>>>>        Function_Return bResult
37047>>>>>    End_Function
37048>>>>>    
37048>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37050>>>>>        If (not(pbPasswordHashing(Self))) Begin
37052>>>>>            Move sPassword to sHash
37053>>>>>            Function_Return True
37054>>>>>        End
37054>>>>>>
37054>>>>>        
37054>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37056>>>>>            Function_Return False
37057>>>>>        End
37057>>>>>>
37057>>>>>        Move ("V1$" + sHash) to sHash
37058>>>>>        Function_Return True
37059>>>>>    End_Function
37060>>>>>    
37060>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37062>>>>>        If (not(pbPasswordHashing(Self))) Begin
37064>>>>>            Move False to bShouldUpgrade
37065>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37066>>>>>        End
37066>>>>>>
37066>>>>>        
37066>>>>>        String sVersion
37066>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37067>>>>>        If (sVersion = "V1$") Begin
37069>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37072>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37073>>>>>        End
37073>>>>>>
37073>>>>>        Else Begin
37074>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37077>>>>>            Function_Return False
37078>>>>>        End
37078>>>>>>
37078>>>>>    End_Function
37079>>>>>    
37079>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37081>>>>>        Handle hoUserDD
37081>>>>>        Integer iErr
37081>>>>>        Get phoUserDD to hoUserDD
37082>>>>>        
37082>>>>>        //  Find the user
37082>>>>>        Send Clear of hoUserDD
37083>>>>>        Move sLoginName to WebAppUser.LoginName
37084>>>>>        Send Find of hoUserDD EQ Index.1
37085>>>>>        If (Found) Begin
37087>>>>>            Send Clear of hoUserDD
37088>>>>>            Function_Return False
37089>>>>>        End
37089>>>>>>
37089>>>>>        
37089>>>>>        Send Clear of hoUserDD
37090>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37091>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37092>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37094>>>>>            Send Clear of hoUserDD
37095>>>>>            Function_Return False
37096>>>>>        End
37096>>>>>>
37096>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37097>>>>>        Get Request_Validate of hoUserDD to iErr
37098>>>>>        If (iErr) Begin
37100>>>>>            Send Clear of hoUserDD
37101>>>>>            Function_Return False
37102>>>>>        End
37102>>>>>>
37102>>>>>        
37102>>>>>        Send Request_Save of hoUserDD
37103>>>>>        Function_Return (not(Err))
37104>>>>>    End_Function
37105>>>>>    
37105>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37107>>>>>        String sSessionKey sUserPassword
37107>>>>>        Handle hoSessionDD hoUserDD
37107>>>>>        Boolean bMatch bUpgrade
37107>>>>>        
37107>>>>>        Get phoSessionDD to hoSessionDD
37108>>>>>        Get phoUserDD to hoUserDD
37109>>>>>        Integer iErr eLoginMode
37109>>>>>        
37109>>>>>        // Refind session record
37109>>>>>        Get psSessionKey to sSessionKey
37110>>>>>        Send Clear of hoSessionDD
37111>>>>>        Move sSessionKey to WebAppSession.SessionKey
37112>>>>>        Send Find of hoSessionDD EQ Index.1
37113>>>>>        
37113>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37115>>>>>            Get peLoginMode to eLoginMode
37116>>>>>            
37116>>>>>            //  Find the user
37116>>>>>            Move sLoginName to WebAppUser.LoginName
37117>>>>>            Send Find of hoUserDD EQ Index.1
37118>>>>>            
37118>>>>>            // Check username and password
37118>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37120>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37121>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37122>>>>>                
37122>>>>>                If (bMatch) Begin
37124>>>>>                    // Store the login
37124>>>>>                    If (bUpgrade) Begin
37126>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37127>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37130>>>>>                    End
37130>>>>>>
37130>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37131>>>>>                    Get Request_Validate of hoSessionDD to iErr
37132>>>>>                    If (iErr) Begin
37134>>>>>                        // this should not happen. If it does its a programming error
37134>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37135>>>>>>
37135>>>>>                        Function_Return False
37136>>>>>                    End
37136>>>>>>
37136>>>>>                    
37136>>>>>                    Send Request_Save of hoSessionDD
37137>>>>>                    
37137>>>>>                    // Update session properties
37137>>>>>                    Send UpdateSessionProperties False
37138>>>>>                    Send NotifyChangeRights
37139>>>>>                    Function_Return True
37140>>>>>                End
37140>>>>>>
37140>>>>>                Else Begin
37141>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37141>>>>>                    Send Clear of hoUserDD
37142>>>>>                End
37142>>>>>>
37142>>>>>            End
37142>>>>>>
37142>>>>>            Else Begin
37143>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37143>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37144>>>>>            End
37144>>>>>>
37144>>>>>        End
37144>>>>>>
37144>>>>>        Else Begin
37145>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37145>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37146>>>>>        End
37146>>>>>>
37146>>>>>          
37146>>>>>        Function_Return False
37147>>>>>    End_Function
37148>>>>>    
37148>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37150>>>>>        Handle hoUserDD
37150>>>>>        Integer iErr
37150>>>>>        Get phoUserDD to hoUserDD
37151>>>>>        
37151>>>>>        //  Find the user
37151>>>>>        Send Clear of hoUserDD
37152>>>>>        Move sLoginName to WebAppUser.LoginName
37153>>>>>        Send Find of hoUserDD EQ Index.1
37154>>>>>        If (not(Found)) Begin
37156>>>>>            Send Clear of hoUserDD
37157>>>>>            Function_Return False
37158>>>>>        End
37158>>>>>>
37158>>>>>        
37158>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37160>>>>>            Send Clear of hoUserDD
37161>>>>>            Function_Return False
37162>>>>>        End
37162>>>>>>
37162>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37163>>>>>        Get Request_Validate of hoUserDD to iErr
37164>>>>>        If (iErr) Begin
37166>>>>>            Send Clear of hoUserDD
37167>>>>>            Function_Return False
37168>>>>>        End
37168>>>>>>
37168>>>>>        
37168>>>>>        Send Request_Save of hoUserDD
37169>>>>>        Function_Return (not(Err))
37170>>>>>    End_Function
37171>>>>>    
37171>>>>>    Function IsLoggedIn Returns Boolean
37173>>>>>        String sLoginName
37173>>>>>        Boolean bLogWebSession bLoggedIn
37173>>>>>        
37173>>>>>        Get pbLogWebSession to bLogWebSession
37174>>>>>        If not bLogWebSession Begin
37176>>>>>            Forward Get IsLoggedIn to bLoggedIn
37178>>>>>            Function_Return bLoggedIn
37179>>>>>        End
37179>>>>>>
37179>>>>>        
37179>>>>>        Get psLoginName to sLoginName
37180>>>>>        
37180>>>>>        Function_Return (sLoginName <> "")
37181>>>>>    End_Function
37182>>>>>    
37182>>>>>    
37182>>>>>    //
37182>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37182>>>>>    // update properties based on the session and user data. Augment this function to update 
37182>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37182>>>>>    // the right records when this procedure is called.
37182>>>>>    //
37182>>>>>    // Params:
37182>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37182>>>>>    //
37182>>>>>    Procedure UpdateSessionProperties Boolean bClear
37184>>>>>        Handle hoUserDD
37184>>>>>        
37184>>>>>        Get phoUserDD to hoUserDD
37185>>>>>        
37185>>>>>        //  Update user properties
37185>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37187>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37188>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37189>>>>>            Set piUserRights to WebAppUser.Rights
37190>>>>>            
37190>>>>>            Send OnSessionPropertiesSet 
37191>>>>>        End
37191>>>>>>
37191>>>>>        Else Begin
37192>>>>>            Set psUsername to ""
37193>>>>>            Set psLoginName to ""
37194>>>>>            Set piUserRights to 0
37195>>>>>            
37195>>>>>            Send OnSessionPropertiesClear
37196>>>>>        End
37196>>>>>>
37196>>>>>    End_Procedure
37197>>>>>    
37197>>>>>    Procedure OnSessionPropertiesSet
37199>>>>>        //  Empty event stub
37199>>>>>    End_Procedure
37200>>>>>    
37200>>>>>    Procedure OnSessionPropertiesClear
37202>>>>>        //  Empty event stub
37202>>>>>    End_Procedure
37203>>>>>    
37203>>>>>    Procedure EndSession
37205>>>>>        Integer iErr
37205>>>>>        Boolean bLogWebSession
37205>>>>>        Handle hoSessionDD       
37205>>>>>        
37205>>>>>        Get phoSessionDD to hoSessionDD
37206>>>>>        Get pbLogWebSession to bLogWebSession
37207>>>>>        If not bLogWebSession Begin
37209>>>>>            Forward Send EndSession
37211>>>>>            Procedure_Return
37212>>>>>        End
37212>>>>>>
37212>>>>>            
37212>>>>>        //  Check if session exists
37212>>>>>        Send Clear of hoSessionDD
37213>>>>>        Get psSessionKey to WebAppSession.SessionKey
37214>>>>>        
37214>>>>>        Send Find of hoSessionDD EQ Index.1
37215>>>>>        If (Found) Begin
37217>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37218>>>>>            Get Request_Validate of hoSessionDD to iErr
37219>>>>>            If (iErr) Begin
37221>>>>>                // this should not happen. If it does its a programming error
37221>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37222>>>>>>
37222>>>>>                Procedure_Return
37223>>>>>            End
37223>>>>>>
37223>>>>>            Send Request_Save of hoSessionDD
37224>>>>>        End
37224>>>>>>
37224>>>>>    End_Procedure
37225>>>>>
37225>>>>>End_Class
