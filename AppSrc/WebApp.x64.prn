39036>>>                    //   (See 2 above). 
39036>>>                    Case Break
39037>>>                Case (NavigateData.eNavigateType=nfFromChild)
39040>>>                    // If from child, this is a probably a parent lookup from a Zoom,
39040>>>                    // so you just want to close (See 1 above)
39040>>>                    Send NavigateClose Self
39041>>>                    Case Break
39042>>>                Case (NavigateData.eNavigateType=nfFromMain)
39045>>>                    // If from main, this is a propbably a main file lookup from a Zoom, 
39045>>>                    // so you just want to close (see 1 above). 
39045>>>                    // This is not used often with the drilldown style
39045>>>                    Send NavigateClose Self
39046>>>                    Case Break
39047>>>                Case Else // must be nfUndefined
39047>>>                    // This may be the start of a drilldown query or some kind of custom query.
39047>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
39047>>>            Case End
