37955>>>    // This can be used to show and hide buttons based on context.
37955>>>    // This can be called any time the view is active.
37955>>>    Procedure SetActionButtons
37958>>>        tWebNavigateData NavigateData
37958>>>        tWebNavigateData NavigateData
37958>>>        Boolean bHasRecord
37958>>>        Handle hoDD
37958>>>
37958>>>        Get Server to hoDD
37959>>>        Get GetNavigateData to NavigateData
37960>>>        
37960>>>        If (hoDD) Begin
37962>>>            Get HasRecord of hoDD to bHasRecord
37963>>>        End
37963>>>>
37963>>>        Else Begin
37964>>>            Move False to bHasRecord
37965>>>        End
37965>>>>
37965>>>
37965>>>        // let's hide all buttons and then show the ones we want
37965>>>        WebSet pbRender of oEditBtn to False 
37966>>>        WebSet pbRender of oSaveBtn to False
37967>>>        WebSet pbRender of oCancelChangesBtn to False
37968>>>        WebSet pbRender of oDeleteBtn to False
37969>>>
37969>>>        If (NavigateData.bReadOnly) Begin 
37971>>>            WebSet pbRender of oEditBtn to True 
37972>>>        End
37972>>>>
37972>>>        Else Begin
37973>>>            WebSet pbRender of oSaveBtn to True
37974>>>            WebSet pbRender of oCancelChangesBtn to True
37975>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37976>>>        End
37976>>>>
37976>>>    End_Procedure
