38200>>>    // This can be used to show and hide buttons based on context.
38200>>>    // This can be called any time the view is active.
38200>>>    Procedure SetActionButtons
38203>>>        tWebNavigateData NavigateData
38203>>>        tWebNavigateData NavigateData
38203>>>        Boolean bHasRecord
38203>>>        Handle hoDD
38203>>>
38203>>>        Get Server to hoDD
38204>>>        Get GetNavigateData to NavigateData
38205>>>        
38205>>>        If (hoDD) Begin
38207>>>            Get HasRecord of hoDD to bHasRecord
38208>>>        End
38208>>>>
38208>>>        Else Begin
38209>>>            Move False to bHasRecord
38210>>>        End
38210>>>>
38210>>>
38210>>>        // let's hide all buttons and then show the ones we want
38210>>>        WebSet pbRender of oEditBtn to False 
38211>>>        WebSet pbRender of oSaveBtn to False
38212>>>        WebSet pbRender of oCancelChangesBtn to False
38213>>>        WebSet pbRender of oDeleteBtn to False
38214>>>
38214>>>        If (NavigateData.bReadOnly) Begin 
38216>>>            WebSet pbRender of oEditBtn to True 
38217>>>        End
38217>>>>
38217>>>        Else Begin
38218>>>            WebSet pbRender of oSaveBtn to True
38219>>>            WebSet pbRender of oCancelChangesBtn to True
38220>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38221>>>        End
38221>>>>
38221>>>    End_Procedure
38222>>>
38222>>>    // this will close the view after a save
38222>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38225>>>        Send NavigateClose Self
38226>>>    End_Procedure
38227>>>
38227>>>    // this will close the view after a delete
38227>>>    Procedure OnViewDeleted Handle hoDDO
38230>>>        Send NavigateClose Self
38231>>>    End_Procedure
