36842>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36843>>>>>    
36843>>>>>    Procedure Construct_Object
36845>>>>>        Handle hoObj
36845>>>>>        
36845>>>>>        Forward Send Construct_Object
36847>>>>>        
36847>>>>>        Set pbSessionCookieHttpOnly to True
36848>>>>>        
36848>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36849>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36850>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36851>>>>>        
36851>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36852>>>>>        Set phoUserDD to hoObj
36853>>>>>        
36853>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36854>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36855>>>>>        Set phoSessionDD to hoObj
36856>>>>>        
36856>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36857>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36858>>>>>        Set phoCrypto to hoObj
36859>>>>>        
36859>>>>>        Property Boolean pbPasswordHashing True
36860>>>>>        
36860>>>>>        Property Boolean pbCreatingNewSession False
36861>>>>>        Property String psLoginName
36862>>>>>        Property String psUserName ""
36863>>>>>        Property Integer piUserRights 0
36864>>>>>    End_Procedure
36865>>>>>    
36865>>>>>    Procedure End_Construct_Object
36867>>>>>        Forward Send End_Construct_Object
36869>>>>>        
36869>>>>>        Handle hoCrypto
36869>>>>>        Integer iFieldLen
36869>>>>>        If (pbPasswordHashing(Self)) Begin
36871>>>>>            Get phoCrypto to hoCrypto
36872>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36875>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36877>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36878>>>>>>
36878>>>>>            End
36878>>>>>>
36878>>>>>        End
36878>>>>>>
36878>>>>>    End_Procedure
36879>>>>>    
36879>>>>>    Function CreateSession String sRemoteAddress Returns String
36881>>>>>        String sSessionKey
36881>>>>>        Integer iErr
36881>>>>>        Boolean bLogWebSession
36881>>>>>        Handle hoSessionDD       
36881>>>>>        Get phoSessionDD to hoSessionDD
36882>>>>>        
36882>>>>>        //  Get session key
36882>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36884>>>>>        
36884>>>>>        Get pbLogWebSession to bLogWebSession
36885>>>>>        If not bLogWebSession Begin
36887>>>>>            Function_Return sSessionKey        
36888>>>>>        End
36888>>>>>>
36888>>>>>
36888>>>>>        //  Store session
36888>>>>>        Send Clear of hoSessionDD
36889>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36890>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36891>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36892>>>>>        Get Request_Validate of hoSessionDD to iErr
36893>>>>>        If (iErr) Begin
36895>>>>>            // this should not happen. If it does its a programming error
36895>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36896>>>>>>
36896>>>>>            Function_Return ""
36897>>>>>        End
36897>>>>>>
36897>>>>>        Send Request_Save of hoSessionDD
36898>>>>>        If (Err) Begin
36900>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36900>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36901>>>>>>
36901>>>>>            Function_Return ""
36902>>>>>        End
36902>>>>>>
36902>>>>>       
36902>>>>>        Function_Return sSessionKey        
36903>>>>>    End_Function
36904>>>>>    
36904>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36906>>>>>        DateTime dtLastAccess dtCurrent
36906>>>>>        TimeSpan tsDiff
36906>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36906>>>>>        Boolean bResult bCreatingNewSession
36906>>>>>        Boolean bLogWebSession bLoadWebApp
36906>>>>>        Integer eLoginMode
36906>>>>>        String sTime
36906>>>>>        Handle hoSessionDD hoUserDD       
36906>>>>>        
36906>>>>>        Move False to bLoadWebApp
36907>>>>>        If (num_arguments >= 2) Begin
36909>>>>>            Move bOptLoadWebApp to bLoadWebApp
36910>>>>>        End
36910>>>>>>
36910>>>>>        
36910>>>>>        Get phoSessionDD to hoSessionDD
36911>>>>>        Get phoUserDD to hoUserDD
36912>>>>>        
36912>>>>>        Get pbLogWebSession to bLogWebSession
36913>>>>>        Get peLoginMode to eLoginMode
36914>>>>>        
36914>>>>>        // for this object, you can only disable logging if login completely is disabled
36914>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36916>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36917>>>>>>
36917>>>>>            Function_Return False
36918>>>>>        End
36918>>>>>>
36918>>>>>
36918>>>>>        //  Clear session properties
36918>>>>>        Set psSessionKey to ""
36919>>>>>        Send UpdateSessionProperties True
36920>>>>>        
36920>>>>>        If not bLogWebSession Begin
36922>>>>>            Forward Get ValidateSession sSessionKey to bResult
36924>>>>>            Function_Return bResult
36925>>>>>        End        
36925>>>>>>
36925>>>>>        
36925>>>>>        Move False to bResult
36926>>>>>        Get piSessionTimeout to iSessionTimeout 
36927>>>>>        
36927>>>>>        //  Check if session exists
36927>>>>>        Send Clear of hoSessionDD
36928>>>>>        Move sSessionKey to WebAppSession.SessionKey
36929>>>>>        Send Find of hoSessionDD EQ Index.1
36930>>>>>            
36930>>>>>        If (Found) Begin
36932>>>>>            //  Calculate timespan between now and last access time
36932>>>>>            Move (CurrentDateTime()) to dtCurrent
36933>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36934>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36935>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36936>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36937>>>>>            
36937>>>>>            //  Check if session didn't time out
36937>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
36939>>>>>                Forward Get ValidateSession sSessionKey to bResult
36941>>>>>                   
36941>>>>>                If (bResult) Begin
36943>>>>>                    //  Update session record
36943>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
36944>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
36945>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
36946>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
36947>>>>>                    Get Request_Validate of hoSessionDD to iErr
36948>>>>>                    If (iErr) Begin
36950>>>>>                        // this should not happen. If it does its a programming error
36950>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36951>>>>>>
36951>>>>>                        Function_Return False
36952>>>>>                    End
36952>>>>>>
36952>>>>>                    Send Request_Save of hoSessionDD
36953>>>>>                    
36953>>>>>                    //  Update user properties
36953>>>>>                    Send UpdateSessionProperties False
36954>>>>>                End
36954>>>>>>
36954>>>>>            End
36954>>>>>>
36954>>>>>            Else Begin
36955>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
36955>>>>>                Get pbCreatingNewSession to bCreatingNewSession
36956>>>>>                
36956>>>>>                If (not(bCreatingNewSession)) Begin
36958>>>>>                    If (not(bLoadWebApp)) Begin
36960>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
36961>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
36962>>>>>>
36962>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
36963>>>>>                    End
36963>>>>>>
36963>>>>>                    Else Begin
36964>>>>>                        Set pbCreatingNewSession to True                    
36965>>>>>                        Get RecreateSession of ghoWebApp to bResult 
36966>>>>>                        Set pbCreatingNewSession to False                        
36967>>>>>                    End
36967>>>>>>
36967>>>>>                End
36967>>>>>>
36967>>>>>            End
36967>>>>>>
36967>>>>>        End
36967>>>>>>
36967>>>>>        Else Begin
36968>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
36969>>>>>>
36969>>>>>        End
36969>>>>>>
36969>>>>>        
36969>>>>>        Function_Return bResult
36970>>>>>    End_Function
36971>>>>>    
36971>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36973>>>>>        If (not(pbPasswordHashing(Self))) Begin
36975>>>>>            Move sPassword to sHash
36976>>>>>            Function_Return True
36977>>>>>        End
36977>>>>>>
36977>>>>>        
36977>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
36979>>>>>            Function_Return False
36980>>>>>        End
36980>>>>>>
36980>>>>>        Move ("V1$" + sHash) to sHash
36981>>>>>        Function_Return True
36982>>>>>    End_Function
36983>>>>>    
36983>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
36985>>>>>        If (not(pbPasswordHashing(Self))) Begin
36987>>>>>            Move False to bShouldUpgrade
36988>>>>>            Function_Return (sUserPassword = sEnteredPassword)
36989>>>>>        End
36989>>>>>>
36989>>>>>        
36989>>>>>        String sVersion
36989>>>>>        Move (Left(sUserPassword, 3)) to sVersion
36990>>>>>        If (sVersion = "V1$") Begin
36992>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
36995>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
36996>>>>>        End
36996>>>>>>
36996>>>>>        Else Begin
36997>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37000>>>>>            Function_Return False
37001>>>>>        End
37001>>>>>>
37001>>>>>    End_Function
37002>>>>>    
37002>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37004>>>>>        Handle hoUserDD
37004>>>>>        Integer iErr
37004>>>>>        Get phoUserDD to hoUserDD
37005>>>>>        
37005>>>>>        //  Find the user
37005>>>>>        Send Clear of hoUserDD
37006>>>>>        Move sLoginName to WebAppUser.LoginName
37007>>>>>        Send Find of hoUserDD EQ Index.1
37008>>>>>        If (Found) Begin
37010>>>>>            Send Clear of hoUserDD
37011>>>>>            Function_Return False
37012>>>>>        End
37012>>>>>>
37012>>>>>        
37012>>>>>        Send Clear of hoUserDD
37013>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37014>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37015>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37017>>>>>            Send Clear of hoUserDD
37018>>>>>            Function_Return False
37019>>>>>        End
37019>>>>>>
37019>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37020>>>>>        Get Request_Validate of hoUserDD to iErr
37021>>>>>        If (iErr) Begin
37023>>>>>            Send Clear of hoUserDD
37024>>>>>            Function_Return False
37025>>>>>        End
37025>>>>>>
37025>>>>>        
37025>>>>>        Send Request_Save of hoUserDD
37026>>>>>        Function_Return (not(Err))
37027>>>>>    End_Function
37028>>>>>    
37028>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37030>>>>>        String sSessionKey sUserPassword
37030>>>>>        Handle hoSessionDD hoUserDD
37030>>>>>        Boolean bMatch bUpgrade
37030>>>>>        
37030>>>>>        Get phoSessionDD to hoSessionDD
37031>>>>>        Get phoUserDD to hoUserDD
37032>>>>>        Integer iErr eLoginMode
37032>>>>>        
37032>>>>>        // Refind session record
37032>>>>>        Get psSessionKey to sSessionKey
37033>>>>>        Send Clear of hoSessionDD
37034>>>>>        Move sSessionKey to WebAppSession.SessionKey
37035>>>>>        Send Find of hoSessionDD EQ Index.1
37036>>>>>        
37036>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37038>>>>>            Get peLoginMode to eLoginMode
37039>>>>>            
37039>>>>>            //  Find the user
37039>>>>>            Move sLoginName to WebAppUser.LoginName
37040>>>>>            Send Find of hoUserDD EQ Index.1
37041>>>>>            
37041>>>>>            // Check username and password
37041>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37043>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37044>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37045>>>>>                
37045>>>>>                If (bMatch) Begin
37047>>>>>                    // Store the login
37047>>>>>                    If (bUpgrade) Begin
37049>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37050>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37053>>>>>                    End
37053>>>>>>
37053>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37054>>>>>                    Get Request_Validate of hoSessionDD to iErr
37055>>>>>                    If (iErr) Begin
37057>>>>>                        // this should not happen. If it does its a programming error
37057>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37058>>>>>>
37058>>>>>                        Function_Return False
37059>>>>>                    End
37059>>>>>>
37059>>>>>                    
37059>>>>>                    Send Request_Save of hoSessionDD
37060>>>>>                    
37060>>>>>                    // Update session properties
37060>>>>>                    Send UpdateSessionProperties False
37061>>>>>                    Send NotifyChangeRights
37062>>>>>                    Function_Return True
37063>>>>>                End
37063>>>>>>
37063>>>>>                Else Begin
37064>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37064>>>>>                    Send Clear of hoUserDD
37065>>>>>                End
37065>>>>>>
37065>>>>>            End
37065>>>>>>
37065>>>>>            Else Begin
37066>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37066>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37067>>>>>            End
37067>>>>>>
37067>>>>>        End
37067>>>>>>
37067>>>>>        Else Begin
37068>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37068>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37069>>>>>        End
37069>>>>>>
37069>>>>>          
37069>>>>>        Function_Return False
37070>>>>>    End_Function
37071>>>>>    
37071>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37073>>>>>        Handle hoUserDD
37073>>>>>        Integer iErr
37073>>>>>        Get phoUserDD to hoUserDD
37074>>>>>        
37074>>>>>        //  Find the user
37074>>>>>        Send Clear of hoUserDD
37075>>>>>        Move sLoginName to WebAppUser.LoginName
37076>>>>>        Send Find of hoUserDD EQ Index.1
37077>>>>>        If (not(Found)) Begin
37079>>>>>            Send Clear of hoUserDD
37080>>>>>            Function_Return False
37081>>>>>        End
37081>>>>>>
37081>>>>>        
37081>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37083>>>>>            Send Clear of hoUserDD
37084>>>>>            Function_Return False
37085>>>>>        End
37085>>>>>>
37085>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37086>>>>>        Get Request_Validate of hoUserDD to iErr
37087>>>>>        If (iErr) Begin
37089>>>>>            Send Clear of hoUserDD
37090>>>>>            Function_Return False
37091>>>>>        End
37091>>>>>>
37091>>>>>        
37091>>>>>        Send Request_Save of hoUserDD
37092>>>>>        Function_Return (not(Err))
37093>>>>>    End_Function
