37591>>>        // What to do when the row is selected.
37591>>>        //
37591>>>        // Depending on how you are using this view, you may wish to
37591>>>        // 1. Close the view, which will update the invoking view:
37591>>>        //      Send NavigateClose Self
37591>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
37591>>>        //      Send NavigateForward of oZoomMainView Self
37591>>>        //      Send NavigateForward of oSelectChildView Self
37591>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
37591>>>        Procedure OnRowClick String sRowID
37594>>>
37594>>>            // If this view is being used in multiple contexts, you may need a block of code
37594>>>            // like this to handle different types of navigation
37594>>>            tWebNavigateData NavigateData
37594>>>            tWebNavigateData NavigateData
37594>>>            Get GetNavigateData to NavigateData
37595>>>            Case Begin
37595>>>                Case (NavigateData.eNavigateType=nfFromParent)
37597>>>                    // If from parent, this is a constrained drilldown.
37597>>>                    // If here, you probably want to Zoom this record or continue to drilldown
37597>>>                    //   (See 2 above). 
37597>>>                    Case Break
37598>>>                Case (NavigateData.eNavigateType=nfFromChild)
37601>>>                    // If from child, this is a probably a parent lookup from a Zoom,
37601>>>                    // so you just want to close (See 1 above)
37601>>>                    Send NavigateClose Self
37602>>>                    Case Break
37603>>>                Case (NavigateData.eNavigateType=nfFromMain)
37606>>>                    // If from main, this is a propbably a main file lookup from a Zoom, 
37606>>>                    // so you just want to close (see 1 above). 
37606>>>                    // This is not used often with the drilldown style
37606>>>                    Send NavigateClose Self
37607>>>                    Case Break
37608>>>                Case Else // must be nfUndefined
37608>>>                    // This may be the start of a drilldown query or some kind of custom query.
37608>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
37608>>>            Case End
37608>>>
37608>>>        End_Procedure
