38299>>>                    //   (See 2 above). 
38299>>>                    Case Break
38300>>>                Case (NavigateData.eNavigateType=nfFromChild)
38303>>>                    // If from child, this is a probably a parent lookup from a Zoom,
38303>>>                    // so you just want to close (See 1 above)
38303>>>                    Send NavigateClose Self
38304>>>                    Case Break
38305>>>                Case (NavigateData.eNavigateType=nfFromMain)
38308>>>                    // If from main, this is a propbably a main file lookup from a Zoom, 
38308>>>                    // so you just want to close (see 1 above). 
38308>>>                    // This is not used often with the drilldown style
38308>>>                    Send NavigateClose Self
38309>>>                    Case Break
38310>>>                Case Else // must be nfUndefined
38310>>>                    // This may be the start of a drilldown query or some kind of custom query.
38310>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
38310>>>            Case End
38310>>>
38310>>>        End_Procedure
