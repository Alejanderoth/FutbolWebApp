37374>>>        Get StateHash of ghoWebApp to sPrevStateHash
37375>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37376>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37378>>>            WebSet psPrevStateHash to sPrevStateHash
37379>>>        End
37379>>>>
37379>>>        
37379>>>    End_Procedure
