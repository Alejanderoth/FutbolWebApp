36768>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36770>>>>>>>        UChar[] ucaSalt
36771>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36772>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36775>>>>>>>        
36775>>>>>>>        If (num_arguments > 4) Begin
36777>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36778>>>>>>>        End
36778>>>>>>>>
36778>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36779>>>>>>>    End_Function
36780>>>>>>>    
36780>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36782>>>>>>>        Boolean bRequiresTimeCost
36782>>>>>>>        UInteger uiAlgo uiTimeCost
36782>>>>>>>        Integer iBegin iEnd
36782>>>>>>>        String sSalt
36782>>>>>>>        
36782>>>>>>>        Move 1 to iBegin
36783>>>>>>>        
36783>>>>>>>        // Parse Algo
36783>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36784>>>>>>>        If (not(iEnd)) Function_Return False
36787>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36788>>>>>>>        
36788>>>>>>>        // Parse Salt
36788>>>>>>>        Move (iEnd + 1) to iBegin
36789>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36790>>>>>>>        If (not(iEnd)) Function_Return False
36793>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36794>>>>>>>        
36794>>>>>>>        Case Begin
36794>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36796>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36799>>>>>>>                Move True to bRequiresTimeCost
36800>>>>>>>                Case Break
36801>>>>>>>            Case Else
36801>>>>>>>                Error 8710 "Invalid algorithm selected."
36802>>>>>>>>
36802>>>>>>>                Function_Return False
36803>>>>>>>        Case End
36803>>>>>>>        
36803>>>>>>>        // Parse optional timecost
36803>>>>>>>        If (bRequiresTimeCost) Begin
36805>>>>>>>            Move (iEnd + 1) to iBegin
36806>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36807>>>>>>>            If (not(iEnd)) Function_Return False
36810>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36811>>>>>>>        End
36811>>>>>>>>
36811>>>>>>>        
36811>>>>>>>        // Parse rest hash
36811>>>>>>>        Move (iEnd + 1) to iBegin
36812>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36813>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36816>>>>>>>        
36816>>>>>>>        // Base64Decode
36816>>>>>>>        UChar[] ucaSalt
36817>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36818>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36821>>>>>>>        
36821>>>>>>>        // Create new hash
36821>>>>>>>        String sNewHash
36821>>>>>>>        If (bRequiresTimeCost) Begin
36823>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36825>>>>>>>                Function_Return False 
36826>>>>>>>            End
36826>>>>>>>>
36826>>>>>>>        End
36826>>>>>>>>
36826>>>>>>>        Else Begin
36827>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36829>>>>>>>                Function_Return False 
36830>>>>>>>            End
36830>>>>>>>>
36830>>>>>>>        End
36830>>>>>>>>
36830>>>>>>>        Function_Return (sNewHash = sHash)
36831>>>>>>>    End_Function
36832>>>>>>>    
36832>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36834>>>>>>>        Boolean bRequireTimeCost
36834>>>>>>>        UBigInt ullSize
36834>>>>>>>        UChar[] ucaSalt
36835>>>>>>>        String sSalt
36835>>>>>>>        
36835>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36836>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36837>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36840>>>>>>>        
36840>>>>>>>        Case Begin
36840>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36842>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36843>>>>>>>                Move True to bRequireTimeCost
36844>>>>>>>                Case Break
36845>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36848>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36849>>>>>>>                Move True to bRequireTimeCost
36850>>>>>>>                Case Break
36851>>>>>>>            Case Else
36851>>>>>>>                Error 8710 "Invalid algorithm selected."
36852>>>>>>>>
36852>>>>>>>                Function_Return 0
36853>>>>>>>        Case End
36853>>>>>>>        
36853>>>>>>>        // calculate base64 in a non-floating-manner
36853>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36854>>>>>>>        
36854>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36855>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36856>>>>>>>        If (bRequireTimeCost) Begin
36858>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36859>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36860>>>>>>>        End
36860>>>>>>>>
36860>>>>>>>        Else Begin
36861>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36862>>>>>>>        End
36862>>>>>>>>
36862>>>>>>>        
36862>>>>>>>        Function_Return ullSize
36863>>>>>>>    End_Function
36864>>>>>>>End_Class
36865>>>>>>>
36865>>>>>>>Class cPasswordHasher is a cObject
36866>>>>>>>    
36866>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36867>>>>>>>    
36867>>>>>>>    Procedure Construct_Object
36869>>>>>>>        Forward Send Construct_Object
36871>>>>>>>        
36871>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36872>>>>>>>        Property UInteger   puiSaltSize         16
36873>>>>>>>        
36873>>>>>>>        Property UInteger   puiOptTimeCost      420000
36874>>>>>>>    End_Procedure
36875>>>>>>>    
36875>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36877>>>>>>>        Boolean bOk
36877>>>>>>>        UInteger uiAlgo
36877>>>>>>>        Get peAlgorithm to uiAlgo
36878>>>>>>>        
36878>>>>>>>        Case Begin
36878>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36880>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36883>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36884>>>>>>>                Case Break
36885>>>>>>>            Case Else
36885>>>>>>>                Error 8710 "Invalid algorithm selected."
36886>>>>>>>>
36886>>>>>>>                Function_Return False
36887>>>>>>>        Case End
36887>>>>>>>        
36887>>>>>>>        Function_Return bOk
36888>>>>>>>    End_Function
36889>>>>>>>    
36889>>>>>>>    Function RequiredBufferSize Returns UBigInt
36891>>>>>>>        UBigInt ullSize
36891>>>>>>>        UInteger uiAlgo
36891>>>>>>>        Get peAlgorithm to uiAlgo
36892>>>>>>>        
36892>>>>>>>        Case Begin
36892>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36894>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36897>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36898>>>>>>>                Case Break
36899>>>>>>>            Case Else
36899>>>>>>>                Error 8710 "Invalid algorithm selected."
36900>>>>>>>>
36900>>>>>>>                Function_Return 0
36901>>>>>>>        Case End
36901>>>>>>>        
36901>>>>>>>        Function_Return ullSize
36902>>>>>>>    End_Function
36903>>>>>>>
36903>>>>>>>End_Class
