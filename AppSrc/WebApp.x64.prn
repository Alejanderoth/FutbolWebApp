38992>>>                    // If from parent, this is a constrained drilldown.
38992>>>                    // If here, you probably want to Zoom this record or continue to drilldown
38992>>>                    //   (See 2 above). 
38992>>>                    Case Break
38993>>>                Case (NavigateData.eNavigateType=nfFromChild)
38996>>>                    // If from child, this is a probably a parent lookup from a Zoom,
38996>>>                    // so you just want to close (See 1 above)
38996>>>                    Send NavigateClose Self
38997>>>                    Case Break
38998>>>                Case (NavigateData.eNavigateType=nfFromMain)
39001>>>                    // If from main, this is a propbably a main file lookup from a Zoom, 
39001>>>                    // so you just want to close (see 1 above). 
39001>>>                    // This is not used often with the drilldown style
39001>>>                    Send NavigateClose Self
39002>>>                    Case Break
39003>>>                Case Else // must be nfUndefined
39003>>>                    // This may be the start of a drilldown query or some kind of custom query.
39003>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
39003>>>            Case End
39003>>>
39003>>>        End_Procedure
