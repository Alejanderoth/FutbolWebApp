38349>>>        // What to do when the row is selected.
38349>>>        //
38349>>>        // Depending on how you are using this view, you may wish to
38349>>>        // 1. Close the view, which will update the invoking view:
38349>>>        //      Send NavigateClose Self
38349>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
38349>>>        //      Send NavigateForward of oZoomMainView Self
38349>>>        //      Send NavigateForward of oSelectChildView Self
38349>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
38349>>>        Procedure OnRowClick String sRowID
38352>>>
38352>>>            // If this view is being used in multiple contexts, you may need a block of code
38352>>>            // like this to handle different types of navigation
38352>>>            tWebNavigateData NavigateData
38352>>>            tWebNavigateData NavigateData
38352>>>            Get GetNavigateData to NavigateData
38353>>>            Case Begin
38353>>>                Case (NavigateData.eNavigateType=nfFromParent)
38355>>>                    // If from parent, this is a constrained drilldown.
38355>>>                    // If here, you probably want to Zoom this record or continue to drilldown
38355>>>                    //   (See 2 above). 
38355>>>                    Case Break
38356>>>                Case (NavigateData.eNavigateType=nfFromChild)
38359>>>                    // If from child, this is a probably a parent lookup from a Zoom,
38359>>>                    // so you just want to close (See 1 above)
38359>>>                    Send NavigateClose Self
38360>>>                    Case Break
38361>>>                Case (NavigateData.eNavigateType=nfFromMain)
38364>>>                    // If from main, this is a propbably a main file lookup from a Zoom, 
38364>>>                    // so you just want to close (see 1 above). 
38364>>>                    // This is not used often with the drilldown style
38364>>>                    Send NavigateClose Self
38365>>>                    Case Break
38366>>>                Case Else // must be nfUndefined
38366>>>                    // This may be the start of a drilldown query or some kind of custom query.
38366>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
38366>>>            Case End
38366>>>
38366>>>        End_Procedure
